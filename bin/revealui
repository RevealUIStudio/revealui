#!/usr/bin/env bash
# revealui — RevealUI developer CLI
# Usage: reveal <command> [args]
set -euo pipefail

REVEAL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

_cmd="${1:-help}"
shift 2>/dev/null || true

_die()  { echo "error: $*" >&2; exit 1; }
_info() { echo -e "\033[2m$*\033[0m"; }
_ok()   { echo -e "\033[1;38;2;52;211;153m✓\033[0m $*"; }
_warn() { echo -e "\033[1;38;2;251;191;36m⚠\033[0m  $*"; }

case "$_cmd" in

  dev)
    cd "$REVEAL_ROOT"

    if [ -n "${IN_NIX_SHELL:-}" ]; then
      _warn "already in dev environment"
      exit 0
    fi

    command -v nix &>/dev/null || _die "nix is not installed — see https://nixos.org/download"

    _info "starting dev environment…"
    exec nix develop
    ;;

  db)
    _sub="${1:-help}"
    shift 2>/dev/null || true
    _PGDATA="${PGDATA:-$REVEAL_ROOT/.pgdata}"
    _PGHOST="${PGHOST:-$_PGDATA}"
    case "$_sub" in
      start)
        command -v pg_ctl &>/dev/null || _die "pg_ctl not found — enter the dev environment first (direnv allow, or nix develop)"
        if [ ! -d "$_PGDATA" ]; then
          _die "postgres not initialized — run 'revealui db init' first"
        fi
        if pg_ctl status -D "$_PGDATA" &>/dev/null; then
          _warn "postgres is already running"; exit 0
        fi
        pg_ctl start -D "$_PGDATA" -l "$_PGDATA/logfile" -o "-k $_PGDATA"
        _ok "postgres started  (connect: psql -h $_PGHOST -d postgres)"
        ;;
      stop)
        command -v pg_ctl &>/dev/null || _die "pg_ctl not found — enter the dev environment first"
        if ! pg_ctl status -D "$_PGDATA" &>/dev/null; then
          _warn "postgres is not running"; exit 0
        fi
        pg_ctl stop -D "$_PGDATA"
        _ok "postgres stopped"
        ;;
      status)
        command -v pg_ctl &>/dev/null || _die "pg_ctl not found — enter the dev environment first"
        if pg_ctl status -D "$_PGDATA" &>/dev/null; then
          _ok "postgres is running"
          pg_ctl status -D "$_PGDATA"
        else
          _warn "postgres is not running"
        fi
        ;;
      init)
        command -v initdb &>/dev/null || _die "initdb not found — enter the dev environment first (direnv allow, or nix develop)"
        if [ -d "$_PGDATA" ]; then
          _die "postgres already initialized at $_PGDATA — use 'revealui db reset' to wipe and reinitialize"
        fi
        _info "initializing postgres at $_PGDATA…"
        initdb --locale=C.UTF-8 --encoding=UTF8 -D "$_PGDATA" --username=postgres
        printf '\n# RevealUI Development Settings\nlisten_addresses = '"'"'localhost'"'"'\nport = 5432\nmax_connections = 100\nshared_buffers = 128MB\nunix_socket_directories = '"'"'%s'"'"'\n' "$_PGDATA" >> "$_PGDATA/postgresql.conf"
        printf '# TYPE  DATABASE  USER  ADDRESS      METHOD\nlocal   all       all               trust\nhost    all       all   127.0.0.1/32 trust\nhost    all       all   ::1/128      trust\n' > "$_PGDATA/pg_hba.conf"
        _ok "postgres initialized — run 'revealui db start' to start the server"
        ;;
      reset)
        command -v pg_ctl &>/dev/null || _die "pg_ctl not found — enter the dev environment first"
        pg_ctl stop -D "$_PGDATA" &>/dev/null || true
        rm -rf "$_PGDATA"
        "$0" db init
        ;;
      psql)
        command -v psql &>/dev/null || _die "psql not found — enter the dev environment first"
        if ! pg_ctl status -D "$_PGDATA" &>/dev/null; then
          _die "postgres is not running — run 'revealui db start' first"
        fi
        exec psql -h "$_PGHOST" -U postgres -d postgres "$@"
        ;;
      *)
        echo "Usage: revealui db <start|stop|status|init|reset|psql>"
        ;;
    esac
    ;;

  help|--help|-h|"")
    echo ""
    echo "  Usage: revealui <command>"
    echo ""
    echo "  Commands:"
    echo "    dev              enter the nix dev environment"
    echo "    db <subcommand>  database management"
    echo ""
    echo "  Database subcommands:"
    echo "    db start         start postgres"
    echo "    db stop          stop postgres"
    echo "    db status        check postgres status"
    echo "    db init          initialize postgres"
    echo "    db reset         wipe and reinitialize"
    echo "    db psql          open postgres shell"
    echo ""
    ;;

  *)
    _die "unknown command: $_cmd — run 'revealui help'"
    ;;
esac
