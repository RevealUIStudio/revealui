# Dependencies
node_modules/

# Windows NTFS alternate data streams
*:Zone.Identifier
.pnp
.pnp.js
.pnpm-store/

# Testing
coverage/
*.lcov
.nyc_output/

# Playwright E2E Testing
test-results/
playwright-report/
playwright/.cache/
e2e/.auth/
*.trace.zip

# Playwright Visual Snapshots
# Keep baseline snapshots (*.png in __snapshots__/) committed
# Ignore generated diff and actual images from failed tests
**/__snapshots__/**/*-actual.png
**/__snapshots__/**/*-diff.png
**/__snapshots__/**/*-previous.png

# Production
build/
dist/
.next/
out/

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Output/log files
*_output.txt
*-errors.txt
categorized-errors.txt
lint-output.txt

# Local env files (secrets - never commit)
.env
.env*.local
.env.development.local
.env.production.local
.env.test.local

# Backup env files (archived old versions)
.env.backups/
.env.backup
.env.clean

# Template file is committed (.env.template)
# .envrc is committed (direnv config, no secrets)

# Vercel — ignore build output but commit project.json (needed for CI deploys)
.vercel/output
.vercel/cache

# TypeScript
*.tsbuildinfo
next-env.d.ts

# TypeScript build artifacts in source directories
# (These should be in dist/ but sometimes tsc outputs to src/)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map
scripts/**/*.js
scripts/**/*.d.ts
scripts/**/*.js.map
scripts/**/*.d.ts.map
# Allow committed .js config files
!**/*.config.js
!**/jest.config.js
!**/vitest.config.js

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db

# Load test results
load-tests/results/
*.json.gz

# Sentry
.sentryclirc

# Turbo
.turbo

# ESLint
.eslintcache

# Documentation lifecycle manager
docs/archive/.index.json

# Auto-generated documentation reports
docs/*VERIFICATION*.md
docs/*REPORT*.md
!docs/COVERAGE-REPORT-TEMPLATE.md

# Generated documentation (copied from /docs during build)
apps/docs/public/docs/
apps/docs/dist/docs/

# ElectricSQL generated files
.electric/

# Ralph iterative workflow files
.cursor/ralph-loop.local.md
.cursor/ralph-prompt.md
.cursor/ralph-complete.marker

# Cursor IDE temporary files
.cursor/backups/
.cursor/debug.log
.cursor/audit-log.jsonl
.cursor/audit-summary.json

# Claude Code session files (local only)
.claude/SESSION_*.md
.claude/workboard.md

# RevealUI cache files (PGlite database)
.revealui/cache/

# RevealUI local configuration (but allow skills to be committed)
.revealui/*
!.revealui/skills/
# =============================================================================
# Nix Development Environment
# =============================================================================
# direnv cache (auto-generated)
.direnv/

# PostgreSQL local development data
.pgdata/
.pgdata.*
:memory:/

# Nix build results (if building packages)
result
result-*

# Type system metrics (local only)
.type-generation-metrics.json
.type-system-snapshot.json
.type-coverage-report.json
.vercel

# Claude Code worktrees (parallel agent isolation)
.claude/worktrees/
