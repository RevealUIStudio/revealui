# Dependencies
node_modules/

# Windows NTFS alternate data streams
*:Zone.Identifier
.pnp
.pnp.js
.pnpm-store/

# Testing
coverage/
*.lcov
.nyc_output/

# Playwright E2E Testing
test-results/
playwright-report/
playwright/.cache/
e2e/.auth/
*.trace.zip

# Test discovery temp files (generated by @revealui/db type tests)
**/__temp_discover_test__/

# Playwright Visual Snapshots
# Keep baseline snapshots (*.png in __snapshots__/) committed
# Ignore generated diff and actual images from failed tests
**/__snapshots__/**/*-actual.png
**/__snapshots__/**/*-diff.png
**/__snapshots__/**/*-previous.png

# Production
build/
dist/
.next/
out/

# Misc
.DS_Store
*.pem
*.key
*.age

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Output/log files
*_output.txt
*-errors.txt
categorized-errors.txt
lint-output.txt

# Local env files (secrets - never commit)
.env
.env*.local
.env.vercel
.env.development.local
.env.production.local
.env.test.local

# Backup env files (archived old versions)
.env.backups/
.env.backup
.env.clean

# Template file is committed (.env.template)
# .envrc is committed (direnv config, no secrets)
# .envrc.local is gitignored (machine-specific overrides, e.g. CLAUDE_AGENT_ROLE)
.envrc.local

# Vercel — ignore build output but commit project.json (needed for CI deploys)
.vercel/output
.vercel/cache

# Vite artifacts
vite.config.ts.timestamp-*.mjs

# Generated quality reports
CODE-QUALITY-REPORT.json

# TypeScript
*.tsbuildinfo
next-env.d.ts

# TypeScript build artifacts in source directories
# (These should be in dist/ but sometimes tsc outputs to src/)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map
scripts/**/*.js
scripts/**/*.d.ts
scripts/**/*.js.map
scripts/**/*.d.ts.map
# Allow committed .js config files
!**/*.config.js
!**/jest.config.js
!**/vitest.config.js

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db

# Load test results
load-tests/results/
*.json.gz

# Sentry
.sentryclirc

# Turbo
.turbo

# ESLint
.eslintcache

