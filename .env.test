# Test environment variables — ALL VALUES ARE FAKE AND SAFE TO COMMIT
# These are placeholder credentials used only for unit/integration tests.
# No real services are accessed with these values.
# Real secrets belong in .env.test.local (gitignored) for tests that hit live services.
NODE_ENV=test
REVEALUI_SECRET=test-secret-that-is-at-least-32-characters-long-for-testing-purposes
REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000
