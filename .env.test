POSTGRES_URL=postgresql://test:test@localhost:5432/test_revealui
DATABASE_URL=postgresql://test:test@localhost:5432/test_revealui
BLOB_READ_WRITE_TOKEN=test-blob-token
STRIPE_SECRET_KEY=sk_test_test123456789012345678901234567890
STRIPE_WEBHOOK_SECRET=whsec_test123456789012345678901234567890
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_test123456789012345678901234567890