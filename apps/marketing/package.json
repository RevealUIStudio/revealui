{
  "name": "marketing",
  "version": "0.1.0",
  "description": "Marketing site and waitlist for RevealUI",
  "private": true,
  "dependencies": {
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/presentation": "workspace:*",
    "drizzle-orm": "catalog:",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@revealui/dev": "workspace:*",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "build": "env -u NODE_ENV next build",
    "clean": "rm -rf .next dist .turbo",
    "dev": "next dev",
    "lint": "biome check .",
    "start": "next start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "typecheck": "tsc --noEmit",
    "vercel-build": "cd ../.. && pnpm turbo build --filter=marketing"
  }
}
