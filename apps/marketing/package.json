{
  "name": "marketing",
  "version": "0.1.0",
  "description": "Marketing site for RevealUI — homepage, blog, pricing, fair-source, contact",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.5",
    "@fontsource-variable/geist-mono": "^5.2.5",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/presentation": "workspace:*",
    "@revealui/router": "workspace:*",
    "@vercel/speed-insights": "^2.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@revealui/dev": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist .turbo",
    "dev": "vite dev --port 3000",
    "lint": "biome check .",
    "preview": "vite preview --port 3000",
    "start": "vite preview --port 3000",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "typecheck": "tsc --noEmit",
    "vercel-build": "cd ../.. && pnpm turbo build --filter=marketing"
  }
}
