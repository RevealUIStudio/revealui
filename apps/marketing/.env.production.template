# =============================================================================
# RevealUI Marketing — Production Environment Variables
# Vercel project: revealui-marketing  (https://revealui.com)
#
# This file documents every env var required or recommended for production.
# Copy values from your secret vault (Revvault: revealui/env/marketing-production).
#
# How to apply: Vercel Dashboard → revealui-marketing → Settings → Environment Variables
# Or via CLI:   vercel env add <NAME> production
# =============================================================================

# -----------------------------------------------------------------------------
# Database — NeonDB (waitlist storage)
# Required. Pooled connection string.
# Neon Dashboard: ep-your-endpoint-id → Connect → Connection string (pooled)
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://user:password@ep-your-endpoint-id.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# -----------------------------------------------------------------------------
# RevealUI Core
# Required. ≥32-character random hex string. Generate: openssl rand -hex 32
# Used for signing rate-limit tokens and internal encryption.
# -----------------------------------------------------------------------------
REVEALUI_SECRET=<32-byte-hex-secret>

# -----------------------------------------------------------------------------
# Public URLs — Marketing self-reference
# Required. Both vars must have the same value.
# -----------------------------------------------------------------------------
REVEALUI_PUBLIC_SERVER_URL=https://revealui.com
NEXT_PUBLIC_SERVER_URL=https://revealui.com

# -----------------------------------------------------------------------------
# Admin URL — used by pricing page CTAs (e.g. "Get Started → /signup?plan=pro")
# Optional but recommended so pricing page CTAs link to the correct admin app.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ADMIN_URL=https://admin.revealui.com

# -----------------------------------------------------------------------------
# Sentry — Error monitoring (optional but recommended for production)
# Create a Next.js project at sentry.io, then paste the DSN below.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project-id
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=revealui-studio
# SENTRY_PROJECT=revealui-marketing
