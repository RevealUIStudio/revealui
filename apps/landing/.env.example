# =============================================================================
# RevealUI Landing — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (NeonDB / PostgreSQL — required for waitlist)
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
# Alternative alias:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# RevealUI Core (required)
# -----------------------------------------------------------------------------
# Secret used for signing tokens and internal encryption. Must be ≥32 chars.
REVEALUI_SECRET=your-secret-key-minimum-32-characters-long

# The public URL where this app is served (no trailing slash).
REVEALUI_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Storage (Vercel Blob — required for file uploads)
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# -----------------------------------------------------------------------------
# Stripe (optional — if billing/payment features are added)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# Sentry (optional — error monitoring)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
