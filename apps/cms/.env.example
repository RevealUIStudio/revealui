# =============================================================================
# RevealUI CMS — Environment Variables
# Copy this file to .env.local and fill in the values.
# Source of truth for required vars: turbo.json `env` array + packages/config/src/schema.ts
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# RevealUI Core (required)
# -----------------------------------------------------------------------------
# Secret used for signing sessions, tokens, and internal encryption.
# Must be at least 32 characters.
REVEALUI_SECRET=your-secret-key-minimum-32-characters-long

# The public URL where the CMS is served (no trailing slash).
# Both vars must match; NEXT_PUBLIC_SERVER_URL is the Next.js public alias.
REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# URL of the RevealUI API (apps/api, default port 3004)
REVEALUI_API_URL=http://localhost:3004
NEXT_PUBLIC_API_URL=http://localhost:3004

# -----------------------------------------------------------------------------
# Admin Bootstrap (optional — creates first admin user on first run)
# -----------------------------------------------------------------------------
REVEALUI_ADMIN_EMAIL=admin@example.com
REVEALUI_ADMIN_PASSWORD=your-admin-password-min-12-chars
# Aliases used by seed scripts:
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password-min-12-chars
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=your-superadmin-password-min-12-chars
USER_EMAIL=user@example.com
USER_PASSWORD=your-user-password-min-12-chars

# -----------------------------------------------------------------------------
# Database (NeonDB / PostgreSQL — required)
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
# Alternative alias:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Reset DB on startup (WARNING: destructive — development only)
# REVEALUI_DROP_DATABASE=false

# -----------------------------------------------------------------------------
# Supabase (vectors + auth DB — optional, required for AI/vector features)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DATABASE_URI=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# Next.js private aliases (not exposed to browser):
NEXT_PRIVATE_SUPABASE_URL=https://your-project.supabase.co
NEXT_PRIVATE_SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# ElectricSQL (real-time sync — optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ELECTRIC_SERVICE_URL=http://localhost:3000
ELECTRIC_SERVICE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Storage (Vercel Blob — required for file uploads)
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# -----------------------------------------------------------------------------
# Stripe (payments — required for billing features)
# -----------------------------------------------------------------------------
# Use test keys (sk_test_...) in development, live keys (sk_live_...) in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Live webhook secret (production only):
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
# Next.js private alias:
NEXT_PRIVATE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Enable Stripe proxy for local webhook testing (stripe CLI):
# STRIPE_PROXY=1
# Expose whether the key is a test key to the client:
REVEALUI_PUBLIC_STRIPE_IS_TEST_KEY=true
NEXT_PUBLIC_IS_LIVE=false

# -----------------------------------------------------------------------------
# Draft / Preview
# -----------------------------------------------------------------------------
REVEALUI_PUBLIC_DRAFT_SECRET=your-draft-secret-min-32-chars
NEXT_PRIVATE_REVEALUI_DRAFT_SECRET=your-draft-secret-min-32-chars

# Revalidation key for on-demand ISR
REVEALUI_REVALIDATION_KEY=your-revalidation-key-min-32-chars
NEXT_PRIVATE_REVEALUI_REVALIDATION_KEY=your-revalidation-key-min-32-chars

# Public seed flag (controls whether DB seed runs in this env)
# REVEALUI_PUBLIC_SEED=false

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated allowed origins (required in production)
# REVEALUI_CORS_ORIGINS=https://app.example.com,https://www.example.com
# REVEALUI_WHITELISTORIGINS=https://app.example.com  # deprecated alias

# -----------------------------------------------------------------------------
# Email / SMTP (optional — for transactional emails)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_USER=smtp-user@example.com
SMTP_PASS=your-smtp-password

# -----------------------------------------------------------------------------
# Sentry (optional — error monitoring)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# -----------------------------------------------------------------------------
# YouTube (optional — media integrations)
# -----------------------------------------------------------------------------
# YOUTUBE_API_KEY=your-youtube-api-key
# YOUTUBE_BASE_URL=https://www.googleapis.com/youtube/v3

# -----------------------------------------------------------------------------
# Neon (optional — Neon API for branch management)
# -----------------------------------------------------------------------------
# NEON_API_KEY=your-neon-api-key

# -----------------------------------------------------------------------------
# Vite / web app (if co-located with CMS)
# -----------------------------------------------------------------------------
# VITE_REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000
# VITE_PUBLIC_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Build flags
# -----------------------------------------------------------------------------
# Force Next.js into build mode (set by CI/build scripts automatically)
# NEXT_BUILD=true

# Skip CMS onInit hook (useful for migrations without running full init)
# SKIP_ONINIT=false

# Custom config file path (defaults to revealui.config.ts in app root)
# REVEALUI_CONFIG_PATH=./revealui.config.ts
