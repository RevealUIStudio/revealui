{
  "extends": "../../packages/dev/src/ts/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolvePackageJsonExports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/types": ["./src/types/index.ts"],
      "@revealui/config": ["./revealui.config.ts"],
      "@revealui/contracts": ["../../packages/contracts/src/*"],
      "@revealui/contracts/cms": ["../../packages/contracts/src/cms/index.ts"],
      "@revealui/types": ["../../packages/core/src/types/index.ts"],
      "@revealui/types/*": ["../../packages/core/src/types/*"],
      "@revealui/generated": ["../../packages/core/src/generated/index.ts"],
      "@revealui/generated/*": ["../../packages/core/src/generated/*"],
      "revealui/*": ["../../packages/core/src/*"],
      "@revealui/core": ["../../packages/core/src/index.ts"],
      "@revealui/core/client": ["../../packages/core/src/client/index.ts"],
      "@revealui/core/utils/*": ["../../packages/core/src/utils/*"],
      "@revealui/core/*": ["../../packages/core/src/*"],
      "@revealui/db": ["../../packages/db/src/index.ts"],
      "@revealui/db/*": ["../../packages/db/src/*"],
      "@revealui/auth/server": ["../../packages/auth/src/server/index.ts"],
      "@revealui/auth/client": ["../../packages/auth/src/client/index.ts"],
      "@revealui/auth/react": ["../../packages/auth/src/react/index.ts"],
      "@revealui/ai/*": ["../../packages/ai/src/*"],
      "@revealui/sync": ["../../packages/sync/src/index.ts"],
      "@revealui/sync/*": ["../../packages/sync/src/*"]
    },
    "target": "ES2022"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "revealui.config.ts",
    "env.d.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "typeAcquisition": {
    "enable": false
  },
  "exclude": ["node_modules"]
}
