{
  "extends": "../../packages/dev/src/ts/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolvePackageJsonExports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/types": ["./src/types/index.ts"],
      "@revealui/config": ["./revealui.config.ts"],
      // Unified type packages (merged into core)
      "@revealui/types": ["../../packages/core/src/types/index.ts"],
      "@revealui/types/*": ["../../packages/core/src/types/*"],
      "@revealui/generated": ["../../packages/core/src/generated/index.ts"],
      "@revealui/generated/*": ["../../packages/core/src/generated/*"],
      // Core framework
      // Note: Remove @revealui/core main path alias to let Turbopack use package.json exports
      // This allows transpilePackages to work correctly and resolve relative imports
      // TypeScript will use package.json exports or wildcard paths below for type resolution
      "revealui/*": ["../../packages/core/src/*"],
      // @revealui/core main export - use package.json exports (not tsconfig path)
      // "@revealui/core": ["../../packages/core/src/index.ts"], // REMOVED - use package.json exports
      // REMOVED: "@revealui/core/core" - core functionality is now in main export
      "@revealui/core/client": ["../../packages/core/src/client/index.ts"],
      "@revealui/core/utils/*": ["../../packages/core/src/utils/*"],
      "@revealui/core/*": ["../../packages/core/src/*"],
      // Contracts package (replaces schema)
      // Remove tsconfig paths to let Turbopack use package.json exports for all subpaths
      // TypeScript will use package.json exports for type resolution
      // "@revealui/contracts": ["../../packages/contracts/src/index.ts"], // REMOVED - use package.json exports
      "@revealui/contracts/*": ["../../packages/contracts/src/*"], // Keep wildcard for subpath type resolution if needed
      // Database package
      // Remove tsconfig paths to let Turbopack use package.json exports
      // "@revealui/db": ["../../packages/db/src/index.ts"], // REMOVED - use package.json exports
      "@revealui/db/*": ["../../packages/db/src/*"], // Keep wildcard for subpath type resolution if needed
      // Auth package
      // Package exports: ./server, ./client, ./react (no main export)
      // Use source files for TypeScript type checking (consistent with other packages)
      // Turbopack will use package.json exports for runtime resolution via transpilePackages
      // "@revealui/auth": ["../../packages/auth/src/index.ts"], // REMOVED - no main export in package.json
      "@revealui/auth/server": ["../../packages/auth/src/server/index.ts"],
      "@revealui/auth/client": ["../../packages/auth/src/client/index.ts"],
      "@revealui/auth/react": ["../../packages/auth/src/react/index.ts"],
      // AI package
      "@revealui/ai/*": ["../../packages/ai/src/*"],
      // Sync package
      "@revealui/sync/*": ["../../packages/sync/src/*"],
      // Legacy paths for compatibility (REMOVED - no longer needed)
    },
    "target": "ES2022"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "revealui.config.ts",
    "env.d.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "typeAcquisition": {
    "enable": false
  },
  "exclude": ["node_modules", "../../packages/core/**/*"]
}
