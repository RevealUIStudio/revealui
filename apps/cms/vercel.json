{
  "buildCommand": "pnpm --filter @revealui/db build && pnpm --filter @revealui/db db:migrate && pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/admin/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "github": {
    "silent": true
  }
}
