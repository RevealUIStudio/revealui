{
  "name": "cms",
  "version": "0.0.1",
  "private": true,
  "description": "Headless CMS powered by RevealUI",
  "license": "MIT",
  "dependencies": {
    "@electric-sql/client": "^1.0.27",
    "@electric-sql/react": "^1.0.27",
    "@revealui/ai": "workspace:*",
    "@revealui/auth": "workspace:*",
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/presentation": "workspace:*",
    "@revealui/services": "workspace:*",
    "@revealui/sync": "workspace:*",
    "@revealui/utils": "workspace:*",
    "@sentry/nextjs": "^10.34.0",
    "@stripe/stripe-js": "^8.6.1",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindplus/elements": "^1.0.22",
    "@types/nodemailer": "^7.0.5",
    "@vercel/blob": "^2.2.0",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "drizzle-orm": "^0.45.1",
    "geist": "^1.7.0",
    "jose": "^6.1.3",
    "lexical": "^0.40.0",
    "next": "^16.1.6",
    "nodemailer": "^7.0.12",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.1",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "dev": "workspace:*",
    "dotenv": "^17.2.4",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "_comment_build": "Next.js 16 uses Turbopack by default for builds. No flags needed.",
    "analyze": "cross-env ANALYZE=true pnpm run vercel-build",
    "analyze:bundle": "./scripts/analyze-bundle.sh",
    "build": "env -u NODE_ENV cross-env NODE_OPTIONS=--no-deprecation next build --turbopack",
    "clean": "rm -rf .next dist .turbo",
    "cms": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" revealui cms",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev --port 4000",
    "devsafe": "rimraf .next && pnpm dev",
    "format": "biome format --write .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation revealui cms generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation revealui cms generate:types",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start --port 4000",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "vercel-build": "pnpm --filter @revealui/utils build && pnpm --filter @revealui/config build && pnpm --filter @revealui/presentation build && pnpm --filter @revealui/db build && pnpm --filter @revealui/contracts build && pnpm --filter @revealui/core build && pnpm --filter @revealui/auth build && pnpm --filter @revealui/sync build && env -u NODE_ENV cross-env NODE_OPTIONS=--no-deprecation TURBOPACK=0 next build"
  },
  "type": "module"
}
