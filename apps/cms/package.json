{
  "name": "cms",
  "description": "Headless CMS powered by RevealUI",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "format": "prettier --write '**/*.{js,ts,tsx,json}'",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev --port 4000",
    "devsafe": "rimraf .next && pnpm dev",
    "build": "pnpm run vercel-build",
    "vercel-build": "cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "cms": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" revealui cms",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start --port 4000",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation revealui cms generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation revealui cms generate:types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/richtext-lexical": "^3.69.0",
    "@revealui/revealui": "workspace:*",
    "@sentry/nextjs": "^10.27.0",
    "@stripe/stripe-js": "^8.5.3",
    "@supabase/supabase-js": "^2.84.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "babel-plugin-react-compiler": "19.0.0-beta-63e3235-20250105",
    "class-variance-authority": "^0.7.1",
    "cross-env": "^10.1.0",
    "geist": "^1.5.1",
    "jsonwebtoken": "^9.0.2",
    "lexical": "^0.38.2",
    "next": "16.0.10",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.1",
    "sharp": "0.34.5",
    "stripe": "^20.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "dev": "workspace:*",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "services": "workspace:*",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
