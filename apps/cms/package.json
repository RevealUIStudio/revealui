{
  "name": "cms",
  "version": "0.0.1",
  "private": true,
  "description": "Headless CMS powered by RevealUI",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.12",
    "@ai-sdk/react": "^3.0.41",
    "@electric-sql/client": "^1.0.27",
    "@electric-sql/react": "^1.0.27",
    "@revealui/ai": "workspace:*",
    "@revealui/auth": "workspace:*",
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/sync": "workspace:*",
    "@sentry/nextjs": "^10.34.0",
    "@stripe/stripe-js": "^8.6.1",
    "@supabase/supabase-js": "^2.90.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindplus/elements": "^1.0.22",
    "@types/nodemailer": "^7.0.5",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.39",
    "babel-plugin-react-compiler": "19.0.0-beta-63e3235-20250105",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "drizzle-orm": "^0.45.1",
    "geist": "^1.5.1",
    "jsonwebtoken": "^9.0.3",
    "lexical": "^0.40.0",
    "next": "^16.1.3",
    "nodemailer": "^7.0.12",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "sharp": "^0.34.5",
    "stripe": "^20.2.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "dev": "workspace:*",
    "dotenv": "^17.2.3",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "services": "workspace:*",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "_comment_turbopack": "TURBOPACK=0 disables Turbopack for production builds due to module resolution issues. See docs/architecture/TURBOPACK-DECISIONS.md",
    "build": "pnpm run vercel-build",
    "clean": "rm -rf .next dist .turbo",
    "cms": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" revealui cms",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev --port 4000",
    "devsafe": "rimraf .next && pnpm dev",
    "format": "biome format --write .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation revealui cms generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation revealui cms generate:types",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "prebuild": "pnpm --filter @revealui/config build && pnpm --filter @revealui/contracts build && pnpm --filter @revealui/core build && pnpm --filter @revealui/db build && pnpm --filter @revealui/auth build && pnpm --filter services build && pnpm --filter @revealui/ai build",
    "predev": "pnpm --filter @revealui/config build && pnpm --filter @revealui/contracts build && pnpm --filter @revealui/core build && pnpm --filter @revealui/db build && pnpm --filter @revealui/auth build && pnpm --filter services build && pnpm --filter @revealui/ai build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start --port 4000",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "vercel-build": "pnpm --filter @revealui/config build && pnpm --filter @revealui/contracts build && pnpm --filter @revealui/core build && pnpm --filter @revealui/db build && pnpm --filter @revealui/auth build && pnpm --filter @revealui/sync build && pnpm --filter services build && pnpm --filter @revealui/ai build && cross-env NODE_OPTIONS=--no-deprecation TURBOPACK=0 next build"
  },
  "type": "module"
}
