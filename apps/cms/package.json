{
  "name": "cms",
  "version": "0.0.1",
  "private": true,
  "description": "Headless CMS powered by RevealUI",
  "license": "MIT",
  "dependencies": {
    "@electric-sql/client": "^1.0.27",
    "@electric-sql/react": "^1.0.27",
    "@revealui/auth": "workspace:*",
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/presentation": "workspace:*",
    "@revealui/sync": "workspace:*",
    "@revealui/utils": "workspace:*",
    "@sentry/nextjs": "^10.34.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@stripe/stripe-js": "^9.0.0",
    "@supabase/supabase-js": "^2.95.3",
    "@types/nodemailer": "^7.0.5",
    "@vercel/blob": "^2.3.2",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.0",
    "jose": "^6.1.3",
    "lexical": "^0.42.0",
    "next": "catalog:",
    "nodemailer": "^8.0.4",
    "prism-react-renderer": "^2.4.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "stripe": "^21.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "dev": "workspace:*",
    "dotenv": "^17.2.4",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "peerDependencies": {
    "@revealui/ai": "^0.2.2",
    "@revealui/services": "^0.2.4"
  },
  "peerDependenciesMeta": {
    "@revealui/ai": {
      "optional": true
    },
    "@revealui/services": {
      "optional": true
    }
  },
  "scripts": {
    "_comment_build": "Next.js 16 uses Turbopack by default for builds. No flags needed.",
    "analyze": "cross-env ANALYZE=true pnpm run vercel-build",
    "analyze:bundle": "./scripts/analyze-bundle.sh",
    "build": "env -u NODE_ENV cross-env NODE_OPTIONS=--no-deprecation next build --turbopack",
    "clean": "rm -rf .next dist .turbo",
    "cms": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" revealui cms",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev --port 4000",
    "devsafe": "rimraf .next && pnpm dev",
    "format": "biome format --write .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation revealui cms generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation revealui cms generate:types",
    "lint": "biome check .",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start --port 4000",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "vercel-build": "cd ../.. && pnpm turbo build --filter=cms"
  }
}
