{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "NODE_ENV=production tsx src/server.ts",
    "vercel-build": "tsc",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "format": "biome format --write .",
    "stripe:webhooks": "stripe listen --forward-to localhost:8000/stripe/webhooks",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .next dist .turbo .output"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@revealui/presentation": "workspace:*",
    "@revealui/router": "workspace:*",
    "@sentry/react": "^10.38.0",
    "@tanstack/react-router": "^1.158.0",
    "@tanstack/react-start": "^1.158.0",
    "@tanstack/router-devtools": "^1.158.0",
    "@vercel/node": "^5.5.23",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^20.3.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@sentry/vite-plugin": "^4.9.0",
    "@swc/react-compiler": "^1.15.11",
    "@tanstack/start-vite-plugin": "^1.91.1",
    "@types/node": "^25.0.9",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "19.0.0-beta-63e3235-20250105",
    "dev": "workspace:*",
    "globals": "^17.0.0",
    "postcss": "^8.5.6",
    "sass": "^1.97.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vinxi": "^0.5.11",
    "vite-plugin-mcp": "^0.3.2",
    "zod": "^3.24.1"
  }
}
