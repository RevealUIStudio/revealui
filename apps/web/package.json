{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "cross-env vite dev",
    "build": "pnpm vercel-build",
    "vercel-build": "cross-env NODE_OPTIONS=--no-deprecation vite build",
    "start": "vite preview",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "format": "biome format --write .",
    "stripe:webhooks": "stripe listen --forward-to localhost:8000/stripe/webhooks",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .next dist .turbo"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@sentry/react": "^10.38.0",
    "@universal-middleware/core": "^0.4.15",
    "@universal-middleware/hono": "^0.4.20",
    "@vercel/node": "^5.5.23",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^20.3.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@hono/vite-dev-server": "^0.24.1",
    "@revealui/core": "workspace:*",
    "@sentry/vite-plugin": "^4.6.2",
    "@swc/react-compiler": "^1.15.11",
    "@types/node": "^25.0.9",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "19.0.0-beta-63e3235-20250105",
    "dev": "workspace:*",
    "globals": "^17.0.0",
    "next": "16.1.6",
    "postcss": "^8.5.6",
    "sass": "^1.97.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^3.24.1",
    "vite-plugin-mcp": "^0.3.2"
  }
}
