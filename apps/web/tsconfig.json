{
  "extends": "../../packages/dev/src/ts/reveal.json",
  "compilerOptions": {
    "baseUrl": ".", // Added baseUrl for path mappings
    "strict": true,
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "bundler",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["vite/client"],
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@reveal-config": ["../cms/revealui.config.ts"],
      // Unified type packages
      "@revealui/types": ["../../packages/types/src/index.ts"],
      "@revealui/types/*": ["../../packages/types/src/*"],
      // Core framework
      "revealui": ["../../packages/revealui/src"],
      "revealui/*": ["../../packages/revealui/src/*"],
      "revealui/core/*": ["../../packages/revealui/src/core/*"],
      "revealui/ui/*": ["../../packages/revealui/src/ui/*"],
      "revealui/layouts/*": ["../../packages/revealui/src/layouts/*"],
      "revealui/data/*": ["../../packages/revealui/src/data/*"],
      "revealui/handlers/*": ["../../packages/revealui/src/handlers/*"],
      "revealui/hooks/*": ["../../packages/revealui/src/hooks/*"],
      "revealui/app": ["../../packages/revealui/src/providers/AppProvider.tsx"],
      "revealui/config": ["../../packages/revealui/src/+config.ts"],
      "revealui/vercel": ["../../packages/revealui/src/plugins/vercel/index.ts"],
      "reveal": ["../../packages/revealui/src"],
      "config/vite": ["../../packages/dev/src/vite/vite.shared.ts"],
      "config/tailwind": ["../../packages/dev/src/tailwind/index.ts"]
    },
    "sourceMap": true
  },
  "include": [
    "./src/**/*",
    "vite.config.ts",
    "../../packages/revealui/src/modules/reveal.d.ts",
    "../../packages/revealui/src/api"
  ],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "next-env.d.ts"]
}
