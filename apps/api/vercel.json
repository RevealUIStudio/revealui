{
  "framework": null,
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=api",
  "ignoreCommand": "git diff --quiet HEAD~1 HEAD -- . ../../packages ../../pnpm-lock.yaml ../../package.json ../../turbo.json 2>/dev/null || exit 1",
  "env": [
    "REVEALUI_SECRET",
    "REVEALUI_KEK",
    "REVEALUI_LICENSE_PRIVATE_KEY",
    "REVEALUI_LICENSE_PUBLIC_KEY",
    "REVEALUI_CRON_SECRET",
    "POSTGRES_URL",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_WEBHOOK_SECRET_LIVE",
    "STRIPE_AGENT_METER_EVENT_NAME",
    "CORS_ORIGIN",
    "CMS_URL",
    "NEXT_PUBLIC_SERVER_URL",
    "REVEALUI_PUBLIC_SERVER_URL",
    "REVEALUI_EARLY_ADOPTER_END",
    "REVEALUI_EARLY_ADOPTER_COUPON_PRO",
    "REVEALUI_EARLY_ADOPTER_COUPON_MAX",
    "REVEALUI_EARLY_ADOPTER_COUPON_ENT",
    "REVEALUI_ALERT_EMAIL"
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
