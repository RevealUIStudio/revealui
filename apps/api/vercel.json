{
  "framework": null,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter api run vercel-build",
  "functions": {
    "api/**": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/cron/sweep-grace-periods", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/billing-readiness", "schedule": "0 6 * * *" },
    { "path": "/api/cron/marketplace-payouts", "schedule": "0 4 * * *" }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
