{
  "name": "api",
  "version": "0.1.0",
  "description": "REST API server with OpenAPI spec and Swagger UI for RevealUI",
  "private": true,
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.0",
    "@hono/swagger-ui": "^0.6.1",
    "@revealui/auth": "workspace:*",
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/mcp": "workspace:*",
    "@revealui/openapi": "workspace:*",
    "@revealui/security": "workspace:*",
    "@sentry/node": "^10.50.0",
    "@vercel/blob": "^2.3.3",
    "drizzle-orm": "catalog:",
    "hono": "4.12.15",
    "jose": "^6.2.2",
    "lib0": "^0.2.117",
    "stripe": "^22.1.0",
    "swagger-ui-dist": "^5.32.4",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "peerDependencies": {
    "@revealui/ai": "workspace:^",
    "@revealui/services": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@revealui/ai": {
      "optional": true
    },
    "@revealui/services": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "lint": "biome check .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "vercel-build": "cd ../.. && pnpm turbo build --filter=api"
  },
  "type": "module"
}
