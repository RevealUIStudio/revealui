{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@hono/node-server": "^1.19.10",
    "@hono/swagger-ui": "^0.6.1",
    "@revealui/auth": "workspace:*",
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/openapi": "workspace:*",
    "@vercel/blob": "^2.3.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.7",
    "jose": "^6.1.3",
    "lib0": "^0.2.117",
    "stripe": "^21.0.1",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "peerDependencies": {
    "@revealui/ai": "^0.2.0",
    "@revealui/services": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@revealui/ai": {
      "optional": true
    },
    "@revealui/services": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "lint": "biome check .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "vercel-build": "cd ../.. && pnpm turbo build --filter=api"
  },
  "type": "module"
}
