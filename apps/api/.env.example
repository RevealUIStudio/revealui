# =============================================================================
# RevealUI API — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3004
# In production, set PORT if your host overrides the port
# PORT=3004

# CORS: comma-separated list of allowed origins (required in production)
# CORS_ORIGIN=https://app.example.com,https://www.example.com

# -----------------------------------------------------------------------------
# Database (NeonDB / PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
# Alternative alias accepted by @revealui/db:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Supabase (vectors + auth DB)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DATABASE_URI=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# RevealUI License (license validation route)
# -----------------------------------------------------------------------------
REVEALUI_LICENSE_PUBLIC_KEY=your-rsa-public-key-pem
REVEALUI_LICENSE_PRIVATE_KEY=your-rsa-private-key-pem
REVEALUI_ADMIN_API_KEY=your-admin-api-key-min-32-chars

# -----------------------------------------------------------------------------
# AI Agents (POST /api/agent-tasks)
# Set at least one of ANTHROPIC_API_KEY or OPENAI_API_KEY to enable agents.
# Without these, the route returns 503 and tickets are left in "open" status.
# -----------------------------------------------------------------------------

# LLM provider keys (first one found wins: Anthropic > OpenAI)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Override the model used by the agent dispatcher
# Defaults: claude-sonnet-4-6 (Anthropic) | gpt-4o (OpenAI)
# AGENT_MODEL=claude-sonnet-4-6

# CMS base URL — agent uses this to call CMS REST API tools
# Required for agents to read/write content. Without it, CMS tool calls throw.
CMS_URL=http://localhost:4000
# CMS_URL=https://cms.yourdomain.com

# CMS API key — sent as Bearer token on agent → CMS requests
# If your CMS requires authentication, set this to a valid API key.
# CMS_API_KEY=your-cms-api-key

# -----------------------------------------------------------------------------
# AI / LLM (used by @revealui/ai if the API proxies agent requests)
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic|vultr|huggingface

# OpenAI
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Vultr Inference
# VULTR_API_KEY=your-vultr-api-key
# VULTR_INFERENCE_API_KEY=your-vultr-inference-api-key
# VULTR_BASE_URL=https://api.vultrinference.com/v1
# VULTR_MODEL=meta-llama/Llama-3-8b-instruct

# HuggingFace
# HF_TOKEN=hf_...
# HF_MODEL_URL=https://api-inference.huggingface.co/models/your-model

# Docker (local inference)
# DOCKER_INFERENCE_URL=http://localhost:8080/generate

# LLM tuning
# LLM_MODEL=gpt-4o
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096
# LLM_ENABLE_CACHE=false
# LLM_ENABLE_RESPONSE_CACHE=false
# LLM_ENABLE_SEMANTIC_CACHE=false
# ANTHROPIC_ENABLE_CACHE=false
# RESPONSE_CACHE_ENABLED=false
# SEMANTIC_CACHE_ENABLED=false

# -----------------------------------------------------------------------------
# WebSocket (collab/agent-collab routes)
# -----------------------------------------------------------------------------
WS_BASE_URL=ws://localhost:3004

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
# LOG_LEVEL=info|warn|error (recommended for production)
