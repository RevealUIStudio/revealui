# =============================================================================
# RevealUI API — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3004
# In production, set PORT if your host overrides the port
# PORT=3004

# CORS: comma-separated list of allowed origins (required in production)
# CORS_ORIGIN=https://app.example.com,https://www.example.com

# -----------------------------------------------------------------------------
# Database (NeonDB / PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
# Alternative alias accepted by @revealui/db:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Supabase (vectors + auth DB)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DATABASE_URI=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# RevealUI License (license validation route)
# -----------------------------------------------------------------------------
REVEALUI_LICENSE_PUBLIC_KEY=your-rsa-public-key-pem
REVEALUI_LICENSE_PRIVATE_KEY=your-rsa-private-key-pem
REVEALUI_ADMIN_API_KEY=your-admin-api-key-min-32-chars

# -----------------------------------------------------------------------------
# AI Agents (POST /api/agent-tasks)
# Set at least one of ANTHROPIC_API_KEY or OPENAI_API_KEY to enable agents.
# Without these, the route returns 503 and tickets are left in "open" status.
# -----------------------------------------------------------------------------

# LLM provider keys — first one found wins: Anthropic > OpenAI > Groq > Ollama
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Override the model used by the agent dispatcher
# Defaults: claude-sonnet-4-6 (Anthropic) | gpt-4o (OpenAI) | qwen/qwen3-32b (Groq) | gemma4:e2b (Ollama)
# AGENT_MODEL=claude-sonnet-4-6

# Admin base URL — agent uses this to call admin REST API tools
# Required for agents to read/write content. Without it, admin tool calls throw.
ADMIN_URL=http://localhost:4000
# ADMIN_URL=https://admin.yourdomain.com

# Admin API key — sent as Bearer token on agent → admin requests
# If your admin app requires authentication, set this to a valid API key.
# ADMIN_API_KEY=your-admin-api-key

# -----------------------------------------------------------------------------
# AI / LLM (used by @revealui/ai if the API proxies agent requests)
# -----------------------------------------------------------------------------
# Default: inference-snaps when no env var is set (zero-config Ubuntu).
# LLM_PROVIDER=inference-snaps|groq|huggingface|ollama

# Groq (cloud, LPU silicon — fast inference)
# GROQ_API_KEY=gsk_...
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# HuggingFace (cloud — broad model catalog)
# HF_TOKEN=hf_...
# HF_MODEL_URL=https://api-inference.huggingface.co/models/your-model

# --- Open-model inference (Apache 2.0 — zero commercial fees) ---

# Ubuntu Inference Snaps (recommended — zero config, one command install)
# Install: sudo snap install gemma3 --beta
# INFERENCE_SNAPS_BASE_URL=http://localhost:9090/v1
# LLM_PROVIDER=inference-snaps

# Ollama (local inference: https://ollama.com — fully offline, zero cost)
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma4:e2b               # pull first: ollama pull gemma4:e2b
# OLLAMA_EMBED_MODEL=nomic-embed-text  # pull first: ollama pull nomic-embed-text

# Docker (local inference)
# DOCKER_INFERENCE_URL=http://localhost:8080/generate

# LLM tuning
# LLM_MODEL=gpt-4o
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096
# LLM_ENABLE_CACHE=false
# LLM_ENABLE_RESPONSE_CACHE=false
# LLM_ENABLE_SEMANTIC_CACHE=false
# ANTHROPIC_ENABLE_CACHE=false
# RESPONSE_CACHE_ENABLED=false
# SEMANTIC_CACHE_ENABLED=false

# -----------------------------------------------------------------------------
# WebSocket (collab/agent-collab routes)
# -----------------------------------------------------------------------------
WS_BASE_URL=ws://localhost:3004

# -----------------------------------------------------------------------------
# Email (transactional emails — password reset, recovery, etc.)
# Provider: Gmail REST API via Google Workspace service account.
# Resend / SMTP / nodemailer paths were removed 2026-04-09 (PR #227).
# -----------------------------------------------------------------------------
# GOOGLE_SERVICE_ACCOUNT_EMAIL=sa@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# EMAIL_FROM=noreply@revealui.com

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Meter event name for usage-based billing (agent task overage).
# Cron job at /api/billing/report-agent-overage sends metered events to Stripe.
# STRIPE_AGENT_METER_EVENT_NAME=agent_task_overage
# Support renewal price IDs (annual renewal for perpetual licenses)
# STRIPE_RENEWAL_PRO_PRICE_ID=price_...
# STRIPE_RENEWAL_MAX_PRICE_ID=price_...
# STRIPE_RENEWAL_ENTERPRISE_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# Cron Jobs (Vercel Cron)
# -----------------------------------------------------------------------------
# Secret for authenticating cron job requests (X-Cron-Secret header).
# Required for /api/billing/support-renewal-check and /api/billing/report-usage.
# REVEALUI_CRON_SECRET=your-cron-secret-min-32-chars

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
# LOG_LEVEL=info|warn|error (recommended for production)
