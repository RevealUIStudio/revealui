# =============================================================================
# RevealUI API — Production Environment Variables
# Vercel project: revealui-api  (https://api.revealui.com)
#
# This file documents every env var required or recommended for production.
# Copy values from your secret vault (Revvault: revealui/env/api-production).
#
# How to apply: Vercel Dashboard → revealui-api → Settings → Environment Variables
# Or via CLI:   vercel env add <NAME> production
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# Database — NeonDB (primary content store)
# Required. Use the pooled connection string for serverless.
# Neon Dashboard: ep-your-endpoint-id → Connect → Connection string (pooled)
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://user:password@ep-your-endpoint-id.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# -----------------------------------------------------------------------------
# RevealUI Core
# Required. ≥32-character random hex string. Generate: openssl rand -hex 32
# Must match the value set in the CMS project (used for cross-app tokens).
# -----------------------------------------------------------------------------
REVEALUI_SECRET=<32-byte-hex-secret>

# -----------------------------------------------------------------------------
# CORS
# Required in production. Comma-separated list of allowed origins.
# Include all apps that call this API.
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://admin.revealui.com,https://revealui.com

# -----------------------------------------------------------------------------
# Stripe — Billing (required for checkout, portal, webhooks)
# Use sk_test_... + whsec_... during test mode; live keys for production.
# Stripe Dashboard: API keys → Secret key / Webhooks → revealui-api endpoint
# Webhook endpoint registered: https://api.revealui.com/api/webhooks/stripe
# Events subscribed: checkout.session.completed, customer.subscription.deleted,
#                    customer.subscription.updated
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-signing-secret>

# -----------------------------------------------------------------------------
# RevealUI License — RSA-2048 key pair
# Required for license JWT generation (checkout webhook) and validation.
# Generate: openssl genrsa -out private.pem 2048
#           openssl rsa -in private.pem -pubout -out public.pem
# IMPORTANT: Vercel stores multi-line PEM as single-line with literal \n.
#            Paste the key with newlines replaced by \n (the webhook handler
#            calls .replace(/\\n/g, '\n') to restore them before use).
# Must match REVEALUI_LICENSE_PUBLIC_KEY set in apps/admin project.
# -----------------------------------------------------------------------------
REVEALUI_LICENSE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvg...\n-----END PRIVATE KEY-----
REVEALUI_LICENSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIj...\n-----END PUBLIC KEY-----

# -----------------------------------------------------------------------------
# AI Agents (optional — enables POST /api/agent-tasks)
# Without at least one key, agent-tasks returns 503.
# ADMIN_URL is needed for agents to call admin REST API tools.
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ADMIN_URL=https://admin.revealui.com
# AGENT_MODEL=claude-sonnet-4-6
