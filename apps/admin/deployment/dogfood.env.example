# =============================================================================
# RevealUI Dogfood Instance — revealui.com
#
# This file documents the env vars that make the Admin deployment at
# admin.revealui.com a "dogfood instance" — RevealUI's own website running
# on top of the RevealUI product stack.
#
# Architecture:
#   revealui.com         → apps/marketing  (Next.js, marketing + waitlist)
#   admin.revealui.com     → apps/admin        (admin dashboard + content engine)
#   docs.revealui.com    → apps/docs       (Vite/React documentation)
#   api.revealui.com     → apps/server        (Hono REST API)
#
# HOW TO USE:
# Start from the generic template: apps/admin/.env.production.template
# Then add the vars below on top of it in Vercel → Settings → Env Vars.
#
# What makes this "dogfood" vs a generic customer deployment:
#   1. Branding: RevealUI's own brand (not white-labeled)
#   2. License: Enterprise-tier (no user limits, all features enabled)
#   3. BYOK key encryption enabled (REVEALUI_KEK is set)
#   4. AI agents enabled server-side (ANTHROPIC_API_KEY set)
#   5. Signups gated to waitlist (REVEALUI_SIGNUP_WHITELIST)
# =============================================================================

# -----------------------------------------------------------------------------
# Branding — dogfood instance shows RevealUI brand (not white-labeled)
# Customers who white-label set REVEALUI_SHOW_POWERED_BY=false and set their
# own REVEALUI_BRAND_NAME. The dogfood instance shows the badge.
# -----------------------------------------------------------------------------
REVEALUI_BRAND_NAME=RevealUI
REVEALUI_BRAND_LOGO_URL=https://revealui.com/logo.svg
REVEALUI_BRAND_PRIMARY_COLOR=#4F46E5
REVEALUI_SHOW_POWERED_BY=true

# -----------------------------------------------------------------------------
# License — Enterprise tier for the dogfood instance
# Enables all Pro+ features: AI agents, BYOK, harnesses, MCP, editors.
# Generate via: revealui-cli license generate --tier=enterprise
# -----------------------------------------------------------------------------
REVEALUI_LICENSE_KEY=<enterprise-license-jwt>

# -----------------------------------------------------------------------------
# BYOK Key Encryption — required for server-side encrypted API key storage
# 64 hex characters (32 bytes). Generate: openssl rand -hex 32
# IMPORTANT: Rotate this key carefully — existing encrypted keys will be
# unreadable if the KEK changes. Keep a backup in Revvault.
# -----------------------------------------------------------------------------
REVEALUI_KEK=<64-hex-chars>

# -----------------------------------------------------------------------------
# AI — default server-side provider for agent workflows
# Used by createLLMClientFromEnv() when no user BYOK key is stored.
# The dogfood instance uses Anthropic as the default.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=<anthropic-api-key>
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Signup gating — dogfood instance is invite-only
# Remove or set REVEALUI_SIGNUP_OPEN=true to allow open signups.
# -----------------------------------------------------------------------------
# REVEALUI_SIGNUP_WHITELIST=alice@example.com,bob@example.com
# REVEALUI_SIGNUP_OPEN=false

# =============================================================================
# All other required vars (database, auth, Stripe, email, etc.) come from
# the generic production template: apps/admin/.env.production.template
# =============================================================================
