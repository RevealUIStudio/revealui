{
  "name": "admin",
  "version": "0.0.1",
  "private": true,
  "description": "RevealUI admin dashboard and content management",
  "license": "MIT",
  "dependencies": {
    "@electric-sql/client": "^1.5.15",
    "@revealui/auth": "workspace:*",
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/paywall": "workspace:*",
    "@revealui/presentation": "workspace:*",
    "@revealui/setup": "workspace:*",
    "@revealui/sync": "workspace:*",
    "@revealui/utils": "workspace:*",
    "@sentry/nextjs": "^10.48.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "cross-env": "^10.1.0",
    "drizzle-orm": "catalog:",
    "geist": "^1.7.0",
    "jose": "^6.2.2",
    "lexical": "^0.43.0",
    "next": "^16.2.3",
    "prism-react-renderer": "^2.4.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@simplewebauthn/server": "^13.3.0",
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "@revealui/dev": "workspace:*",
    "dotenv": "catalog:",
    "postcss": "^8.5.9",
    "rimraf": "^6.1.3",
    "stripe": "^22.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "peerDependencies": {
    "@revealui/ai": "workspace:^",
    "@revealui/services": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@revealui/ai": {
      "optional": true
    },
    "@revealui/services": {
      "optional": true
    }
  },
  "scripts": {
    "_comment_build": "Next.js 16 uses Turbopack by default for builds. No flags needed.",
    "analyze": "cross-env ANALYZE=true pnpm run vercel-build",
    "analyze:bundle": "./scripts/analyze-bundle.sh",
    "build": "env -u NODE_ENV cross-env NODE_OPTIONS=--no-deprecation next build --turbopack",
    "clean": "rm -rf .next dist .turbo",
    "admin": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" revealui admin",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev --port 4000",
    "devsafe": "rimraf .next && pnpm dev",
    "format": "biome format --write .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation revealui admin generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation revealui admin generate:types",
    "lint": "biome check .",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start --port 4000",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "vercel-build": "cd ../.. && pnpm turbo build --filter=admin"
  }
}
