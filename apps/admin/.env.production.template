# =============================================================================
# RevealUI Admin — Production Environment Variables
# Vercel project: revealui-admin  (https://admin.revealui.com)
#
# This file documents every env var required or recommended for production.
# Copy values from your secret vault (Revvault: revealui/env/admin-production).
#
# How to apply: Vercel Dashboard → revealui-admin → Settings → Environment Variables
# Or via CLI:   vercel env add <NAME> production
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# Database — NeonDB (primary content store)
# Required. Pooled connection string for serverless Next.js functions.
# Neon Dashboard: ep-your-endpoint-id → Connect → Connection string (pooled)
# NOTE: The Admin app uses a DIFFERENT NeonDB endpoint than the API.
#       The API uses the NeonDB REST HTTP driver; the Admin app uses the pooled pg driver.
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://user:password@ep-your-endpoint-id.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# -----------------------------------------------------------------------------
# RevealUI Core
# Required. ≥32-character random hex string. Generate: openssl rand -hex 32
# Must match the value set in the API project.
# -----------------------------------------------------------------------------
REVEALUI_SECRET=<32-byte-hex-secret>

# -----------------------------------------------------------------------------
# Public URLs — Admin self-reference
# Required. Both vars must have the same value.
# -----------------------------------------------------------------------------
REVEALUI_PUBLIC_SERVER_URL=https://admin.revealui.com
NEXT_PUBLIC_SERVER_URL=https://admin.revealui.com

# -----------------------------------------------------------------------------
# API URL — backend REST API
# Required. Used by Admin proxy routes (/api/billing/*) to forward to the API.
# -----------------------------------------------------------------------------
REVEALUI_API_URL=https://api.revealui.com
NEXT_PUBLIC_API_URL=https://api.revealui.com

# -----------------------------------------------------------------------------
# Email — Gmail REST API via Google Workspace service account (required for
# password reset, verification, and recovery flows).
# Resend / SMTP / nodemailer paths were removed 2026-04-09 (PR #227).
# Setup: create a service account, grant domain-wide delegation, set the
# from-address to a Workspace user with delegation.
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=sa@<your-project>.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY: PKCS8 PEM from the service account JSON. Literal newlines
# inside the PEM must be escaped as `\n` so the shell preserves them when loading.
GOOGLE_PRIVATE_KEY=<paste-service-account-pkcs8-pem-with-newlines-escaped-as-literal-backslash-n>
EMAIL_FROM=noreply@revealui.com

# -----------------------------------------------------------------------------
# Stripe — Client-side (required for billing page)
# Used by the Admin app billing page to redirect to Stripe Checkout via API.
# Admin app does NOT handle Stripe webhooks — those go to the API project.
# Stripe Dashboard: API keys → Publishable key
# Stripe Dashboard: Products → RevealUI Pro → Prices → price_...
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<your-stripe-publishable-key>
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_<your-pro-price-id>
NEXT_PUBLIC_STRIPE_MAX_PRICE_ID=price_<your-max-price-id>
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_<your-enterprise-price-id>
NEXT_PUBLIC_IS_LIVE=false
REVEALUI_PUBLIC_STRIPE_IS_TEST_KEY=true

# -----------------------------------------------------------------------------
# RevealUI License — RSA-2048 key pair
# Required. The public key validates incoming license JWTs from customers.
# The private key is used server-side to generate license JWTs at checkout.
# Both keys must match those set in the API project.
# IMPORTANT: Vercel stores multi-line PEM as single-line with literal \n.
# -----------------------------------------------------------------------------
REVEALUI_LICENSE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvg...\n-----END PRIVATE KEY-----
REVEALUI_LICENSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIj...\n-----END PUBLIC KEY-----

# -----------------------------------------------------------------------------
# ElectricSQL — Real-time sync (required for AI agent memory, collab features)
# Self-hosted on Railway: https://your-electric-instance.up.railway.app
# ELECTRIC_SECRET: generated during Electric deployment, stored in Railway vars
# -----------------------------------------------------------------------------
ELECTRIC_SERVICE_URL=https://your-electric-instance.up.railway.app
NEXT_PUBLIC_ELECTRIC_SERVICE_URL=https://your-electric-instance.up.railway.app
ELECTRIC_SECRET=<your-electric-secret>

# -----------------------------------------------------------------------------
# Signup Gating (optional — controls who can create admin accounts)
# If neither var is set, signups are open to everyone.
# Option A: Whitelist specific emails
# REVEALUI_SIGNUP_WHITELIST=alice@example.com,bob@example.com
# Option B: Open signups
# REVEALUI_SIGNUP_OPEN=true
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Sentry — Error monitoring (optional but recommended for production)
# Create a Next.js project at sentry.io, then paste the DSN below.
# SENTRY_AUTH_TOKEN: Settings → API Keys → Create Integration Token
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project-id
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=revealui-studio
# SENTRY_PROJECT=revealui-admin

# -----------------------------------------------------------------------------
# Supabase — Vectors + Auth (optional — required for AI/vector features)
# Supabase Dashboard: Project Settings → API
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
