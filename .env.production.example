# =============================================================================
# RevealUI — Production Environment Variables
# Copy to .env.production.local (or set in your hosting dashboard).
# All variables marked REQUIRED must be set before deploying.
# =============================================================================

# -----------------------------------------------------------------------------
# Core (REQUIRED)
# -----------------------------------------------------------------------------

# Minimum 32-character secret for session signing, HMAC, and CSRF tokens
REVEALUI_SECRET=

# Public-facing URL of the API server (must be HTTPS in production)
REVEALUI_PUBLIC_SERVER_URL=https://api.yourdomain.com
NEXT_PUBLIC_SERVER_URL=https://api.yourdomain.com

# Node environment
NODE_ENV=production

# -----------------------------------------------------------------------------
# Database — NeonDB (REQUIRED)
# Primary REST database for users, sites, content, billing
# -----------------------------------------------------------------------------
# Format: postgresql://user:pass@host/db?sslmode=require
POSTGRES_URL=

# -----------------------------------------------------------------------------
# Database — Supabase (REQUIRED for vector/AI features)
# Vector database for embeddings, AI memory, real-time auth
# -----------------------------------------------------------------------------
# Format: postgresql://postgres:pass@db.project.supabase.co:6543/postgres
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (REQUIRED for billing)
# Use live keys (sk_live_, pk_live_) — test keys are rejected in production
# -----------------------------------------------------------------------------
# Use live keys — test keys are rejected in production validation
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_AGENT_METER_EVENT_NAME=agent_task_overage

# -----------------------------------------------------------------------------
# CORS (REQUIRED)
# Comma-separated list of allowed origins for API requests
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://cms.yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------------------
# Email — Resend (REQUIRED for waitlist, password reset, notifications)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# OAuth Providers (optional — enable the ones you need)
# -----------------------------------------------------------------------------
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitHub Team Provisioning (optional — auto-adds Pro users to GitHub org)
# Fine-grained PAT with org:write:members scope
# -----------------------------------------------------------------------------
# REVEALUI_GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# License Validation (REQUIRED for Pro/Max/Enterprise)
# RSA key pair for signing and verifying license JWTs
# -----------------------------------------------------------------------------
# REVEALUI_LICENSE_PUBLIC_KEY=
# REVEALUI_LICENSE_PRIVATE_KEY=
# REVEALUI_ADMIN_API_KEY=your-admin-api-key-min-32-chars

# -----------------------------------------------------------------------------
# Blob Storage (optional — for media uploads)
# Vercel Blob or compatible S3 provider
# -----------------------------------------------------------------------------
# BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Admin Account (optional — seeded on first run)
# -----------------------------------------------------------------------------
# REVEALUI_ADMIN_EMAIL=admin@yourdomain.com
# REVEALUI_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Signup Gating (optional)
# -----------------------------------------------------------------------------
# REVEALUI_SIGNUP_OPEN=true
# REVEALUI_SIGNUP_WHITELIST=user1@example.com,user2@example.com

# -----------------------------------------------------------------------------
# Cron Jobs (optional — for Vercel Cron or external schedulers)
# Secret for authenticating cron job requests (X-Cron-Secret header)
# -----------------------------------------------------------------------------
# REVEALUI_CRON_SECRET=your-cron-secret-min-32-chars

# -----------------------------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# ElectricSQL (optional — real-time sync)
# -----------------------------------------------------------------------------
# ELECTRIC_SERVICE_URL=https://electric.yourdomain.com

# -----------------------------------------------------------------------------
# Branding — Enterprise / Forge (optional)
# White-label overrides for Forge-tier customers
# -----------------------------------------------------------------------------
# REVEALUI_BRAND_NAME=YourBrand
# REVEALUI_BRAND_LOGO_URL=https://...
# REVEALUI_BRAND_PRIMARY_COLOR=#ea580c
# REVEALUI_SHOW_POWERED_BY=true
# FORGE_LICENSED_DOMAIN=yourdomain.com
# FORGE_LICENSE_KEY=

# -----------------------------------------------------------------------------
# Open-model inference only — no proprietary cloud APIs
# Paths: Ubuntu inference snaps > BitNet > Ollama (first found wins)
# See .env.template for full provider list
# -----------------------------------------------------------------------------
# BITNET_BASE_URL=http://localhost:8080/v1
# OLLAMA_BASE_URL=http://localhost:11434
# CMS_URL=https://cms.yourdomain.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# App Ports (only needed for self-hosted / Docker deployments)
# Vercel/serverless deployments ignore these
# -----------------------------------------------------------------------------
# API_PORT=3004
# PORT=3000
