engine-strict=true
# pnpm-specific configs (npm will warn but these are valid for pnpm)
strict-peer-dependencies=false
auto-install-peers=true

# npm public registry for @revealui scope (OSS packages)
@revealui:registry=https://registry.npmjs.org
# Auth: NPM_TOKEN loaded from RevVault via .envrc → direnv.
# CI uses OIDC via release.yml. Fallback: `npm config set` writes to ~/.npmrc.
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# All @revealui packages (OSS + Pro) are published to the public npm registry.
# Pro packages are source-available under LICENSE.commercial, gated at runtime.