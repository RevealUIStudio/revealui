engine-strict=true
# pnpm-specific configs (npm will warn but these are valid for pnpm)
strict-peer-dependencies=false
auto-install-peers=true

# npm public registry for @revealui scope (OSS packages)
@revealui:registry=https://registry.npmjs.org
# Auth: use `npm login` locally (writes to ~/.npmrc). CI uses OIDC via release.yml.

# GitHub Packages registry for Pro packages (@revealui/ai, mcp, editors, services, harnesses)
# Pro packages override the scope registry via their publishConfig.registry field
# A PAT with read:packages scope is required to install Pro packages
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}