engine-strict=true
# pnpm-specific configs (npm will warn but these are valid for pnpm)
strict-peer-dependencies=false
auto-install-peers=true

# npm public registry for @revealui scope (OSS packages)
@revealui:registry=https://registry.npmjs.org
# Auth: Local dev uses ~/.npmrc (set via `npm login` or direnv NODE_AUTH_TOKEN).
# CI uses OIDC trusted publishing via actions/setup-node — no token needed in this file.