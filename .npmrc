engine-strict=false
# pnpm-specific configs (npm will warn but these are valid for pnpm)
strict-peer-dependencies=false
auto-install-peers=true

# npm public registry for @revealui scope
@revealui:registry=https://registry.npmjs.org
# NPM_TOKEN is only required when publishing — set it in CI or before running pnpm changeset:publish
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}