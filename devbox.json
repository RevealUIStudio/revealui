{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "packages": [
    "nodejs@24.12.0",
    "pnpm@10.28.2",
    "postgresql@16",
    "stripe-cli@latest"
  ],
  "shell": {
    "init_hook": [
      "corepack enable",
      "echo '🚀 RevealUI Devbox shell ready!'",
      "echo 'Node.js version:' $(node --version)",
      "echo 'pnpm version:' $(pnpm --version)",
      "echo 'PostgreSQL version:' $(postgres --version | head -n 1)",
      "echo ''",
      "echo 'Available commands:'",
      "echo '  devbox run dev    - Start development servers'",
      "echo '  devbox run setup  - Install deps and init database'",
      "echo '  devbox run test   - Run tests'",
      "echo '  pnpm <command>    - Run any pnpm command'",
      "echo ''"
    ],
    "scripts": {
      "dev": [
        "pnpm dev"
      ],
      "setup": [
        "pnpm install",
        "pnpm db:init",
        "pnpm db:migrate"
      ],
      "test": [
        "pnpm test"
      ],
      "db:start": [
        "pg_ctl -D $PGDATA -l $PGDATA/logfile start"
      ],
      "db:stop": [
        "pg_ctl -D $PGDATA stop"
      ],
      "stripe:listen": [
        "stripe listen --forward-to localhost:4000/api/webhooks/stripe"
      ]
    }
  },
  "env": {
    "NODE_ENV": "development",
    "PGDATA": ".devbox/virtenv/postgresql/data"
  }
}
