# =============================================================================
# REVEALUI FRAMEWORK - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# 
# Copy this file to .env.development.local and fill in your values
# DO NOT commit .env.development.local to git (it's in .gitignore)
#
# Usage:
#   cp .env.template .env.development.local
#   # Then edit .env.development.local with your actual values
#
# =============================================================================

# =============================================================================
# REQUIRED - REVEALUI CORE
# =============================================================================

# Secret key for JWT tokens and session encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 32+ characters
# Security: HIGH - Server-side only, never expose to client
REVEALUI_SECRET=your-secret-key-here-minimum-32-characters

# Public server URL (used by RevealUI CMS)
# Development: http://localhost:4000
# Production: https://your-domain.com
# Security: LOW - Safe for client-side
REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000

# Next.js public server URL (used by Next.js)
# Should match REVEALUI_PUBLIC_SERVER_URL
# Development: http://localhost:4000
# Production: https://your-domain.com
# Security: LOW - Safe for client-side
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# =============================================================================
# REQUIRED - DATABASE
# =============================================================================

# PostgreSQL connection string (NeonDB, Supabase, or other Postgres provider)
# Format: postgresql://user:password@host:port/database?sslmode=require
# Get from: https://neon.tech → Dashboard → Connection String
# Security: HIGH - Server-side only, contains credentials
# Note: DATABASE_URL is also supported as fallback for compatibility
POSTGRES_URL=postgresql://user:password@host:port/database?sslmode=require

# Alternative: DATABASE_URL (fallback if POSTGRES_URL not set)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# =============================================================================
# REQUIRED - STORAGE (Vercel Blob)
# =============================================================================

# Vercel Blob Storage read/write token
# Required for media uploads in production
# Get from: https://vercel.com/dashboard → Storage → Blob → Create Token
# Security: HIGH - Server-side only
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# REQUIRED - STRIPE PAYMENTS
# =============================================================================

# Stripe secret key (server-side)
# Development: Use test key (sk_test_...)
# Production: Use live key (sk_live_...)
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Security: HIGH - Server-side only
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe publishable key (client-side safe)
# Development: Use test key (pk_test_...)
# Production: Use live key (pk_live_...)
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Security: LOW - Safe for client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook secret (for webhook signature verification)
# Get from: https://dashboard.stripe.com → Developers → Webhooks → Add endpoint
# For local dev: Use `stripe listen --forward-to localhost:4000/api/webhooks/stripe`
# Security: HIGH - Server-side only
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# OPTIONAL - REVEALUI ADMIN
# =============================================================================

# Initial admin user email (only used if no users exist)
# Optional - can be set during first user creation in UI
# Security: LOW - Public information
# REVEALUI_ADMIN_EMAIL=admin@example.com

# Initial admin user password (only used if no users exist)
# Must be at least 12 characters
# Optional - can be set during first user creation in UI
# Security: HIGH - Server-side only
# REVEALUI_ADMIN_PASSWORD=your-secure-password-here

# =============================================================================
# OPTIONAL - CORS & SECURITY
# =============================================================================

# Comma-separated list of allowed CORS origins
# Format: https://domain1.com,https://domain2.com
# Optional - defaults to empty (no CORS)
# Security: LOW - Public configuration
REVEALUI_CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Legacy: REVEALUI_WHITELISTORIGINS (deprecated, use REVEALUI_CORS_ORIGINS)
# REVEALUI_WHITELISTORIGINS=http://localhost:3000,http://localhost:4000

# =============================================================================
# OPTIONAL - SUPABASE CLIENT
# =============================================================================

# Supabase project URL
# Optional - only needed if using Supabase client features
# Get from: https://supabase.com → Project Settings → API
# Security: LOW - Safe for client-side
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key
# Optional - only needed if using Supabase client features
# Get from: https://supabase.com → Project Settings → API
# Security: LOW - Safe for client-side
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase database URI (alternative to POSTGRES_URL)
# Optional - can be used instead of POSTGRES_URL for Supabase connections
# Format: postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# Security: HIGH - Server-side only
# SUPABASE_DATABASE_URI=postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# =============================================================================
# OPTIONAL - ELECTRIC SYNC
# =============================================================================

# Electric service URL (for real-time sync)
# Optional - only needed if using Electric sync features
# Security: LOW - Safe for client-side
# NEXT_PUBLIC_ELECTRIC_SERVICE_URL=ws://localhost:5133

# Electric service URL (server-side)
# Optional - only needed if using Electric sync features
# Security: LOW - Server-side configuration
# ELECTRIC_SERVICE_URL=ws://localhost:5133

# =============================================================================
# OPTIONAL - ERROR MONITORING (Sentry)
# =============================================================================

# Sentry DSN for error tracking
# Optional - only needed if using Sentry for error monitoring
# Get from: https://sentry.io → Settings → Client Keys (DSN)
# Security: LOW - Safe for client-side
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o1234567.ingest.sentry.io/1234567

# Sentry auth token (for CI/CD deployments)
# Optional - only needed for automated source map uploads
# Get from: https://sentry.io → Settings → Auth Tokens
# Security: HIGH - Server-side only, CI/CD only
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry organization slug
# Optional - only needed for automated deployments
# Get from: https://sentry.io → Settings → Organization
# Security: LOW - Public configuration
# SENTRY_ORG=your-org-slug

# Sentry project slug
# Optional - only needed for automated deployments
# Get from: https://sentry.io → Settings → Projects
# Security: LOW - Public configuration
# SENTRY_PROJECT=your-project-slug

# =============================================================================
# OPTIONAL - DEVELOPMENT TOOLS
# =============================================================================

# Neon API key (for MCP server)
# Optional - only needed if using Neon MCP integration
# Get from: https://neon.tech → Settings → API Keys
# Security: HIGH - Server-side only
# NEON_API_KEY=neon_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key (for MCP server)
# Optional - only needed if using Supabase MCP integration
# Get from: https://supabase.com → Project Settings → API → Service Role Key
# Security: HIGH - Server-side only, has admin access
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe proxy logging (development only)
# Optional - set to '1' to enable proxy logging
# Security: LOW - Development only
# STRIPE_PROXY=0

# Skip onInit hook (testing only)
# Optional - set to 'true' to skip onInit in test environment
# Security: N/A - Testing only
# SKIP_ONINIT=false

# OpenAI API key (for AI features)
# Optional - only needed if using AI features
# Get from: https://platform.openai.com/api-keys
# Security: HIGH - Server-side only
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MCP API key (for MCP server)
# Optional - only needed if using MCP integrations
# Security: HIGH - Server-side only
# MCP_API_KEY=your-mcp-api-key-here

# Vercel API key (for deployments)
# Optional - only needed for Vercel deployments
# Get from: https://vercel.com/account/tokens
# Security: HIGH - Server-side only
# VERCEL_API_KEY=vercel_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================

# Node environment
# Automatically set by Next.js/Vercel
# Values: development, production, test
# NODE_ENV=development

# Node options
# Optional - recommended to suppress deprecation warnings
# NODE_OPTIONS=--no-deprecation

# =============================================================================
# OPTIONAL - AI / LLM CONFIGURATION
# =============================================================================

# LLM Provider Selection
# Options: openai, anthropic, vultr
# Default: openai
# LLM_PROVIDER=openai

# OpenAI Configuration
# Optional - only needed if using OpenAI provider
# Get from: https://platform.openai.com/api-keys
# Security: HIGH - Server-side only
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Configuration
# Optional - only needed if using Anthropic provider
# Get from: https://console.anthropic.com/
# Security: HIGH - Server-side only
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vultr AI Configuration
# Optional - only needed if using Vultr provider
# Get from: https://www.vultr.com/
# Security: HIGH - Server-side only
# VULTR_API_KEY=VXUUC6WSXXXXXXXXXXXXXXXXXXXXXXXXXX
# VULTR_BASE_URL=https://api.vultrinference.com/v1

# LLM Model Selection
# Optional - provider-specific model name
# Examples: gpt-4o-mini, claude-3-5-sonnet-20241022, llama-3-8b-instruct
# LLM_MODEL=gpt-4o-mini

# Enable Anthropic Prompt Caching (90% cost savings on repeated context)
# Cache TTL: 5 minutes, automatically caches system prompts and tools
# Works with: Anthropic Claude only (OpenAI doesn't support caching yet)
# Recommended: true for production (significant cost savings)
# Security: N/A - Performance optimization
LLM_ENABLE_CACHE=true

# Enable Vector Memory for Context
# Optional - enables semantic search for conversation context
# Requires: POSTGRES_URL with pgvector extension
# Default: false
# ENABLE_VECTOR_MEMORY=false

# =============================================================================
# APP-SPECIFIC VARIABLES
# =============================================================================

# CMS URL (for web app to connect to CMS)
# Development: http://localhost:4000
# Production: https://your-cms-domain.com
# Security: LOW - Safe for client-side
NEXT_PUBLIC_CMS_URL=http://localhost:4000

# Vite-specific variables (for RevealUI web app)
# Development: http://localhost:4000
# Security: LOW - Safe for client-side
VITE_CMS_URL=http://localhost:4000
VITE_REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000

# Supabase publishable key (legacy naming)
# Optional - use NEXT_PUBLIC_SUPABASE_ANON_KEY instead
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxx
