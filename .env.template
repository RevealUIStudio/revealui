# =============================================================================
# REVEALUI FRAMEWORK - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# 
# Copy this file to .env.development.local and fill in your values
# DO NOT commit .env.development.local to git (it's in .gitignore)
#
# Usage:
#   cp .env.template .env.development.local
#   # Then edit .env.development.local with your actual values
#
# =============================================================================

# =============================================================================
# REQUIRED - REVEALUI CORE
# =============================================================================

# Secret key for JWT tokens and session encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 32+ characters
# Security: HIGH - Server-side only, never expose to client
REVEALUI_SECRET=your-secret-key-here-minimum-32-characters

# Session cookie domain (REQUIRED in production)
# Set to your root domain with leading dot to share across subdomains
# Example: .example.com (allows auth.example.com, app.example.com, etc.)
# Security: MEDIUM - Must match your actual deployment domain
SESSION_COOKIE_DOMAIN=.your-domain.com

# Public server URL (used by RevealUI Admin)
# Development: http://localhost:4000
# Production: https://your-domain.com
# Security: LOW - Safe for client-side
REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000

# Next.js public server URL (used by Next.js)
# Should match REVEALUI_PUBLIC_SERVER_URL
# Development: http://localhost:4000
# Production: https://your-domain.com
# Security: LOW - Safe for client-side
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# Public API URL (used by marketing site and other consumers)
# Development: http://localhost:3004
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:3004

# =============================================================================
# REQUIRED - DATABASE
# =============================================================================

# PostgreSQL connection string (NeonDB, Supabase, or other Postgres provider)
# Format: postgresql://user:password@host:port/database?sslmode=require
# Get from: https://neon.tech → Dashboard → Connection String
# Security: HIGH - Server-side only, contains credentials
# Note: DATABASE_URL is also supported as fallback for compatibility
POSTGRES_URL=postgresql://user:password@host:port/database?sslmode=require

# Vector database (Supabase with pgvector)
# Used for: AI memory embeddings, agent tasks, semantic search
# Note: DATABASE_URL is accepted as fallback but SUPABASE_DATABASE_URL is preferred
SUPABASE_DATABASE_URL=postgresql://user:password@host.supabase.co:6543/postgres

# Alternative: DATABASE_URL (fallback if POSTGRES_URL not set)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# -----------------------------------------------------------------------------
# Database Pool [OPTIONAL]
# -----------------------------------------------------------------------------

# DB_POOL_MAX=10                    # Max connections in pg pool (default: 10)
# DB_POOL_IDLE_TIMEOUT=30000        # Idle connection timeout in ms (default: 30000)

# =============================================================================
# REQUIRED - STORAGE (Vercel Blob)
# =============================================================================

# Vercel Blob Storage read/write token
# Required for media uploads in production
# Get from: https://vercel.com/dashboard → Storage → Blob → Create Token
# Security: HIGH - Server-side only
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# REQUIRED - STRIPE PAYMENTS
# =============================================================================

# Stripe secret key (server-side)
# Development: Use test key (sk_test_...)
# Production: Use live key (sk_live_...)
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Security: HIGH - Server-side only
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe publishable key (client-side safe)
# Development: Use test key (pk_test_...)
# Production: Use live key (pk_live_...)
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Security: LOW - Safe for client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook secret (for webhook signature verification)
# Get from: https://dashboard.stripe.com → Developers → Webhooks → Add endpoint
# For local dev: Use `stripe listen --forward-to localhost:4000/api/webhooks/stripe`
# Security: HIGH - Server-side only
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...   # Separate secret for live mode

# Stripe price IDs (created by `pnpm stripe:seed`)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# Stripe Max price ID (created by `pnpm stripe:seed`)
NEXT_PUBLIC_STRIPE_MAX_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# Stripe Enterprise/Forge price ID (created by `pnpm stripe:seed`)
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe support renewal price IDs (annual renewal for perpetual licenses)
# STRIPE_RENEWAL_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_RENEWAL_MAX_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_RENEWAL_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Billing Meter event name for agent task overage reporting
# Create a Meter in Stripe Dashboard → Billing → Meters with event_name matching this value
# STRIPE_AGENT_METER_EVENT_NAME=agent_task_overage

# Early adopter promotion (optional — time-limited coupon for launch)
# REVEALUI_EARLY_ADOPTER_END=2026-06-01
# REVEALUI_EARLY_ADOPTER_COUPON_PRO=coupon_xxx
# REVEALUI_EARLY_ADOPTER_COUPON_MAX=coupon_xxx

# License signing keys (generated by `pnpm stripe:keys`)
REVEALUI_LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
REVEALUI_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Email provider — Gmail REST API via Google Workspace service account
# (required for password reset, verification, and recovery flows).
# Resend / SMTP / nodemailer paths were removed 2026-04-09 (PR #227).
# Setup: create a service account, enable domain-wide delegation, set
# EMAIL_FROM to a Workspace user that holds the delegation.
GOOGLE_SERVICE_ACCOUNT_EMAIL=sa@<project>.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<escaped-pem>\n-----END PRIVATE KEY-----\n"
EMAIL_FROM=noreply@yourdomain.com

# Email address to notify when someone joins the waitlist
# Optional - waitlist notifications are silently skipped if unset
# REVEALUI_WAITLIST_NOTIFY_EMAIL=founder@yourdomain.com

# =============================================================================
# OPTIONAL - REVEALUI ADMIN
# =============================================================================

# Initial admin user email (only used if no users exist)
# Optional - can be set during first user creation in UI
# Security: LOW - Public information
# REVEALUI_ADMIN_EMAIL=admin@example.com

# Initial admin user password (only used if no users exist)
# Must be at least 12 characters
# Optional - can be set during first user creation in UI
# Security: HIGH - Server-side only
# REVEALUI_ADMIN_PASSWORD=your-secure-password-here
# ADMIN_NAME=Admin User

# E2E test credentials (for Playwright tests)
# ADMIN_ADMIN_EMAIL=admin@example.com
# ADMIN_ADMIN_PASSWORD=
# STRIPE_PRO_PRICE_ID=price_xxx
# STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# =============================================================================
# OPTIONAL - CORS & SECURITY
# =============================================================================

# Comma-separated list of allowed CORS origins
# Format: https://domain1.com,https://domain2.com
# Optional - defaults to empty (no CORS)
# Security: LOW - Public configuration
REVEALUI_CORS_ORIGINS=http://localhost:3000,http://localhost:4000
# CORS_ORIGIN=https://admin.yourdomain.com,https://yourdomain.com

# Legacy: REVEALUI_WHITELISTORIGINS (deprecated, use REVEALUI_CORS_ORIGINS)
# REVEALUI_WHITELISTORIGINS=http://localhost:3000,http://localhost:4000

# =============================================================================
# OPTIONAL - BRANDING & WHITE-LABEL
# =============================================================================

# Display name shown in the admin UI and emails (default: "RevealUI")
# REVEALUI_BRAND_NAME=Acme CMS

# URL to your logo image (shown in admin login and emails)
# REVEALUI_BRAND_LOGO_URL=https://cdn.example.com/logo.png

# Primary brand color as a hex value (used in admin UI accents)
# REVEALUI_BRAND_PRIMARY_COLOR=#6366f1

# Show "Powered by RevealUI" footer badge in admin UI (default: true)
# Set to false to hide (requires Pro license)
# REVEALUI_SHOW_POWERED_BY=true

# =============================================================================
# OPTIONAL - SIGNUP CONTROL
# =============================================================================

# Allow open self-registration (default: true in development, false in production)
# Set to false to restrict signup to the whitelist below
# REVEALUI_SIGNUP_OPEN=true

# Comma-separated list of email addresses or domains allowed to sign up
# Only used when REVEALUI_SIGNUP_OPEN=false
# Examples: "alice@example.com,bob@example.com" or "@example.com"
# REVEALUI_SIGNUP_WHITELIST=

# Support contact email (shown in transactional emails sent to customers)
# Defaults to support@revealui.com if not set
# REVEALUI_SUPPORT_EMAIL=support@yourdomain.com

# =============================================================================
# OPTIONAL - LICENSE
# =============================================================================

# RevealUI Pro/Enterprise license key (unlocks commercial features)
# Get your key at: https://revealui.com/pro
# Security: MEDIUM - Keep out of client-side bundles
# REVEALUI_LICENSE_KEY=rui_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Encryption key for license keys at rest (AES-256-GCM, 32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REVEALUI_LICENSE_ENCRYPTION_KEY=

# License cache TTL in milliseconds (default: 15000 = 15 seconds)
# Controls how quickly license revocations take effect.
# Lower = faster revocation detection, higher = less DB pressure.
# LICENSE_CACHE_TTL_MS=15000

# =============================================================================
# OPTIONAL - SUPABASE CLIENT
# =============================================================================

# Supabase project URL
# Optional - only needed if using Supabase client features
# Get from: https://supabase.com → Project Settings → API
# Security: LOW - Safe for client-side
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key
# Optional - only needed if using Supabase client features
# Get from: https://supabase.com → Project Settings → API
# Security: LOW - Safe for client-side
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase database URI (alternative to POSTGRES_URL)
# Optional - can be used instead of POSTGRES_URL for Supabase connections
# Format: postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# Security: HIGH - Server-side only
# SUPABASE_DATABASE_URI=postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# =============================================================================
# OPTIONAL - ELECTRIC SYNC
# =============================================================================

# Electric service URL (for real-time sync)
# Optional - only needed if using Electric sync features
# Security: LOW - Safe for client-side
# NEXT_PUBLIC_ELECTRIC_SERVICE_URL=ws://localhost:5133

# Electric service URL (server-side)
# Optional - only needed if using Electric sync features
# Security: LOW - Server-side configuration
# ELECTRIC_SERVICE_URL=ws://localhost:5133

# =============================================================================
# OPTIONAL - ERROR MONITORING (Sentry)
# =============================================================================

# Sentry DSN for error tracking
# Optional - only needed if using Sentry for error monitoring
# Get from: https://sentry.io → Settings → Client Keys (DSN)
# Security: LOW - Safe for client-side
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o1234567.ingest.sentry.io/1234567

# Sentry auth token (for CI/CD deployments)
# Optional - only needed for automated source map uploads
# Get from: https://sentry.io → Settings → Auth Tokens
# Security: HIGH - Server-side only, CI/CD only
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry organization slug
# Optional - only needed for automated deployments
# Get from: https://sentry.io → Settings → Organization
# Security: LOW - Public configuration
# SENTRY_ORG=your-org-slug

# Sentry project slug
# Optional - only needed for automated deployments
# Get from: https://sentry.io → Settings → Projects
# Security: LOW - Public configuration
# SENTRY_PROJECT=your-project-slug

# Internal logging/error endpoints (token-protected)
# REVEALUI_ERROR_TOKEN=
# REVEALUI_LOG_TOKEN=

# =============================================================================
# OPTIONAL - DEVELOPMENT TOOLS
# =============================================================================

# Neon API key (for MCP server)
# Optional - only needed if using Neon MCP integration
# Get from: https://neon.tech → Settings → API Keys
# Security: HIGH - Server-side only
# NEON_API_KEY=neon_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key (for MCP server)
# Optional - only needed if using Supabase MCP integration
# Get from: https://supabase.com → Project Settings → API → Service Role Key
# Security: HIGH - Server-side only, has admin access
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe proxy logging (development only)
# Optional - set to '1' to enable proxy logging
# Security: LOW - Development only
# STRIPE_PROXY=0

# Skip onInit hook (testing only)
# Optional - set to 'true' to skip onInit in test environment
# Security: N/A - Testing only
# SKIP_ONINIT=false

# Skip env validation (CI builds)
# SKIP_ENV_VALIDATION=true

# API server port (default: 3004)
# API_PORT=3004

# Playwright E2E test base URL
# PLAYWRIGHT_BASE_URL=http://localhost:4000

# OpenAI API key (for AI features)
# Optional - only needed if using AI features
# Get from: https://platform.openai.com/api-keys
# Security: HIGH - Server-side only
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MCP API key (for MCP server)
# Optional - only needed if using MCP integrations
# Security: HIGH - Server-side only
# MCP_API_KEY=your-mcp-api-key-here

# Vercel API key (for deployments)
# Optional - only needed for Vercel deployments
# Get from: https://vercel.com/account/tokens
# Security: HIGH - Server-side only
# VERCEL_API_KEY=vercel_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================

# Node environment
# Automatically set by Next.js/Vercel
# Values: development, production, test
# NODE_ENV=development

# Node options
# Optional - recommended to suppress deprecation warnings
# NODE_OPTIONS=--no-deprecation

# =============================================================================
# OPTIONAL - AI / LLM CONFIGURATION
# =============================================================================

# LLM Provider Selection
# Options: inference-snaps (default, Ubuntu local), ollama (local), groq, huggingface
# Default: inference-snaps when no env var is set (auto-detect prefers
#   INFERENCE_SNAPS_BASE_URL → GROQ_API_KEY → OLLAMA_BASE_URL).
# LLM_PROVIDER=inference-snaps

# Open-Model Inference (Apache 2.0 — zero commercial fees)
# RevealUI supports open models only — no proprietary cloud APIs.
# Local: Ubuntu inference snaps (recommended), Ollama (any GGUF model)
# Cloud: Groq (LPU silicon, fast), HuggingFace (model variety)
# INFERENCE_SNAPS_BASE_URL=http://localhost:9090/v1
# OLLAMA_BASE_URL=http://localhost:11434

# Web search (for AI agent tools)
# TAVILY_API_KEY=tvly-...

# Groq Configuration
# Optional - only needed if using Groq provider for cloud inference
# Get from: https://console.groq.com/keys
# Security: HIGH - Server-side only
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# HuggingFace Configuration
# Optional - only needed if using HuggingFace provider
# Get from: https://huggingface.co/settings/tokens
# Security: HIGH - Server-side only
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HF_MODEL_URL=https://api-inference.huggingface.co/models/your-model

# LLM Model Selection
# Optional - provider-specific model name
# Examples: gemma3 (inference-snaps), qwen/qwen3-32b (groq), gemma4:e2b (ollama)
# LLM_MODEL=gemma3

# Enable Anthropic Prompt Caching (90% cost savings on repeated context)
# Cache TTL: 5 minutes, automatically caches system prompts and tools
# Works with: Anthropic Claude only (OpenAI doesn't support caching yet)
# Recommended: true for production (significant cost savings)
# Security: N/A - Performance optimization
LLM_ENABLE_CACHE=true

# Enable Response Caching (100% cost savings on duplicate requests)
# Cache TTL: 5 minutes, caches complete LLM responses
# Works with: All providers
# Recommended: true for cloud providers without built-in prompt caching
# Security: N/A - Performance optimization
# Note: Use with Anthropic prompt caching for maximum savings
LLM_ENABLE_RESPONSE_CACHE=true

# Enable Semantic Caching (73% cost reduction, 65% hit rate vs 18%)
# Cache TTL: 1 hour, matches similar queries using vector embeddings
# Similarity threshold: 0.95 (configurable)
# Works with: All providers
# Recommended: true for FAQ-style applications with similar questions
# Security: N/A - Performance optimization
# Note: More powerful than response caching - matches "How do I reset password?" with "Password reset help"
# Requires: POSTGRES_URL with pgvector extension
LLM_ENABLE_SEMANTIC_CACHE=true

# Enable Vector Memory for Context
# Optional - enables semantic search for conversation context
# Requires: POSTGRES_URL with pgvector extension
# Default: false
# ENABLE_VECTOR_MEMORY=false

# =============================================================================
# OPTIONAL - OAUTH ADMIN SSO
# All providers are optional — only configure the ones you want to enable.
# =============================================================================

# Google OAuth 2.0 — https://console.cloud.google.com → OAuth 2.0 Client IDs
# Security: HIGH - Server-side only
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth App — https://github.com/settings/developers → OAuth Apps
# Security: HIGH - Server-side only
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Vercel OAuth App — https://vercel.com/account/oauth-applications
# Security: HIGH - Server-side only
# VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=

# Comma-separated email allowlist for OAuth admin access.
# Leave empty to allow any authenticated OAuth account.
# OAUTH_ADMIN_EMAILS=admin@example.com,other@example.com

# Base URL used to construct OAuth redirect URIs (e.g. https://admin.revealui.com)
# Defaults to NEXT_PUBLIC_SERVER_URL if not set.
# NEXT_PUBLIC_APP_URL=http://localhost:4000

# =============================================================================
# OPTIONAL - MCP SERVERS
# =============================================================================

# MCP_PERSISTENCE_DRIVER=pglite          # pglite (default) or postgres
# MCP_METRICS_MODE=logs                  # logs (default), prometheus, or otel
# ELECTRIC_DATABASE_URL=                 # ElectricSQL connection
# ELECTRIC_API_KEY=                      # ElectricSQL API key
# PGVECTOR_ENABLED=false                 # Enable pgvector in MCP

# =============================================================================
# APP-SPECIFIC VARIABLES
# =============================================================================

# Admin URL (for web app to connect to admin)
# Development: http://localhost:4000
# Production: https://your-admin-domain.com
# Security: LOW - Safe for client-side
NEXT_PUBLIC_ADMIN_URL=http://localhost:4000

# Vite-specific variables (for RevealUI web app)
# Development: http://localhost:4000
# Security: LOW - Safe for client-side
VITE_ADMIN_URL=http://localhost:4000
VITE_REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000

# Supabase publishable key (legacy naming)
# Optional - use NEXT_PUBLIC_SUPABASE_ANON_KEY instead
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# =============================================================================
# x402 NATIVE PAYMENTS (Phase 5.2 — disabled by default)
# Enables per-task USDC micropayments via the x402 protocol (https://x402.org)
# when agent task quota is exceeded. Agents pay in USDC on Base instead of
# hard-blocking. Requires a USDC wallet address on Base to receive payments.
# =============================================================================

# Set to 'true' to enable x402 payment path when quota is exceeded
X402_ENABLED=false

# Your USDC wallet address on Base that receives micropayments
# Required when X402_ENABLED=true
X402_RECEIVING_ADDRESS=

# Base network to use: 'evm:base' (mainnet) or 'evm:base-sepolia' (testnet)
X402_NETWORK=evm:base

# USDC price per agent task (human-readable, e.g. '0.001' = $0.001)
X402_PRICE_PER_TASK=0.001

# Coinbase x402 facilitator URL (default: public Coinbase-hosted endpoint)
X402_FACILITATOR_URL=https://x402.org/facilitator

# =============================================================================
# PERPETUAL LICENSE PROVISIONING (Phase 5.3 — Track C)
# Required for perpetual license GitHub team provisioning and support renewal
# cron job. Both are optional at boot; provisioning gracefully degrades.
# =============================================================================

# Fine-grained GitHub PAT with org:write:members scope
# Used to add perpetual license buyers to the RevealUIStudio/revealui-pro-customers team
# Required when perpetual licenses are sold via Stripe checkout (mode=payment)
REVEALUI_GITHUB_TOKEN=

# Secret shared with your cron provider to authenticate POST /api/billing/support-renewal-check
# Any long random string — generate with: openssl rand -hex 32
REVEALUI_CRON_SECRET=

# =============================================================================
# FORGE SELF-HOSTED (Phase 5.4 — enterprise tier)
# Only required when running RevealUI Forge on your own infrastructure.
# See docker-compose.forge.yml for the full self-hosted stack.
# =============================================================================

# Your Forge enterprise license key (issued at checkout)
FORGE_LICENSE_KEY=

# The domain this Forge instance is licensed to serve (e.g. admin.acme.com)
# Requests from any other Host will receive HTTP 403.
FORGE_LICENSED_DOMAIN=

# =============================================================================
# MCP MARKETPLACE (Phase 5.5)
# Required only when operating the RevealUI MCP marketplace.
# Developers publish MCP servers; callers pay via x402 (USDC on Base).
# RevealUI takes 20%; developers earn 80% via Stripe Connect.
# =============================================================================

# URL to redirect developers to after completing Stripe Connect onboarding.
# Defaults to ADMIN_URL/account/marketplace/connect/return if not set.
MARKETPLACE_CONNECT_RETURN_URL=
