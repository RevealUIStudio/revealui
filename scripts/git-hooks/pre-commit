#!/usr/bin/env bash
#
# Pre-Commit Hook - Code Validation
#
# Validates staged files against RevealUI code standards to prevent
# technical debt from being committed.
#
# This hook:
# - Validates TypeScript/JavaScript files
# - Checks for console.log, any types, etc.
# - Can auto-fix violations (with --auto-fix flag)
# - Blocks commits with errors
#
# Installation:
#   ln -sf ../../scripts/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Bypass (for emergencies):
#   git commit --no-verify
#

set -e

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}✓ No TypeScript/JavaScript files to validate${NC}"
  exit 0
fi

echo "🔍 Validating code standards..."
echo ""

ERRORS_FOUND=false
TOTAL_ERRORS=0
TOTAL_WARNINGS=0

# Validate each staged file
while IFS= read -r file; do
  if [ ! -f "$file" ]; then
    continue
  fi

  # Run validator
  RESULT=$(tsx scripts/validation/validate-code.ts "$file" --json 2>&1) || true

  # Parse JSON result
  VALID=$(echo "$RESULT" | jq -r '.valid // false')
  ERRORS=$(echo "$RESULT" | jq -r '.errors // 0')
  WARNINGS=$(echo "$RESULT" | jq -r '.warnings // 0')

  if [ "$VALID" = "false" ]; then
    ERRORS_FOUND=true
    TOTAL_ERRORS=$((TOTAL_ERRORS + ERRORS))
    TOTAL_WARNINGS=$((TOTAL_WARNINGS + WARNINGS))

    echo -e "${RED}✗ $file${NC}"

    # Show violations
    echo "$RESULT" | jq -r '.violations[] | "  [\(.severity | ascii_upcase)] \(.message) (line \(.line))"'
    echo ""
  else
    echo -e "${GREEN}✓ $file${NC}"
  fi
done <<< "$STAGED_FILES"

echo ""
echo "─────────────────────────────────────────"

if [ "$ERRORS_FOUND" = true ]; then
  echo -e "${RED}✗ Code validation failed${NC}"
  echo -e "  ${RED}Errors: $TOTAL_ERRORS${NC}"
  echo -e "  ${YELLOW}Warnings: $TOTAL_WARNINGS${NC}"
  echo ""
  echo "Fix violations and try again, or use:"
  echo "  git commit --no-verify  (bypass validation)"
  echo ""
  exit 1
else
  echo -e "${GREEN}✓ All files pass code standards${NC}"
  exit 0
fi
