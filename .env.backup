# =============================================================================
# RevealUI Development Environment Variables
# =============================================================================
# This file is loaded by both CMS and Web apps
# DO NOT commit this file to git (it's in .gitignore)

# =============================================================================
# CMS Configuration
# =============================================================================

# CMS Server URL (used by CMS itself)
REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# CMS Secret (generate a new one for production)
REVEALUI_SECRET=dev-secret-change-in-production

# =============================================================================
# CORS Configuration
# =============================================================================
# Frontend URL must be included for CORS to work
# Format: comma-separated URLs (no spaces)

REVEALUI_CORS_ORIGINS=http://localhost:3000,http://localhost:4000
REVEALUI_WHITELISTORIGINS=http://localhost:3000,http://localhost:4000

# =============================================================================
# Frontend Web App Configuration
# =============================================================================
# Vite requires VITE_ prefix for client-side access

# CMS API URL for frontend to fetch data
VITE_CMS_URL=http://localhost:4000

# Alternative variable names (for compatibility)
NEXT_PUBLIC_CMS_URL=http://localhost:4000
VITE_REVEALUI_PUBLIC_SERVER_URL=http://localhost:4000

# =============================================================================
# Database Configuration (if using Postgres)
# =============================================================================
# Uncomment and configure if using Postgres instead of SQLite
# POSTGRES_URL=postgresql://user:password@host:5432/database

