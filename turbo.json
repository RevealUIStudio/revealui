{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [],
  "globalPassThroughEnv": [],
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "env": [
        "NODE_ENV",
        "SKIP_ENV_VALIDATION",
        "SKIP_ONINIT",
        "NEXT_BUILD",
        "NEXT_PUBLIC_*",
        "VITE_*",
        "REVEALUI_*",
        "API_URL",
        "CMS_URL",
        "X402_*",
        "LOGGER_PORT",
        "DOCS_PORT",
        "YOUTUBE_BASE_URL"
      ],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "tsup.config.ts",
        "vite.config.ts",
        "next.config.mjs"
      ],
      "outputs": ["dist/**", ".next/**", "output/**", "public/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": true,
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "src/**/*.jsx",
        "eslint.config.js",
        "biome.json",
        "package.json"
      ],
      "outputs": []
    },
    "lint:biome": {
      "cache": true,
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/**/*.jsx", "biome.json"],
      "outputs": []
    },
    "lint:eslint": {
      "cache": true,
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "src/**/*.jsx",
        "eslint.config.js",
        "package.json"
      ],
      "outputs": []
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "format": {
      "cache": false,
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/**/*.jsx", "biome.json"]
    },
    "test": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "vitest.config.ts",
        "package.json"
      ],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx",
        "**/*.test.ts",
        "**/*.test.tsx",
        "vitest.config.ts",
        "package.json"
      ],
      "outputs": ["coverage/**", "coverage/lcov.info"]
    },
    "test:ui": {
      "cache": false,
      "persistent": true
    },
    "test:integration": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "presentation:build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.css", "package.json", "tsconfig.json"],
      "outputs": ["packages/presentation/dist/**"]
    },
    "cms:build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.css",
        "public/**",
        "package.json",
        "tsconfig.json",
        "next.config.mjs"
      ],
      "outputs": ["apps/cms/.next/**", "apps/cms/.next/cache/**"]
    },
    "api:build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "package.json", "tsconfig.json"],
      "outputs": ["apps/api/dist/**"]
    }
  }
}
