{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"globalEnv": [
		"VERCEL_API_KEY",
		"VERCEL_TOKEN",
		"VERCEL_ACCESS_TOKEN",
		"VERCEL_TEAM_ID",
		"STRIPE_SECRET_KEY",
		"STRIPE_PUBLISHABLE_KEY",
		"OPENAI_API_KEY"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"start": {
			"dependsOn": ["build"],
			"cache": false,
			"persistent": true
		},
		"lint": {},
		"typecheck": {},
		"clean": {
			"cache": false
		}
	}
}

