{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [],
  "globalPassThroughEnv": [
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "VERCEL_CLIENT_ID",
    "VERCEL_CLIENT_SECRET",
    "STRIPE_*",
    "RESEND_*",
    "EMAIL_FROM",
    "FORGE_LICENSED_DOMAIN",
    "VERCEL",
    "VERCEL_ENV"
  ],
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "env": [
        "NODE_ENV",
        "SKIP_ENV_VALIDATION",
        "SKIP_ONINIT",
        "NEXT_BUILD",
        "NEXT_PUBLIC_*",
        "VITE_*",
        "REVEALUI_*",
        "API_URL",
        "CMS_URL",
        "X402_*",
        "LOGGER_PORT",
        "DOCS_PORT",
        "YOUTUBE_BASE_URL",
        "POSTGRES_URL",
        "DATABASE_URL",
        "BLOB_READ_WRITE_TOKEN"
      ],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "tsup.config.ts",
        "vite.config.ts",
        "next.config.mjs"
      ],
      "outputs": ["dist/**", ".next/**", "output/**", "public/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": true,
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "src/**/*.jsx",
        "biome.json",
        "package.json"
      ],
      "outputs": []
    },
    "lint:biome": {
      "cache": true,
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/**/*.jsx", "biome.json"],
      "outputs": []
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json",
        "../../packages/dev/src/ts/**"
      ],
      "outputs": []
    },
    "format": {
      "cache": false,
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/**/*.jsx", "biome.json"]
    },
    "test": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "vitest.config.ts",
        "package.json"
      ],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "**/__tests__/**/*.ts",
        "**/__tests__/**/*.tsx",
        "**/*.test.ts",
        "**/*.test.tsx",
        "vitest.config.ts",
        "package.json"
      ],
      "outputs": ["coverage/**", "coverage/lcov.info"]
    },
    "test:ui": {
      "cache": false,
      "persistent": true
    },
    "test:integration": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    }
  }
}
