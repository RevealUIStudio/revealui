# =============================================================================
# direnv Configuration for RevealUI Framework
# =============================================================================
#
# This file automatically loads the Nix development environment when you
# enter the project directory using direnv + nix-direnv for fast activation.
#
# Setup:
#   1. Install direnv: Already configured on NixOS-WSL
#   2. Allow this file: direnv allow
#   3. Environment activates automatically on cd!
#
# =============================================================================

# Load the flake-based development environment.
# nix-direnv is provided by flake.nix buildInputs — no external fetch needed.
if ls .direnv/flake-profile-* 2>/dev/null | grep -q .; then
  printf "\033[2m  ◈ loading Nix environment…\033[0m\n" >&2
else
  printf "\033[2m  ◈ evaluating Nix flake (cold boot — ~30 s)\033[0m\n" >&2
fi
use flake

# Watch for changes to Nix files (auto-reload environment)
watch_file flake.nix
watch_file flake.lock

# Load .envrc.local early — it provides REVVAULT_IDENTITY and REVVAULT_STORE
# which revvault needs to decrypt secrets. Must come before the revvault block.
source_env_if_exists .envrc.local

# =============================================================================
# Revvault: load secrets from age-encrypted vault (optional)
# =============================================================================
if [[ -x "$HOME/.local/bin/revvault" ]]; then
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/core 2>/dev/null)"
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/license 2>/dev/null)"
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/stripe 2>/dev/null)"
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/supabase 2>/dev/null)"
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/services 2>/dev/null)"
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/cron 2>/dev/null)"
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/admin 2>/dev/null)"
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/admin-url 2>/dev/null)"
  eval "$("$HOME/.local/bin/revvault" export-env revealui/env/npm 2>/dev/null)"
fi

# Load environment files (for secrets and local config)
# .env overrides vault values — useful for local dev tweaks.
# Once Revvault covers all vars, .env can be removed.
dotenv_if_exists .env
dotenv_if_exists .env.development.local
dotenv_if_exists .env.local

# Keep the Nix dev shell's local Postgres as the default for local development.
# If a dotenv file sets a remote DB URL, require an explicit opt-in so direnv
# does not silently redirect local commands like db:migrate or db-reset.
if [[ "${REVEALUI_USE_REMOTE_DB:-0}" != "1" ]]; then
  export PGDATA="$PWD/.pgdata"
  export PGHOST="$PWD/.pgdata"
  export PGDATABASE="postgres"
  export PGUSER="postgres"
  export POSTGRES_URL="postgresql://postgres@localhost:5432/postgres"
  export DATABASE_URL="postgresql://postgres@localhost:5432/postgres"
fi

# Watch for changes to environment files (triggers direnv reload on edit)
watch_file .env
watch_file .env.development.local
watch_file .env.local

# Claude Code agent identity — auto-detected by session-start.js hook.
# Override in .envrc.local (gitignored) if auto-detection fails.
