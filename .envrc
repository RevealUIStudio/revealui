# =============================================================================
# direnv Configuration for RevealUI Framework
# =============================================================================
#
# This file automatically loads the Nix development environment when you
# enter the project directory using direnv + nix-direnv for fast activation.
#
# Setup:
#   1. Install direnv: Already configured on NixOS-WSL
#   2. Allow this file: direnv allow
#   3. Environment activates automatically on cd!
#
# =============================================================================

# Load the flake-based development environment.
# nix-direnv is provided by flake.nix buildInputs — no external fetch needed.
use flake

# Watch for changes to Nix files (auto-reload environment)
watch_file flake.nix
watch_file flake.lock

# Load environment files (for secrets and local config)
# .env - bare KEY=VALUE pairs, auto-exported to shell on cd (see .env.development.local for docs)
dotenv_if_exists .env
dotenv_if_exists .env.development.local
dotenv_if_exists .env.local

# Watch for changes to environment files (triggers direnv reload on edit)
watch_file .env
watch_file .env.development.local
watch_file .env.local
