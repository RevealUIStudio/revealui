# =============================================================================
# direnv Configuration for RevealUI Framework
# =============================================================================
#
# This file configures direnv to automatically load environment variables
# when you enter the project directory.
#
# Setup:
#   1. Install direnv: brew install direnv (macOS) or apt install direnv (Linux)
#   2. Add to your shell config (~/.bashrc or ~/.zshrc):
#      eval "$(direnv hook bash)"  # or zsh
#   3. Allow this file: direnv allow
#
# For NixOS users:
#   - Enable direnv: programs.direnv.enable = true
#   - Optionally add: use nix  # or use flake
#
# Node Version: This project requires Node.js >=24.12.0
# The .nvmrc file specifies the exact version to use.
# =============================================================================

# Set Node version using nvm if available, otherwise fall back to the
# pinned Node binary path so tooling uses Node 24.
NODE_VERSION="24.12.0"
NODE_BIN="$HOME/.nvm/versions/node/v${NODE_VERSION}/bin"
if command -v nvm &> /dev/null; then
  nvm use
elif [ -d "$NODE_BIN" ]; then
  PATH="$NODE_BIN:$PATH"
fi

# Load .env.development.local if it exists (contains your local secrets)
# This file is gitignored and should contain your actual credentials
# Using dotenv_if_exists (direnv stdlib function) - only loads if file exists
dotenv_if_exists .env.development.local

# Alternative: Load .env.local as fallback
# if [ -f .env.local ]; then
#   dotenv .env.local
# fi

# For NixOS users (optional):
# Uncomment if using Nix dev shells
# use nix
# or
# use flake

# Watch for changes to env files
watch_file .env.development.local
watch_file .env.local
watch_file .env.template
