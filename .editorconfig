# EditorConfig helps maintain consistent coding styles across various editors and IDEs
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript, JavaScript, JSX, TSX
[*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 100

# JSON files
[*.json]
indent_style = space
indent_size = 2

# JSON with comments (tsconfig, etc.)
[*.jsonc]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# MDX files
[*.mdx]
trim_trailing_whitespace = false

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab

# Package.json - always 2 spaces
[package.json]
indent_style = space
indent_size = 2

# Lock files - don't format
[{package-lock.json,pnpm-lock.yaml,yarn.lock}]
insert_final_newline = false
trim_trailing_whitespace = false

# Environment files
[.env*]
insert_final_newline = true
trim_trailing_whitespace = true

# Git files
[.git*]
insert_final_newline = true
trim_trailing_whitespace = true

# Docker files
[Dockerfile*]
indent_style = space
indent_size = 2

# SQL files
[*.sql]
indent_style = space
indent_size = 2

# GraphQL files
[*.{gql,graphql}]
indent_style = space
indent_size = 2

# HTML files
[*.html]
indent_style = space
indent_size = 2

# CSS, SCSS, SASS files
[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# XML files
[*.xml]
indent_style = space
indent_size = 2

# TOML files
[*.toml]
indent_style = space
indent_size = 2
