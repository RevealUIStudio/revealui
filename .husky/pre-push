#!/bin/bash

# Guard: Pro packages must remain gitignored — prevents accidental leak to public repo
for pkg in packages/ai packages/harnesses; do
  if ! git check-ignore -q "$pkg" 2>/dev/null; then
    echo ""
    echo "FATAL: $pkg is no longer gitignored! Aborting push."
    echo "   Restore the entry in .gitignore before pushing."
    echo ""
    exit 1
  fi
done

# Check if any committed Pro package files would be pushed
RANGE=""
while read local_ref local_oid remote_ref remote_oid; do
  if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
    RANGE="$local_oid"
  else
    RANGE="$remote_oid..$local_oid"
  fi
done
if [ -n "$RANGE" ]; then
  PRO_FILES=$(git diff --name-only "$RANGE" -- packages/ai/ packages/harnesses/ 2>/dev/null || true)
  if [ -n "$PRO_FILES" ]; then
    echo ""
    echo "FATAL: Pro package files detected in commits being pushed!"
    echo "$PRO_FILES" | head -20
    echo ""
    echo "   Pro packages must never be pushed to the public repo."
    echo ""
    exit 1
  fi
fi

# Branch-aware gate strictness
#   main/test: full gate (these trigger CI + deploy)
#   develop/feature/*: quality-only (local dev, no CI)
BRANCH=$(git rev-parse --abbrev-ref HEAD)
case "$BRANCH" in
  main|test)
    echo ""
    echo "Running full CI gate for protected branch '$BRANCH'..."
    echo ""
    pnpm gate
    ;;
  *)
    echo ""
    echo "Running quality checks for '$BRANCH'..."
    echo ""
    pnpm gate --phase=1 --changed
    ;;
esac
