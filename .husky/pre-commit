#!/bin/bash

# Guard: Pro packages must remain gitignored — prevents accidental leak to public repo
LEAKED=""
for pkg in ee/packages/ai ee/packages/mcp ee/packages/editors ee/packages/services; do
  if ! git check-ignore -q "$pkg/" 2>/dev/null; then
    LEAKED="$LEAKED $pkg"
  fi
done
if [ -n "$LEAKED" ]; then
  echo ""
  echo "FATAL: Pro packages are no longer gitignored!"
  echo "   Leaked:$LEAKED"
  echo "   Restore these entries in .gitignore before committing:"
  echo "   ee/packages/ai/"
  echo "   ee/packages/mcp/"
  echo "   ee/packages/editors/"
  echo "   ee/packages/services/"
  echo ""
  exit 1
fi

# Scan for hardcoded secrets before committing
pnpm secrets:scan

# Gitleaks — scan staged changes for leaked secrets
if command -v gitleaks &>/dev/null; then
  gitleaks protect --staged --no-banner
fi

# Run lint-staged for formatting checks
pnpm lint-staged

# Run code validator for AI-generated code standards
echo ""
echo "🔍 Validating code standards..."
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | grep -v -E '(\.test\.|\.spec\.|__tests__|examples/|^e2e/|/e2e/|packages/utils/src/logger/|packages/test/load-tests/|packages/test/src/integration|packages/setup/src/utils/logger|packages/core/src/utils/logger|packages/core/src/instance/logger|packages/core/src/utils/logger-client|packages/core/src/security/headers|packages/contracts/src/|/generated/)' || true)

if [ -n "$STAGED_TS_FILES" ]; then
  VALIDATION_FAILED=false

  while IFS= read -r file; do
    if [ -f "$file" ]; then
      node --import tsx scripts/validation/validate-code.ts "$file" > /dev/null 2>&1 || {
        echo "  ❌ $file (has code standard violations)"
        node --import tsx scripts/validation/validate-code.ts "$file" 2>&1 | grep -A 1 "ERROR\|WARNING" | head -10
        VALIDATION_FAILED=true
      }
    fi
  done <<EOF
$STAGED_TS_FILES
EOF

  if [ "$VALIDATION_FAILED" = true ]; then
    echo ""
    echo "❌ Code validation failed. Fix violations or use:"
    echo "   git commit --no-verify  (bypass validation)"
    exit 1
  else
    echo "✅ All files pass code standards"
  fi
else
  echo "  ℹ️  No TypeScript/JavaScript files to validate"
fi
echo ""

# Check if script files changed
SCRIPT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^scripts/.*\.ts$" || true)

if [ -n "$SCRIPT_FILES" ]; then
  echo "📝 Script files changed, validating dependencies..."
  echo "Changed files:"
  echo "$SCRIPT_FILES" | sed 's/^/  - /'

  # Validate dependencies for changed files
  for file in $SCRIPT_FILES; do
    echo "  Validating $file..."
    # Removed: pnpm check validate:dependencies — script does not exist in package.json
    true
  done

  # Removed: pnpm ops audit:exit-codes — script does not exist in package.json

  echo "✅ Script validation complete"
fi

# Check if schema files changed
SCHEMA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "packages/db/src/schema/.*\.ts$" || true)

if [ -n "$SCHEMA_FILES" ]; then
  echo "🔄 Schema files changed, regenerating types..."
  echo "Changed files:"
  echo "$SCHEMA_FILES" | sed 's/^/  - /'

  # Regenerate types
  pnpm --filter @revealui/db generate:all

  if [ $? -eq 0 ]; then
    echo "✅ Types regenerated successfully"

    # Stage generated files
    git add packages/contracts/src/generated/*.ts
    git add packages/db/src/types/database.ts

    echo "📦 Generated files staged for commit"
  else
    echo "❌ Type generation failed. Fix errors before committing."
    exit 1
  fi
fi
