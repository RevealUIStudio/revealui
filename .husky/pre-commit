# Run package extraction guardrails before commits
echo "🛡️ Running package extraction guardrails..."
if ! pnpm exec tsx scripts/validation/package-extraction-guardrails.ts; then
    echo "❌ Package extraction guardrails failed. Fix issues before committing."
    exit 1
fi

# Monitor for unauthorized package creation
echo "👀 Checking for unauthorized package creation..."
if ! pnpm exec tsx scripts/validation/package-creation-monitor.ts --enforce; then
    echo "❌ Package creation violations detected. Fix issues before committing."
    exit 1
fi

echo "✅ All package extraction checks passed"

# Run console statement validation for production code
echo "Checking for console statements in production code..."
pnpm validate:console || exit 1

# Run Biome linter on staged files (bypassing Turbo to avoid dependency cycle)
echo "Running Biome linter on staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | grep -v '^scripts/' || true)
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | xargs pnpm dlx @biomejs/biome check --files-ignore-unknown=true || exit 1
else
  echo "No TypeScript/JavaScript files staged (excluding scripts directory)"
fi