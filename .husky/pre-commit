# Run lint-staged for formatting checks
pnpm lint-staged

# Check if script files changed
SCRIPT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^scripts/.*\.ts$" || true)

if [ -n "$SCRIPT_FILES" ]; then
  echo "📝 Script files changed, validating dependencies..."
  echo "Changed files:"
  echo "$SCRIPT_FILES" | sed 's/^/  - /'

  # Validate dependencies for changed files
  for file in $SCRIPT_FILES; do
    echo "  Validating $file..."
    pnpm check validate:dependencies --file="$file" > /dev/null 2>&1 || {
      echo "⚠️  Warning: $file has dependency validation issues"
      echo "   Run 'pnpm check validate:dependencies --file=$file' to see details"
    }
  done

  # Audit exit codes (warnings only)
  echo "  Auditing exit codes..."
  pnpm ops audit:exit-codes --json > /tmp/exit-code-audit.json 2>&1 || true
  VIOLATIONS=$(cat /tmp/exit-code-audit.json | grep -o '"totalViolations":[0-9]*' | grep -o '[0-9]*' || echo "0")
  if [ "$VIOLATIONS" -gt "0" ]; then
    echo "⚠️  Warning: Found $VIOLATIONS exit code violations"
    echo "   Run 'pnpm ops audit:exit-codes' to see details"
  fi

  echo "✅ Script validation complete"
fi

# Check if schema files changed
SCHEMA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "packages/db/src/schema/.*\.ts$" || true)

if [ -n "$SCHEMA_FILES" ]; then
  echo "🔄 Schema files changed, regenerating types..."
  echo "Changed files:"
  echo "$SCHEMA_FILES" | sed 's/^/  - /'

  # Regenerate types
  pnpm generate:all

  if [ $? -eq 0 ]; then
    echo "✅ Types regenerated successfully"

    # Stage generated files
    git add packages/contracts/src/generated/*.ts
    git add packages/db/src/types/database.ts

    echo "📦 Generated files staged for commit"
  else
    echo "❌ Type generation failed. Fix errors before committing."
    exit 1
  fi
fi
