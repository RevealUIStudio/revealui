# Run console statement validation for production code
echo "Checking for console statements in production code..."
pnpm validate:console || exit 1

# Run Biome linter on staged files (bypassing Turbo to avoid dependency cycle)
echo "Running Biome linter on staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | grep -v '^scripts/' || true)
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | xargs pnpm dlx @biomejs/biome check --files-ignore-unknown=true || exit 1
else
  echo "No TypeScript/JavaScript files staged (excluding scripts directory)"
fi