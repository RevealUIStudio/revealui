{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "jsx": "react-jsx",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "revealui/*": ["./packages/core/src/*"],
      "revealui/config": ["./packages/core/src/config/index.ts"],
      "revealui/plugins/*": ["./packages/core/src/plugins/*"],
      "@revealui/types": ["./packages/types/src/index.ts"],
      "@revealui/types/*": ["./packages/types/src/*"],
      "@revealui/generated": ["./packages/generated/src/index.ts"],
      "@revealui/generated/*": ["./packages/generated/src/*"],
      "@revealui/core": ["./packages/core/src/index.ts"],
      "@revealui/core/*": ["./packages/core/src/*"],
      "@revealui/contracts": ["./packages/contracts/src/index.ts"],
      "@revealui/contracts/*": ["./packages/contracts/src/*"]
    }
  },
  "include": ["revealui.config.ts"],
  "exclude": ["node_modules"]
}
