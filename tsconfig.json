{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext"],
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "resolvePackageJsonExports": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@revealui/scripts": ["scripts/lib/index.ts"],
      "@revealui/scripts/*": ["scripts/lib/*"],
      "@revealui/core": ["packages/core/src/index.ts"],
      "@revealui/core/*": ["packages/core/src/*"],
      "@revealui/db": ["packages/db/src/index.ts"],
      "@revealui/db/*": ["packages/db/src/*"],
      "@revealui/ai": ["packages/ai/src/index.ts"],
      "@revealui/ai/*": ["packages/ai/src/*"],
      "@revealui/auth": ["packages/auth/src/index.ts"],
      "@revealui/auth/*": ["packages/auth/src/*"]
    }
  },
  "include": ["scripts/**/*", "packages/**/*", "apps/**/*"],
  "exclude": ["node_modules", "dist"]
}
