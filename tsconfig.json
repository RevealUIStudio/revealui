{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "jsx": "react-jsx",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "moduleResolution": "Bundler",
    "module": "Preserve",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "revealui/*": ["./packages/revealui/dist/*", "./packages/revealui/src/*"],
      "revealui/config": [
        "./packages/revealui/dist/config/index.js",
        "./packages/revealui/src/config/index.ts"
      ],
      "revealui/plugins/*": [
        "./packages/revealui/dist/plugins/*",
        "./packages/revealui/src/plugins/*"
      ],
      "@revealui/types": [
        "./packages/revealui/dist/types/index.js",
        "./packages/revealui/src/types/index.ts"
      ]
    }
  },
  "include": ["revealui.config.ts"],
  "exclude": ["node_modules"]
}
