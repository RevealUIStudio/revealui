{
  "RevealUI Development Task": {
    "prefix": "devtask",
    "body": [
      "## 🎯 ${1:Task Type}: ${2:Brief Description}",
      "",
      "**Files:** ${3:file paths}",
      "**Context:** ${4:What's happening, why this matters}",
      "",
      "**Requirements:**",
      "- [ ] ${5:Core requirement 1}",
      "- [ ] ${6:Core requirement 2}",
      "- [ ] ${7:Core requirement 3}",
      "",
      "**Constraints:**",
      "- ESM only (no CommonJS)",
      "- Named exports preferred",
      "- No GraphQL (REST + RPC only)",
      "- TypeScript strict mode",
      "${8:- Additional constraints}",
      "",
      "**Success:**",
      "- [ ] ${9:Measurable outcome 1}",
      "- [ ] ${10:Measurable outcome 2}",
      "",
      "**Next:** ${11:Immediate action or phase}",
      "",
      "**Notes:** ${12:Gotchas, risks, or reminders}"
    ],
    "description": "Simple RevealUI development task template"
  },

  "RevealUI Testing Task": {
    "prefix": "testtask",
    "body": [
      "## 🧪 Test: ${1:What to test}",
      "",
      "**Files:** ${2:test files and source}",
      "**Coverage Goal:** ${3:80-95%}",
      "",
      "**Test Cases:**",
      "- [ ] ${4:Happy path}",
      "- [ ] ${5:Error cases}",
      "- [ ] ${6:Edge cases}",
      "",
      "**Framework:** ${7:Vitest + RTL + Playwright}",
      "**Success:** All tests pass + coverage met",
      "",
      "**Next:** ${8:Run tests / Add more cases}"
    ],
    "description": "Simple testing task template"
  },

  "RevealUI Bug Fix": {
    "prefix": "bugfix",
    "body": [
      "## 🐛 Bug: ${1:Brief description}",
      "",
      "**Reproduce:** ${2:Steps to reproduce}",
      "**Expected:** ${3:What should happen}",
      "**Actual:** ${4:What's happening}",
      "",
      "**Root Cause:** ${5:Suspected issue}",
      "**Files:** ${6:Files to modify}",
      "",
      "**Fix:**",
      "- [ ] ${7:Solution approach}",
      "- [ ] ${8:Implement fix}",
      "- [ ] ${9:Add test case}",
      "",
      "**Verify:** ${10:How to confirm it's fixed}"
    ],
    "description": "Simple bug fix template"
  }
}