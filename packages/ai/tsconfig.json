{
  "extends": "../dev/src/ts/react-library.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    // TODO: Enable strict mode - currently disabled due to complex AI/vector memory types
    // See docs/technical-debt/TYPESCRIPT-STRICT-MODE.md for migration plan
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["src/**/*", "src/.scripts/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/observability/**/*",
    "src/orchestration/**/*",
    "src/client/**/*",
    "src/memory/vector/**/*"
  ]
}
