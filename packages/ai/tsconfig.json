{
  "extends": "../dev/src/ts/react-library.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true
  },
  "include": ["src/**/*", "src/.scripts/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/observability/**/*",
    "src/orchestration/**/*",
    "src/client/**/*",
    "src/memory/vector/**/*"
  ]
}
