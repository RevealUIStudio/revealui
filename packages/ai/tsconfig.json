{
  "extends": "../dev/src/ts/react-library.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*", "src/.scripts/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
