{
	"name": "@revealui/ai",
	"version": "0.1.0",
	"description": "AI primitives and utilities for RevealUI",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./primitives": {
			"types": "./dist/primitives/index.d.ts",
			"import": "./dist/primitives/index.js"
		},
		"./hooks": {
			"types": "./dist/hooks/index.d.ts",
			"import": "./dist/hooks/index.js"
		},
		"./utils": {
			"types": "./dist/utils/index.d.ts",
			"import": "./dist/utils/index.js"
		},
		"./mcp": {
			"types": "./dist/mcp/index.d.ts",
			"import": "./dist/mcp/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "eslint src/**/*.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/openai": "^1.0.0",
		"@modelcontextprotocol/sdk": "^0.5.0",
		"ai": "^4.0.0",
		"openai": "^4.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"eslint": "^9.39.2",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	}
}
