{
  "name": "@revealui/ai",
  "version": "0.1.0",
  "description": "AI system for RevealUI - memory, LLM, orchestration, and tools",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./memory": {
      "import": "./dist/memory/index.js",
      "types": "./dist/memory/index.d.ts"
    },
    "./memory/memory": {
      "import": "./dist/memory/memory/index.js",
      "types": "./dist/memory/memory/index.d.ts"
    },
    "./memory/vector": {
      "import": "./dist/memory/vector/index.js",
      "types": "./dist/memory/vector/index.d.ts"
    },
    "./memory/persistence": {
      "import": "./dist/memory/persistence/index.js",
      "types": "./dist/memory/persistence/index.d.ts"
    },
    "./embeddings": {
      "import": "./dist/embeddings/index.js",
      "types": "./dist/embeddings/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./skills": {
      "import": "./dist/skills/index.js",
      "types": "./dist/skills/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "uuid": "^13.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "dev": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.1",
    "react": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "llm",
    "memory",
    "crdt",
    "vector-search",
    "agent",
    "orchestration",
    "tools",
    "skills",
    "revealui",
    "real-time",
    "offline-first"
  ],
  "license": "MIT"
}
