{
  "name": "@revealui/sync",
  "version": "0.1.0",
  "description": "Sync client for RevealUI - enables cross-tab/session agent memory sharing",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./provider": {
      "types": "./dist/provider/index.d.ts",
      "import": "./dist/provider/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:real-api": "vitest run real-api"
  },
  "dependencies": {
    "@electric-sql/client": "^1.4.0",
    "@electric-sql/react": "^1.0.26",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "dev": "workspace:*",
    "eslint": "^9.39.2",
    "jsdom": "^27.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "revealui",
    "electric-sql",
    "real-time",
    "sync",
    "agent-memory"
  ],
  "license": "MIT"
}
