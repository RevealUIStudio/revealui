{
  "name": "@revealui/sync",
  "version": "1.0.0",
  "description": "ElectricSQL client for real-time sync and local-first storage",
  "main": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./provider": "./src/provider/index.tsx",
    "./hooks": "./src/hooks/index.ts",
    "./shapes": "./src/shapes.ts",
    "./operations": "./src/operations.ts",
    "./client": "./src/client/index.ts"
  },
  "files": [
    "./src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/client": "^1.4.0",
    "@electric-sql/react": "^1.0.27",
    "zod": "^3.22.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "biome": "^0.3.3",
    "@revealui/db": "workspace:*",
    "@revealui/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@revealui/db": "*",
    "@revealui/core": "*"
  }
}
