{
  "name": "@revealui/sync",
  "version": "0.3.5",
  "description": "ElectricSQL sync utilities for RevealUI",
  "license": "MIT",
  "dependencies": {
    "@electric-sql/react": "^1.0.43",
    "@revealui/contracts": "workspace:*",
    "@revealui/db": "workspace:*",
    "lib0": "^0.2.117",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^4.1.0",
    "dev": "workspace:*",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "experimental": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/provider/index.d.ts",
      "import": "./dist/provider/index.js"
    },
    "./collab": {
      "types": "./dist/collab/index.d.ts",
      "import": "./dist/collab/index.js"
    },
    "./collab/server": {
      "types": "./dist/collab/server-index.d.ts",
      "import": "./dist/collab/server-index.js"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
