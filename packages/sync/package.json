{
  "name": "@revealui/sync",
  "version": "1.0.0",
  "description": "ElectricSQL client for real-time sync and local-first storage",
  "main": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./provider": "./src/provider/index.tsx",
    "./hooks": "./src/hooks/index.ts",
    "./shapes": "./src/shapes.ts",
    "./operations": "./src/operations.ts",
    "./client": "./src/client/index.ts"
  },
  "files": [
    "./src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/migration/migrate.ts"
  },
  "dependencies": {
    "@revealui/db": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "electric-sql": "^0.9.0",
    "@electric-sql/react": "^0.9.0",
    "@electric-sql/pglite": "^0.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@revealui/core": "workspace:*",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "biome": "^0.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "@revealui/core": "*",
    "@revealui/db": "*",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
