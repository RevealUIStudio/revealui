{
  "name": "@revealui/sync",
  "version": "0.1.0",
  "description": "ElectricSQL sync utilities for RevealUI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint:eslint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/react": "^1.0.30",
    "@revealui/db": "workspace:*",
    "@revealui/contracts": "workspace:*"
  },
  "devDependencies": {
    "dev": "workspace:*",
    "typescript": "^5.9.3"
  }
}
