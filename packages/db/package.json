{
  "name": "@revealui/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./core/agents": {
      "types": "./dist/core/agents.d.ts",
      "import": "./dist/core/agents.js"
    },
    "./core/cms": {
      "types": "./dist/core/cms.d.ts",
      "import": "./dist/core/cms.js"
    },
    "./core/crdt-operations": {
      "types": "./dist/core/crdt-operations.d.ts",
      "import": "./dist/core/crdt-operations.js"
    },
    "./core/node-ids": {
      "types": "./dist/core/node-ids.d.ts",
      "import": "./dist/core/node-ids.js"
    },
    "./core/pages": {
      "types": "./dist/core/pages.d.ts",
      "import": "./dist/core/pages.js"
    },
    "./core/rate-limits": {
      "types": "./dist/core/rate-limits.d.ts",
      "import": "./dist/core/rate-limits.js"
    },
    "./core/sites": {
      "types": "./dist/core/sites.d.ts",
      "import": "./dist/core/sites.js"
    },
    "./core/users": {
      "types": "./dist/core/users.d.ts",
      "import": "./dist/core/users.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "generate:types": "tsx src/types/generate.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@revealui/config": "workspace:*",
    "@revealui/schema": "workspace:*",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
