{
  "name": "@revealui/core",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./types": {
      "types": "./dist/core/types/index.d.ts",
      "import": "./dist/core/types/index.js"
    },
    "./config": {
      "types": "./dist/core/config/index.d.ts",
      "import": "./dist/core/config/index.js"
    },
    "./database": {
      "types": "./dist/core/database/index.d.ts",
      "import": "./dist/core/database/index.js"
    },
    "./storage": {
      "types": "./dist/core/storage/index.d.ts",
      "import": "./dist/core/storage/index.js"
    },
    "./auth": {
      "types": "./dist/core/auth/index.d.ts",
      "import": "./dist/core/auth/index.js"
    },
    "./admin": {
      "types": "./dist/client/admin/index.d.ts",
      "import": "./dist/client/admin/index.js"
    },
    "./admin/utils/serializeConfig": {
      "types": "./dist/client/admin/utils/serializeConfig.d.ts",
      "import": "./dist/client/admin/utils/serializeConfig.js"
    },
    "./richtext": {
      "types": "./dist/core/richtext/index.d.ts",
      "import": "./dist/core/richtext/index.js"
    },
    "./richtext-lexical": {
      "types": "./dist/core/richtext-lexical/index.d.ts",
      "import": "./dist/core/richtext-lexical/index.js"
    },
    "./richtext-lexical/client": {
      "types": "./dist/client/richtext-lexical/index.d.ts",
      "import": "./dist/client/richtext-lexical/index.js"
    },
    "./richtext-lexical/react": {
      "types": "./dist/core/richtext-lexical/exports/react/index.d.ts",
      "import": "./dist/core/richtext-lexical/exports/react/index.js"
    },
    "./richtext-lexical/html": {
      "types": "./dist/core/richtext-lexical/exports/html/index.d.ts",
      "import": "./dist/core/richtext-lexical/exports/html/index.js"
    },
    "./richtext-lexical/rsc": {
      "types": "./dist/core/richtext-lexical/exports/server/rsc.d.tsx",
      "import": "./dist/core/richtext-lexical/exports/server/rsc.js"
    },
    "./translations": {
      "types": "./dist/core/translations/index.d.ts",
      "import": "./dist/core/translations/index.js"
