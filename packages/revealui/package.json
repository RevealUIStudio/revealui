      "types": "./dist/client/ui/index.d.tsx",
      "import": "./dist/client/ui/index.js"
    },
    "./plugins": {
      "types": "./dist/core/plugins/index.d.ts",
      "import": "./dist/core/plugins/index.js"
    },
    "./api/rest": {
      "types": "./dist/core/api/rest.d.ts",
      "import": "./dist/core/api/rest.js"
    },
    "./http": {
      "types": "./dist/client/http/index.d.ts",
      "import": "./dist/client/http/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./types/interfaces/app": {
      "types": "./dist/types/interfaces/app.d.ts",
      "import": "./dist/types/interfaces/app.js"
    },
    "./nextjs": {
      "types": "./dist/core/nextjs/index.d.ts",
      "import": "./dist/core/nextjs/index.js"
    },
    "./nextjs/withRevealUI": {
      "types": "./dist/core/nextjs/withRevealUI.d.ts",
      "import": "./dist/core/nextjs/withRevealUI.js"
    }
  },
  "dependencies": {
    "@lexical/clipboard": "^0.39.0",
    "@lexical/code": "^0.39.0",
    "@lexical/link": "^0.39.0",
    "@lexical/list": "^0.39.0",
    "@lexical/react": "^0.39.0",
    "@lexical/rich-text": "^0.39.0",
    "@lexical/selection": "^0.39.0",
    "@lexical/table": "^0.39.0",
    "@lexical/utils": "^0.39.0",
    "@revealui/schema": "workspace:*",
    "@vercel/blob": "^2.0.0",
    "@vercel/postgres": "^0.10.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "dataloader": "^2.2.3",
    "deepmerge": "^4.3.1",
    "jsonwebtoken": "^9.0.3",
    "lexical": "^0.39.0",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "sharp": "^0.34.5",
    "to-snake-case": "^1.0.0",
    "zod": "^4.3.5"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/json-schema": "^7.0.15",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "@types/to-snake-case": "^1.0.2",
    "@vitest/coverage-v8": "^4.0.16",
    "tsup": "^8.5.1",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
