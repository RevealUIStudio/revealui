{
  "name": "services",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./client": "./src/client/index.ts"
  },
  "files": [
    "./src/**/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:supabase-types": "pnpm dlx supabase gen types --lang=typescript --project-id leltxmcqbyyvksjcykrq --schema public > src/core/supabase/types.ts",
    "lint": "eslint . --cache --fix",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@revealui/config": "workspace:*",
    "@revealui/core": "workspace:*",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "@vercel/node": "^5.5.16",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.1.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "postcss": "^8.5.6",
    "supabase": "^2.70.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
