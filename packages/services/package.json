{
  "name": "@revealui/services",
  "version": "0.3.4",
  "description": "External service integrations for RevealUI — Stripe, Supabase, and Vercel",
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/services"
  },
  "license": "MIT",
  "dependencies": {
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@solana/kit": "^6.7.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@vercel/node": "^5.7.2",
    "drizzle-orm": "catalog:",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@revealui/dev": "workspace:*",
    "dotenv": "catalog:",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./stripe/payment-intent": {
      "types": "./dist/stripe/payment-intent.d.ts",
      "import": "./dist/stripe/payment-intent.js"
    },
    "./revealcoin": {
      "types": "./dist/revealcoin/index.d.ts",
      "import": "./dist/revealcoin/index.js"
    },
    "./stripe/stripeClient": {
      "types": "./dist/stripe/stripeClient.d.ts",
      "import": "./dist/stripe/stripeClient.js"
    }
  },
  "files": [
    "dist"
  ],
  "funding": {
    "type": "commercial",
    "url": "https://revealui.com/pro"
  },
  "main": "./dist/index.js",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
