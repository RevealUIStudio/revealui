    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.2.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.9",
    "dev": "workspace:*",
    "dotenv": "^17.2.3",
    "postcss": "^8.5.6",
    "supabase": "^2.72.8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
