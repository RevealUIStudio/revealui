{
  "name": "services",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:supabase-types": "tsx ../../scripts/generate/supabase-types.ts",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@revealui/config": "workspace:*",
    "@revealui/core": "workspace:*",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@vercel/node": "^5.5.23",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.2.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.9",
    "@vitest/coverage-v8": "^4.0.18",
    "dev": "workspace:*",
    "dotenv": "^17.2.3",
    "postcss": "^8.5.6",
    "supabase": "^2.72.8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
