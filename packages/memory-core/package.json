{
  "name": "@revealui/memory-core",
  "version": "0.1.0",
  "description": "CRDT-based memory system for RevealUI",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
