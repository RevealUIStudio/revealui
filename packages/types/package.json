{
  "name": "@revealui/types",
  "version": "0.1.0",
  "description": "Unified type exports for RevealUI framework",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core.ts",
      "import": "./src/core.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    },
    "./generated": {
      "types": "./src/generated.ts",
      "import": "./src/generated.ts"
    },
    "./cms": {
      "types": "./src/cms.ts",
      "import": "./src/cms.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ."
  },
  "dependencies": {
    "@revealui/core": "workspace:*",
    "@revealui/schema": "workspace:*",
    "@revealui/generated": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "revealui",
    "types",
    "typescript"
  ],
  "license": "MIT"
}
