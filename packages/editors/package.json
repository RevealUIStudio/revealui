{
  "name": "@revealui/editors",
  "version": "0.1.4",
  "description": "Editor integration for RevealUI — config sync and extension recommendations for VS Code, Zed, and Antigravity",
  "keywords": [
    "antigravity",
    "editor",
    "revealui",
    "vscode",
    "zed"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/editors"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dev": "workspace:*",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "funding": {
    "type": "individual",
    "url": "https://revealui.com"
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
