{
  "name": "@revealui/cli",
  "version": "0.2.0",
  "description": "Create RevealUI projects with a single command",
  "keywords": [
    "cli",
    "cms",
    "create",
    "revealui",
    "scaffolding"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "RevealUI Team",
  "bin": {
    "create-revealui": "./bin/create-revealui.js"
  },
  "dependencies": {
    "@revealui/config": "workspace:*",
    "@revealui/setup": "workspace:*",
    "commander": "^13.0.0",
    "execa": "^9.0.0",
    "inquirer": "^12.0.0",
    "jose": "^6.1.3",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^25.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
