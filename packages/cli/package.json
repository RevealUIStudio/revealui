{
  "name": "@revealui/cli",
  "version": "0.6.1",
  "description": "Create RevealUI projects with a single command",
  "keywords": [
    "cli",
    "cms",
    "create",
    "revealui",
    "scaffolding"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "RevealUI Team",
  "bin": {
    "create-revealui": "./bin/create-revealui.js",
    "revealui": "./bin/revealui.js"
  },
  "dependencies": {
    "@revealui/config": "workspace:*",
    "@revealui/setup": "workspace:*",
    "commander": "^14.0.3",
    "execa": "^9.0.0",
    "@clack/prompts": "^0.10.0",
    "jose": "^6.1.3",
    "ora": "^9.3.0"
  },
  "peerDependencies": {
    "@revealui/ai": "^0.2.5"
  },
  "peerDependenciesMeta": {
    "@revealui/ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
