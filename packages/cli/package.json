{
  "name": "@revealui/cli",
  "version": "0.7.0",
  "description": "Create RevealUI projects with a single command",
  "keywords": [
    "cli",
    "admin",
    "create",
    "revealui",
    "scaffolding"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "RevealUI Team",
  "bin": {
    "create-revealui": "./bin/create-revealui.js",
    "revealui": "./bin/revealui.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@revealui/config": "workspace:*",
    "@revealui/setup": "workspace:*",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "jose": "^6.2.3",
    "ora": "^9.4.0",
    "semver": "^7.7.4",
    "tinyglobby": "^0.2.16"
  },
  "optionalDependencies": {
    "@revealui/ai": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/semver": "^7.7.1",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "homepage": "https://revealui.com",
  "bugs": {
    "url": "https://github.com/RevealUIStudio/revealui/issues"
  }
}
