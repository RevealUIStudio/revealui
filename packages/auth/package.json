{
  "name": "@revealui/auth",
  "version": "0.3.8",
  "description": "Authentication system for RevealUI - database-backed sessions with Better Auth patterns",
  "keywords": [
    "auth",
    "authentication",
    "revealui",
    "sessions"
  ],
  "license": "MIT",
  "dependencies": {
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/security": "workspace:*",
    "@simplewebauthn/server": "^13.3.0",
    "bcryptjs": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@revealui/dev": "workspace:*",
    "happy-dom": "^20.9.0",
    "react": "^19.2.5",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "peerDependencies": {
    "@simplewebauthn/browser": "^13.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@simplewebauthn/browser": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/auth"
  },
  "homepage": "https://revealui.com",
  "author": "RevealUI Studio <founder@revealui.com>",
  "bugs": {
    "url": "https://github.com/RevealUIStudio/revealui/issues"
  }
}
