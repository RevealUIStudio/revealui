{
  "name": "@revealui/auth",
  "version": "0.2.1",
  "description": "Authentication system for RevealUI - database-backed sessions with Better Auth patterns",
  "keywords": [
    "auth",
    "authentication",
    "revealui",
    "sessions"
  ],
  "license": "MIT",
  "dependencies": {
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "dev": "workspace:*",
    "react": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
