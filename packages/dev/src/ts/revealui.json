{
  "extends": "./base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["node", "vite/client"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "revealui": ["./../../core/src/revealui.ts"],
      "revealui/*": ["./../../core/src/index.ts"],
      "@revealui/*": ["./../../core/src/*"],
      "@revealui/ui/*": ["./../../core/src/ui/*"],
      "@revealui/config": ["./../../core/src/config/index.ts"],
      "@revealui/types": ["./../../core/src/types/*"],
      "@revealui/db": ["./../../db/src/*"],
      "@revealui/db/*": ["./../../db/src/*"],
      "@revealui/auth": ["./../../auth/src/*"],
      "@revealui/auth/*": ["./../../auth/src/*"],
      "@revealui/sync": ["./../../sync/src/*"],
      "@revealui/sync/*": ["./../../sync/src/*"],
      "@revealui/contracts": ["./../../contracts/src/*"],
      "@revealui/contracts/*": ["./../../contracts/src/*"],
      "@revealui/generated": ["./../../core/src/generated/*"],
      "@revealui/generated/*": ["./../../core/src/generated/*"],
      "@revealui/utils": ["./../../core/src/utils/*"],
      "@revealui/utils/*": ["./../../core/src/utils/*"],
      "@revealui/hooks": ["./../../core/src/hooks/*"],
      "@revealui/hooks/*": ["./../../core/src/hooks/*"]
    },
    "sourceMap": true
  },
  "include": [],
  "exclude": ["node_modules", "dist"]
}
