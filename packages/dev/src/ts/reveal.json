{
  "extends": "./base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["vite/client"],
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "revealui/*": ["../../revealui/src/*"],
      "revealui/core/*": ["../../revealui/src/core/*"],
      "revealui/ui/*": ["../../revealui/src/ui/*"],
      "revealui/config": ["../../revealui/src/+config.ts"],
      "revealui/types": ["../../revealui/src/types/*"]
    },
    "sourceMap": true
  },
  "include": ["../../revealui/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
