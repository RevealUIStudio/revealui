{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./src/ts/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "target": "es2022"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
