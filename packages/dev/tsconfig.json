{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./src/ts/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
