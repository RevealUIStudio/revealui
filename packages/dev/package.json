{
  "name": "dev",
  "version": "0.0.1",
  "description": "Shared development configs (Biome, TypeScript, Tailwind) for RevealUI",
  "private": true,
  "license": "MIT",
  "dependencies": {
    "minimatch": "^10.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "globals": "^17.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.2",
    "vite": "catalog:",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite/vite.shared.ts",
    "./tailwind": "./src/tailwind/tailwind.config.ts",
    "./tailwind/create-config": "./src/tailwind/create-config.ts",
    "./postcss": "./src/postcss/postcss.config.ts",
    "./biome": "./src/biome/biome.config.ts",
    "./code-validator": "./src/code-validator/index.ts",
    "./ts/base": "./src/ts/base.json",
    "./ts/library": "./src/ts/library.json",
    "./ts/revealui": "./src/ts/revealui.json",
    "./ts/vite": "./src/ts/vite.json",
    "./ts/nextjs": "./src/ts/nextjs.json",
    "./ts/react-library": "./src/ts/react-library.json"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:integration": "vitest run src/__tests__/integration",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:imports": "tsx ../../scripts/validation/verify-dev-package-imports.ts"
  },
  "type": "module"
}
