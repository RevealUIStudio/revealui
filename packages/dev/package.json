{
  "name": "@revealui/dev",
  "version": "0.1.0",
  "description": "Zero-config dev environment for RevealUI — Biome, TypeScript, Tailwind, Vite, PostCSS, editor integration, and terminal themes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/dev"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "biome",
    "dev-environment",
    "editor-config",
    "revealui",
    "tailwind",
    "typescript",
    "vite"
  ],
  "dependencies": {
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "globals": "catalog:",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite/vite.shared.ts",
    "./tailwind": "./src/tailwind/tailwind.config.ts",
    "./tailwind/create-config": "./src/tailwind/create-config.ts",
    "./postcss": "./src/postcss/postcss.config.ts",
    "./biome": "./src/biome/biome.config.ts",
    "./code-validator": "./src/code-validator/index.ts",
    "./ts/base": "./src/ts/base.json",
    "./ts/library": "./src/ts/library.json",
    "./ts/revealui": "./src/ts/revealui.json",
    "./ts/vite": "./src/ts/vite.json",
    "./ts/nextjs": "./src/ts/nextjs.json",
    "./ts/react-library": "./src/ts/react-library.json",
    "./editors": "./src/editors/index.ts"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:integration": "vitest run src/__tests__/integration",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:imports": "tsx ../../scripts/validation/verify-dev-package-imports.ts"
  },
  "type": "module",
  "homepage": "https://revealui.com",
  "author": "RevealUI Studio <founder@revealui.com>",
  "bugs": {
    "url": "https://github.com/RevealUIStudio/revealui/issues"
  }
}
