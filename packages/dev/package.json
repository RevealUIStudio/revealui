{
  "name": "dev",
  "version": "0.0.1",
  "private": true,
  "files": [
    "./src/**/*"
  ],
  "type": "module",
  "scripts": {
    "tailwind:dev": "npx @tailwindcss/cli -i ./src/tailwind/styles.css -o ./dist/styles.css --watch",
    "tailwind:build": "npx @tailwindcss/cli -i ./src/tailwind/styles.css -o ./dist/styles.css --minify",
    "ts:dev": "tsx",
    "ts:build": "tsc",
    "dev": "tsx && npx @tailwindcss/cli -i ./src/tailwind/styles.css -o ./dist/styles.css --watch",
    "build": "tsc && npx @tailwindcss/cli -i ./src/tailwind/styles.css -o ./dist/styles.css --minify",
    "format": "prettier --write '**/*.{cjs,mjs,js,jsx,ts,tsx,css,scss,md,json}'",
    "lint": "eslint"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.0.4",
    "@typescript-eslint/eslint-plugin": "8.48.0",
    "@typescript-eslint/parser": "8.48.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "2.6.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-tailwindcss": "3.18.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  }
}
