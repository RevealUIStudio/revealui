{
  "name": "@revealui/editor-daemon",
  "version": "0.1.0",
  "description": "Editor host service - JSON-RPC server with editor adapter registry",
  "license": "MIT",
  "type": "module",
  "bin": {
    "revealui-editor-daemon": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@revealui/editor-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "dev": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
