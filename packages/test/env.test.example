# Test Environment Variables Example
#
# Copy this file to .env.test and fill in your actual values.
# DO NOT commit .env.test to version control!
#
# Usage:
#   cp env.test.example .env.test
#   # Edit .env.test with your actual values
#   source .env.test  # or use dotenv/load in your test scripts

# =============================================================================
# Database Connections
# =============================================================================

# Supabase (Vector Database) Connection String
# Used for vector search operations and agent_memories table
# Format: postgresql://user:password@host:port/database
# Get this from: Supabase Dashboard > Settings > Database > Connection String
# Use transaction pooling port (6543) for better performance
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:6543/postgres

# NeonDB (REST Database) Connection String
# Used for transactional REST API operations
# Format: postgresql://user:password@host:port/database
# Get this from: Neon Dashboard > Connection Details
POSTGRES_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb

# =============================================================================
# OpenAI API (for Embeddings)
# =============================================================================

# OpenAI API Key for generating embeddings
# Required for: generateEmbedding() function in tests
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Optional: Test-Specific Configuration
# =============================================================================

# Test timeout (milliseconds)
# Default: 30000 (30 seconds)
# TEST_TIMEOUT=30000

# Test database cleanup
# Set to 'false' to keep test data after tests (for debugging)
# Default: 'true'
# CLEANUP_TEST_DATA=true

# =============================================================================
# Security Notes
# =============================================================================
#
# - Never commit .env.test with real credentials
# - Use staging/test databases, not production
# - Rotate API keys regularly
# - Use environment-specific connection strings
# - Consider using secrets management in CI/CD
#
# =============================================================================
# Getting Connection Strings
# =============================================================================
#
# Supabase:
#   1. Go to https://supabase.com/dashboard
#   2. Select your project
#   3. Settings > Database
#   4. Copy "Connection string" (use Transaction Pooling mode)
#
# NeonDB:
#   1. Go to https://console.neon.tech
#   2. Select your project
#   3. Connection Details
#   4. Copy connection string
#
# OpenAI:
#   1. Go to https://platform.openai.com/api-keys
#   2. Create new secret key
#   3. Copy the key (you won't see it again!)
