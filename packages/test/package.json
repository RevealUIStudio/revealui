{
  "name": "test",
  "version": "0.0.1",
  "description": "E2E specs, integration tests, fixtures, mocks, and test utilities for RevealUI",
  "private": true,
  "license": "MIT",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@revealui/auth": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/utils": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.12",
    "stripe": "^21.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@supabase/supabase-js": "^2.95.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "bcryptjs": "^3.0.3",
    "dev": "workspace:*",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "catalog:",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./integration/setup": {
      "types": "./dist/integration/setup.d.ts",
      "import": "./dist/integration/setup.js"
    },
    "./integration/test-database": {
      "types": "./dist/integration/test-database.d.ts",
      "import": "./dist/integration/test-database.js"
    }
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "test": "vitest",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:auth-e2e": "playwright test src/e2e/auth.spec.ts",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:coverage:unit": "vitest run --coverage src/units",
    "test:db:setup": "cd ../.. && pnpm exec tsx packages/test/scripts/setup-dual-database.ts",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts src/integration",
    "test:integration:pro": "vitest run --config vitest.integration-pro.config.ts",
    "test:integration:pro:watch": "vitest watch --config vitest.integration-pro.config.ts",
    "test:integration:watch": "vitest watch --config vitest.integration.config.ts src/integration",
    "test:memory:all": "pnpm test:integration:pro",
    "test:memory:dual": "vitest run --config vitest.integration.config.ts src/integration/memory/dual-database.integration.test.ts",
    "test:memory:episodic": "vitest run --config vitest.integration-pro.config.ts src/integration-pro/memory/episodic-memory.integration.test.ts",
    "test:memory:vector": "vitest run --config vitest.integration-pro.config.ts src/integration-pro/memory/vector-memory.integration.test.ts",
    "test:perf:analyze": "cd ../.. && pnpm exec tsx scripts/test/analyze-performance-baseline.ts",
    "test:perf:auth": "k6 run load-tests/auth/auth-sign-in.js && k6 run load-tests/auth/auth-sign-up.js && k6 run load-tests/auth/auth-rate-limiting.js",
    "test:perf:auth:ratelimit": "k6 run load-tests/auth/auth-rate-limiting.js",
    "test:perf:auth:session": "k6 run load-tests/auth/auth-session-validation.js",
    "test:perf:auth:signin": "k6 run load-tests/auth/auth-sign-in.js",
    "test:perf:auth:signup": "k6 run load-tests/auth/auth-sign-up.js",
    "test:perf:auth:stress": "k6 run load-tests/auth/auth-stress.js",
    "test:perf:dry-run": "cd ../.. && DRY_RUN=true pnpm exec tsx scripts/test/performance-baseline.ts",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run src/units",
    "test:unit:watch": "vitest watch src/units",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
