{
  "name": "test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest run src/units",
    "test:unit:watch": "vitest watch src/units",
    "test:integration": "vitest run --config vitest.integration.config.ts src/integration",
    "test:integration:watch": "vitest watch --config vitest.integration.config.ts src/integration",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:unit": "vitest run --coverage src/units",
    "test:e2e": "playwright test",
    "test:auth-e2e": "playwright test src/e2e/auth.spec.ts",
    "test:perf:auth": "k6 run src/performance/auth-sign-in.js && k6 run src/performance/auth-sign-up.js && k6 run src/performance/auth-rate-limiting.js",
    "test:perf:auth:signin": "k6 run src/performance/auth-sign-in.js",
    "test:perf:auth:signup": "k6 run src/performance/auth-sign-up.js",
    "test:perf:auth:session": "k6 run src/performance/auth-session-validation.js",
    "test:perf:auth:ratelimit": "k6 run src/performance/auth-rate-limiting.js",
    "test:perf:auth:stress": "k6 run src/performance/auth-stress.js",
    "test:load": "k6 run load-tests/auth-login.js",
    "test:load:auth": "k6 run load-tests/auth-login.js",
    "test:load:api": "k6 run load-tests/api-pages.js",
    "test:load:payment": "k6 run load-tests/payment-processing.js",
    "test:load:all": "k6 run load-tests/auth-login.js && k6 run load-tests/api-pages.js && k6 run load-tests/payment-processing.js",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:memory:setup": "cd ../.. && pnpm exec tsx packages/test/scripts/setup-vector-database.ts",
    "test:memory:verify": "cd ../.. && pnpm exec tsx packages/test/scripts/verify-test-setup.ts",
    "test:memory:vector": "cd ../.. && pnpm exec tsx packages/test/scripts/run-memory-tests.ts vector",
    "test:memory:dual": "cd ../.. && pnpm exec tsx packages/test/scripts/run-memory-tests.ts dual",
    "test:memory:episodic": "cd ../.. && pnpm exec tsx packages/test/scripts/run-memory-tests.ts episodic",
    "test:memory:all": "cd ../.. && pnpm exec tsx packages/test/scripts/run-memory-tests.ts all"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "jsdom": "^27.4.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@revealui/core": "workspace:*",
    "@revealui/db": "workspace:*",
    "@revealui/ai": "workspace:*",
    "@revealui/schema": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.1",
    "vite": "^7.3.0",
    "zod": "^3.24.1"
  }
}
