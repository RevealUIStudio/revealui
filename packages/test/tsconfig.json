{
  "extends": "../dev/src/ts/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "types": ["@playwright/test", "node"],
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": false
  },
  "include": ["./src/**/*", "src/.scripts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/units/validation/validation-utilities.test.ts",
    "src/units/validation/email-validation.test.ts",
    "src/units/validation/password-validation.test.ts",
    "src/units/fixtures/fixtures-validation.test.ts",
    "src/units/utils/query-builder.test.ts",
    "src/units/utils/stripUnselectedFields.test.ts",
    "src/units/utils/getSelectMode.test.ts",
    "src/units/utils/getBlockSelect.test.ts",
    "src/units/utils/mocks.test.ts",
    "src/units/utils/field-traversal.test.ts",
    "src/units/utils/flattenResult.test.ts",
    "src/units/utils/field-conversion.test.ts",
    "src/units/utils/access-conversion.test.ts",
    "src/units/utils/block-conversion.test.ts",
    "src/patterns/**/*.test.*",
    "src/units/utils/framework-utilities.test.ts",
    "src/mocks/**/*.ts",
    "src/integration/services/stripe.integration.test.ts",
    "src/integration/services/supabase.integration.test.ts",
    "src/integration/database/transactions.integration.test.ts",
    "src/integration/database/persistence.integration.test.ts",
    "src/integration/api/users.integration.test.ts",
    "src/integration/api/collections.integration.test.ts",
    "src/integration/api/email-validation.test.ts",
    "src/integration/api/api-cors.integration.test.ts",
    "src/integration/api/api-error-handler.integration.test.ts",
    "src/integration/memory/**/*.test.ts",
    "src/integration/memory/**/*.ts",
    "src/integration/test-database.ts",
    "src/integration-pro/**/*.ts",
    "src/utils/test-database.ts",
    "src/e2e/auth.spec.ts",
    "src/e2e/page-objects/RegisterPage.ts"
  ]
}
