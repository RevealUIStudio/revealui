{
  "extends": "../dev/src/ts/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "types": ["@playwright/test", "node"],
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": false,
    "jsx": "react-jsx",
    "paths": {
      "@cms/*": ["../../apps/cms/src/*"],
      "@api/*": ["../../apps/api/src/*"]
    }
  },
  "include": ["./src/**/*", "src/.scripts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/mocks/**/*.ts",
    "src/integration-pro/**/*.ts",
    "src/patterns/**/*.test.*",
    "src/integration/database/transactions.integration.test.ts",
    "src/integration/services/supabase.integration.test.ts",
    "src/integration/memory/**/*.ts",
    "src/integration/test-database.ts",
    "src/utils/test-database.ts",
  ]
}
