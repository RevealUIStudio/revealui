{
  "extends": "../dev/src/ts/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["@playwright/test", "node"],
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": false,
    "jsx": "react-jsx",
    "paths": {}
  },
  "include": ["./src/**/*", "src/.scripts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/mocks/**/*.ts",
    "src/integration/**/*.ts",
    "src/integration-pro/**/*.ts",
    "src/units/**/*.ts",
    "src/e2e/**/*.ts",
    "src/patterns/**/*.test.*"
  ]
}
