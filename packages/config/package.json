{
  "name": "@revealui/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./revealui": {
      "types": "./dist/revealui.config.d.ts",
      "import": "./dist/revealui.config.js"
    },
