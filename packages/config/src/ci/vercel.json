{
  "version": 2,
  "builds": [
    {
      "src": "apps/mainframe/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "apps/admin/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/apps/admin/admin/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/apps/admin/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/apps/mainframe/dist/assets/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/apps/mainframe/dist/:path*"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "images": {
    "sizes": [256, 640, 1080, 2048, 3840],
    "minimumCacheTTL": 60
  }
}
