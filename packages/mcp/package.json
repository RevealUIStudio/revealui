{
  "name": "@revealui/mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol integrations for RevealUI — adapter framework, hypervisor, and MCP contracts",
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/mcp"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@revealui/config": "workspace:*",
    "@revealui/contracts": "workspace:*",
    "@revealui/core": "workspace:*",
    "@revealui/security": "workspace:*",
    "dotenv": "catalog:",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "pg": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/servers/adapter.d.ts",
      "import": "./dist/servers/adapter.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./hypervisor": {
      "types": "./dist/hypervisor.d.ts",
      "import": "./dist/hypervisor.js"
    },
    "./db": {
      "types": "./dist/adapters/db.d.ts",
      "import": "./dist/adapters/db.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline.d.ts",
      "import": "./dist/pipeline.js"
    },
    "./rate-limiter": {
      "types": "./dist/rate-limiter.d.ts",
      "import": "./dist/rate-limiter.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry.d.ts",
      "import": "./dist/telemetry.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./streamable-http": {
      "types": "./dist/streamable-http.d.ts",
      "import": "./dist/streamable-http.js"
    }
  },
  "files": [
    "dist"
  ],
  "funding": {
    "type": "commercial",
    "url": "https://revealui.com/pro"
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "homepage": "https://revealui.com",
  "author": "RevealUI Studio <founder@revealui.com>",
  "bugs": {
    "url": "https://github.com/RevealUIStudio/revealui/issues"
  },
  "keywords": [
    "revealui",
    "mcp",
    "model-context-protocol",
    "ai",
    "tool-discovery",
    "servers"
  ]
}
