{
  "name": "@revealui/harnesses",
  "version": "0.1.0",
  "description": "AI harness integration system - adapters, daemon, workboard coordination, and JSON-RPC server",
  "license": "SEE LICENSE IN ../../LICENSE.commercial",
  "type": "module",
  "bin": {
    "revealui-harnesses": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./workboard": {
      "types": "./dist/workboard/index.d.ts",
      "import": "./dist/workboard/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@revealui/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "dev": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
