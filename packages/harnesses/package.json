{
  "name": "@revealui/harnesses",
  "version": "0.1.9",
  "description": "[Pro] AI harness integration system - adapters, daemon, workboard coordination, and JSON-RPC server",
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/harnesses"
  },
  "license": "FSL-1.1-MIT",
  "bin": {
    "revealui-harnesses": "./dist/cli.js"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@revealui/core": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@revealui/dev": "workspace:*",
    "@types/node": "^25.5.2",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./workboard": {
      "types": "./dist/workboard/index.d.ts",
      "import": "./dist/workboard/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./vaughn": {
      "types": "./dist/vaughn/index.d.ts",
      "import": "./dist/vaughn/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "funding": {
    "type": "commercial",
    "url": "https://revealui.com/pro"
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "start": "node dist/cli.js",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "homepage": "https://revealui.com",
  "author": "RevealUI Studio <founder@revealui.com>",
  "bugs": {
    "url": "https://github.com/RevealUIStudio/revealui/issues"
  },
  "keywords": [
    "revealui",
    "harness",
    "ai",
    "workboard",
    "json-rpc",
    "agent"
  ]
}
