{
  "name": "@revealui/cache",
  "version": "0.1.2",
  "description": "Caching infrastructure for RevealUI - CDN config, edge cache, ISR presets, revalidation",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "@types/node": "^25.5.0",
    "dev": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.1.7"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
