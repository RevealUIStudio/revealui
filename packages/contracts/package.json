{
  "name": "@revealui/contracts",
  "version": "1.1.0",
  "description": "Unified contracts package for RevealUI - schemas, validation, and type safety across the stack",
  "keywords": [
    "contracts",
    "revealui",
    "schema",
    "typescript",
    "validation",
    "zod"
  ],
  "license": "MIT",
  "dependencies": {
    "@revealui/db": "workspace:*",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "dev": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./foundation": {
      "types": "./dist/foundation/index.d.ts",
      "import": "./dist/foundation/index.js"
    },
    "./representation": {
      "types": "./dist/representation/index.d.ts",
      "import": "./dist/representation/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "import": "./dist/entities/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./cms": {
      "types": "./dist/cms/index.d.ts",
      "import": "./dist/cms/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "import": "./dist/database/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js"
    },
    "./core": {
      "types": "./dist/cms/index.d.ts",
      "import": "./dist/cms/index.js"
    },
    "./core/contracts": {
      "types": "./dist/cms/index.d.ts",
      "import": "./dist/cms/index.js"
    },
    "./blocks": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./generated": {
      "types": "./dist/generated/database.d.ts",
      "import": "./dist/generated/database.js"
    },
    "./generated/database": {
      "types": "./dist/generated/database.d.ts",
      "import": "./dist/generated/database.js"
    },
    "./generated/zod-schemas": {
      "types": "./dist/generated/zod-schemas.d.ts",
      "import": "./dist/generated/zod-schemas.js"
    },
    "./generated/contracts": {
      "types": "./dist/generated/contracts.d.ts",
      "import": "./dist/generated/contracts.js"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "@revealui/db": "workspace:*",
    "typescript": ">=5.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
