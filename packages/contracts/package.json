{
  "name": "@revealui/contracts",
  "version": "1.3.6",
  "description": "Unified contracts package for RevealUI - schemas, validation, and type safety across the stack",
  "keywords": [
    "contracts",
    "revealui",
    "schema",
    "typescript",
    "validation",
    "zod"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@revealui/db": "workspace:*",
    "@types/node": "catalog:",
    "@revealui/dev": "workspace:*",
    "drizzle-zod": "^0.8.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./foundation": {
      "types": "./dist/foundation/index.d.ts",
      "import": "./dist/foundation/index.js"
    },
    "./representation": {
      "types": "./dist/representation/index.d.ts",
      "import": "./dist/representation/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "import": "./dist/entities/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./cms": {
      "types": "./dist/cms/index.d.ts",
      "import": "./dist/cms/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "import": "./dist/database/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js"
    },
    "./core": {
      "types": "./dist/cms/index.d.ts",
      "import": "./dist/cms/index.js"
    },
    "./core/contracts": {
      "types": "./dist/cms/index.d.ts",
      "import": "./dist/cms/index.js"
    },
    "./blocks": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts",
      "import": "./dist/pricing.js"
    },
    "./generated": {
      "types": "./dist/generated/database.d.ts",
      "import": "./dist/generated/database.js"
    },
    "./generated/database": {
      "types": "./dist/generated/database.d.ts",
      "import": "./dist/generated/database.js"
    },
    "./generated/zod-schemas": {
      "types": "./dist/generated/zod-schemas.d.ts",
      "import": "./dist/generated/zod-schemas.js"
    },
    "./generated/contracts": {
      "types": "./dist/generated/contracts.d.ts",
      "import": "./dist/generated/contracts.js"
    },
    "./content-validation": {
      "types": "./dist/content-validation.d.ts",
      "import": "./dist/content-validation.js"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "peerDependencies": {
    "@revealui/db": "workspace:^",
    "drizzle-zod": "^0.8.3",
    "typescript": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@revealui/db": {
      "optional": true
    },
    "drizzle-zod": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=text",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/RevealUIStudio/revealui.git",
    "directory": "packages/contracts"
  }
}
