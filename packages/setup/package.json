{
  "name": "@revealui/setup",
  "version": "0.1.0",
  "description": "Setup utilities for RevealUI projects - environment, database, and configuration management",
  "keywords": [
    "cli",
    "configuration",
    "database",
    "environment",
    "revealui",
    "setup"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/RevealUI.git",
    "directory": "packages/setup"
  },
  "license": "MIT",
  "author": "RevealUI Team",
  "dependencies": {
    "@revealui/config": "workspace:*",
    "chalk": "^5.6.2",
    "execa": "^9.0.0",
    "inquirer": "^12.0.0",
    "ora": "^8.0.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^25.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./environment": {
      "types": "./dist/environment/index.d.ts",
      "import": "./dist/environment/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
