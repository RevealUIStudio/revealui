{
  "api": {
    "packages": [
      {
        "name": "@revealui/core",
        "path": "packages/revealui/src"
      },
      {
        "name": "@revealui/contracts",
        "path": "packages/contracts/src"
      },
      {
        "name": "@revealui/db",
        "path": "packages/db/src"
      }
    ],
    "outputDir": "docs/api"
  },
  "website": {
    "appPath": "apps/docs",
    "contentDir": "docs/content"
  },
  "validation": {
    "jsdoc": {
      "required": true,
      "minCoverage": 80
    },
    "links": {
      "checkExternal": false,
      "timeout": 5000
    }
  },
  "generation": {
    "autoUpdate": true,
    "watchMode": false
  }
}
