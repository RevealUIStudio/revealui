{
  // Editor Basics
  "tab_size": 2,
  "hard_tabs": false,
  "preferred_line_length": 100,
  "soft_wrap": "preferred_line_length",
  "format_on_save": "on",
  "formatter": "auto",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,

  // LSP Configuration
  "enable_language_server": true,
  "show_completions_on_input": true,
  "show_completion_documentation": true,

  // Inlay Hints (useful for TypeScript)
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },

  // Git Integration
  "git": {
    "enabled": true,
    "autoFetch": true,
    "autoFetchInterval": 300,
    "inline_blame": {
      "enabled": false
    }
  },
  "terminal": {
    "shell": {
      "program": "bash"
    },
    "working_directory": "current_project_directory",
    "detect_venv": {
      "on": {
        "activate_script": "default"
      }
    }
  },

  // Project-specific settings
  "project": {
    "search": {
      "excluded_directories": [
        "node_modules",
        ".next",
        ".turbo",
        "dist",
        ".husky",
        "coverage",
        ".size-limit"
      ]
    }
  },

  // Language-Specific Settings
  "languages": {
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true
      },
      "hard_tabs": false,
      "preferred_line_length": 100,
      "language_servers": ["vtsls", "!typescript-language-server"],
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_type_hints": true,
        "show_other_hints": true
      }
    },
    "TSX": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true
      },
      "hard_tabs": false,
      "preferred_line_length": 100,
      "language_servers": ["vtsls", "!typescript-language-server"],
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_type_hints": true
      }
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true
      },
      "hard_tabs": false,
      "preferred_line_length": 100,
      "language_servers": ["vtsls"]
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    },
    "Markdown": {
      "tab_size": 2,
      "format_on_save": "on",
      "preferred_line_length": 80,
      "soft_wrap": "preferred_line_length"
    },
    "YAML": {
      "tab_size": 2,
      "hard_tabs": false
    }
  },

  // TypeScript Language Server Configuration
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "suggest": {
            "autoImports": true,
            "completeFunctionCalls": true
          },
          "preferences": {
            "importModuleSpecifier": "relative",
            "useAliasesForRenames": false
          },
          "updateImportsOnFileMove": {
            "enabled": "always"
          },
          "tsserver": {
            "maxTsServerMemory": 8192,
            "log": "off"
          },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all"
            },
            "parameterTypes": {
              "enabled": true
            },
            "variableTypes": {
              "enabled": true
            },
            "propertyDeclarationTypes": {
              "enabled": true
            },
            "functionLikeReturnTypes": {
              "enabled": true
            },
            "enumMemberValues": {
              "enabled": true
            }
          }
        },
        "javascript": {
          "suggest": {
            "autoImports": true,
            "completeFunctionCalls": true
          },
          "preferences": {
            "importModuleSpecifier": "relative"
          },
          "updateImportsOnFileMove": {
            "enabled": "always"
          },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all"
            },
            "parameterTypes": {
              "enabled": true
            },
            "variableTypes": {
              "enabled": true
            },
            "propertyDeclarationTypes": {
              "enabled": true
            },
            "functionLikeReturnTypes": {
              "enabled": true
            },
            "enumMemberValues": {
              "enabled": true
            }
          }
        }
      }
    }
  },

  // File Type Associations
  "file_types": {
    "JSON": ["**/.size-limit.json"],
    "JSONC": ["**/.zed/*.json", "**/tsconfig*.json", "**/.vscode/*.json"],
    "TypeScript": ["**/*.mts"],
    "Markdown": ["**/*.md", "**/*.mdx"]
  },

  // UI Settings
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "ui_font_size": 14,
  "buffer_font_size": 13,
  "buffer_font_family": "Fira Code",
  "buffer_font_features": {
    "calt": true,
    "liga": true
  },

  // Editor Features
  "show_whitespaces": "selection",
  "show_indent_guides": true,
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 2,
    "coloring": "indent_aware"
  },
  "relative_line_numbers": false,
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_symbol": true,
    "diagnostics": true
  },
  "gutter": {
    "line_numbers": true,
    "code_actions": true,
    "folds": true
  },

  // Collaboration (if using Zed's collaboration features)
  "collaboration_panel": {
    "button": true
  },

  // File Finder
  "file_finder": {
    "file_icons": true
  },

  // Diagnostics
  "diagnostics": {
    "include_warnings": true
  },

  // Tasks
  "task": {
    "show_status_indicator": true
  },

  // Telemetry (opt-out if preferred)
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },

  // Auto-update
  "auto_update": true,

  // Journal
  "journal": {
    "path": "~",
    "hour_format": "hour24"
  }
}
