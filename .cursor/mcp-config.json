{
	"mcpServers": {
		"vercel": {
			"command": "pnpm",
			"args": ["mcp:vercel"],
			"env": {
				"VERCEL_API_KEY": "${VERCEL_API_KEY}",
				"VERCEL_TOKEN": "${VERCEL_TOKEN}"
			}
		},
		"stripe": {
			"command": "pnpm",
			"args": ["mcp:stripe"],
			"env": {
				"STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}"
			}
		}
	}
}
