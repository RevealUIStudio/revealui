apiVersion: v1
kind: Secret
metadata:
  name: revealui-secrets
  namespace: revealui
type: Opaque
stringData:
  # Database
  DATABASE_URL: "postgresql://user:password@postgres:5432/revealui"
  POSTGRES_PASSWORD: "change-this-password"

  # JWT & Auth
  JWT_SECRET: "change-this-secret-32-chars-min"
  NEXTAUTH_SECRET: "change-this-secret-32-chars-min"

  # S3 Storage
  S3_ACCESS_KEY: "change-this-access-key"
  S3_SECRET_KEY: "change-this-secret-key"

  # Monitoring
  SENTRY_DSN: ""

  # Email (optional)
  SMTP_PASSWORD: ""

  # OAuth (optional)
  GOOGLE_CLIENT_SECRET: ""
  GITHUB_CLIENT_SECRET: ""
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: revealui-config
  namespace: revealui
data:
  NODE_ENV: "production"
  PORT: "3000"
  LOG_LEVEL: "info"

  # Database
  POSTGRES_DB: "revealui"
  POSTGRES_USER: "revealui"

  # S3 Storage
  S3_ENDPOINT: "https://s3.amazonaws.com"
  S3_BUCKET: "revealui-media"
  S3_REGION: "us-east-1"

  # Application
  NEXTAUTH_URL: "https://revealui.example.com"
  API_URL: "https://api.revealui.example.com"

  # Feature Flags
  ENABLE_ANALYTICS: "true"
  ENABLE_MONITORING: "true"

  # Rate Limiting
  RATE_LIMIT_MAX: "100"
  RATE_LIMIT_WINDOW: "60000"

  # Email (optional)
  SMTP_HOST: "smtp.sendgrid.net"
  SMTP_PORT: "587"
  SMTP_USER: "apikey"
  SMTP_FROM: "noreply@revealui.example.com"

  # OAuth (optional)
  GOOGLE_CLIENT_ID: ""
  GITHUB_CLIENT_ID: ""
