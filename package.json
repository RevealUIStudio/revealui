{
  "name": "reveal-ui",
  "description": "monorepo for RevealUI",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "install:clean": "cross-env NODE_OPTIONS=\"--no-deprecation\" pnpm install",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist packages/*/.next apps/*/.next packages/*/.turbo apps/*/.turbo .next .turbo",
    "clean:install": "pnpm clean && pnpm install:clean",
    "postinstall": "tsx scripts/setup/postinstall.ts",
    "build": "turbo run build --parallel",
    "build:auth": "pnpm --filter @revealui/auth build",
    "dev": "tsx scripts/workflows/engine.ts --pre-hook && turbo run dev --parallel",
    "dev:cms": "pnpm run build:auth && pnpm --filter cms dev",
    "monitor": "tsx scripts/gates/ops/monitor.ts",
    "monitor:watch": "tsx scripts/gates/ops/monitor.ts --watch",
    "build:cms": "pnpm run build:auth && pnpm --filter cms build",
    "format": "biome format --write .",
    "lint": "pnpm lint:biome && pnpm lint:eslint",
    "lint:biome": "biome check .",
    "lint:eslint": "turbo run eslint .",
    "lint:fix": "biome check --write . && eslint . --fix",
    "typecheck:all": "pnpm -r typecheck",
    "test": "turbo run test --concurrency=15",
    "test:coverage": "turbo run test:coverage",
    "test:integration": "tsx scripts/dev-tools/run-integration-tests.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:report": "playwright show-report",
    "playwright:install": "playwright install --with-deps",
    "benchmark:queries": "tsx scripts/performance/benchmark-queries.ts",
    "benchmark:api": "tsx scripts/performance/benchmark-api.ts",
    "benchmark:api:compression": "tsx scripts/performance/benchmark-api.ts compression",
    "benchmark:api:caching": "tsx scripts/performance/benchmark-api.ts caching",
    "benchmark:api:payload": "tsx scripts/performance/benchmark-api.ts payload",
    "benchmark:api:rate-limit": "tsx scripts/performance/benchmark-api.ts rate-limit",
    "benchmark:api:combined": "tsx scripts/performance/benchmark-api.ts combined",
    "benchmark:bundle": "tsx scripts/performance/benchmark-bundle.ts",
    "benchmark:bundle:build": "tsx scripts/performance/benchmark-bundle.ts build",
    "benchmark:bundle:size": "tsx scripts/performance/benchmark-bundle.ts size",
    "benchmark:bundle:splitting": "tsx scripts/performance/benchmark-bundle.ts splitting",
    "benchmark:bundle:dynamic": "tsx scripts/performance/benchmark-bundle.ts dynamic",
    "benchmark:bundle:assets": "tsx scripts/performance/benchmark-bundle.ts assets",
    "benchmark:bundle:tree-shaking": "tsx scripts/performance/benchmark-bundle.ts tree-shaking",
    "benchmark:bundle:compression": "tsx scripts/performance/benchmark-bundle.ts compression",
    "benchmark:cache": "tsx scripts/performance/benchmark-cache.ts",
    "benchmark:cache:cdn": "tsx scripts/performance/benchmark-cache.ts cdn",
    "benchmark:cache:keys": "tsx scripts/performance/benchmark-cache.ts keys",
    "benchmark:cache:optimistic": "tsx scripts/performance/benchmark-cache.ts optimistic",
