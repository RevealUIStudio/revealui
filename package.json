    "build-cache:stats": "tsx scripts/cli/build-cache.ts stats",
    "build-cache:list": "tsx scripts/cli/build-cache.ts list",
    "build-cache:clear": "tsx scripts/cli/build-cache.ts clear",
    "build-cache:cleanup": "tsx scripts/cli/build-cache.ts cleanup",
    "build-cache:info": "tsx scripts/cli/build-cache.ts info",
    "metrics": "tsx scripts/cli/metrics.ts",
