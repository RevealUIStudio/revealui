    "analyze:audit-docs": "tsx scripts/cli/analyze.ts audit-docs",
    "analyze:dependencies": "tsx scripts/cli/analyze.ts dependencies",
    "automation:engine": "tsx scripts/workflows/engine.ts",
    "db:init": "tsx scripts/setup/database.ts",
    "db:migrate": "tsx scripts/setup/migrations.ts",
    "db:reset": "tsx scripts/setup/reset-database.ts",
    "db:seed": "dotenv -- tsx scripts/setup/seed-sample-content.ts",
