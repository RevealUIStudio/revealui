{
  "name": "reveal-ui",
  "description": "monorepo for RevealUI",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "install:clean": "cross-env NODE_OPTIONS=\"--no-deprecation\" pnpm install",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist packages/*/.next apps/*/.next packages/*/.turbo apps/*/.turbo .next .turbo",
    "clean:install": "pnpm clean && pnpm install:clean",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node scripts/setup/postinstall.mjs",
    "build": "turbo run build --parallel",
    "dev": "tsx scripts/automation/engine.ts --pre-hook && turbo run dev --parallel",
    "format": "biome format --write .",
    "lint": "pnpm lint:biome && pnpm lint:eslint",
    "lint:biome": "biome check .",
    "lint:eslint": "turbo run lint:eslint",
    "lint:fix": "biome check --write .",
    "typecheck:all": "pnpm -r typecheck",
    "test": "turbo run test --concurrency=15",
    "test:coverage": "turbo run test:coverage",
    "test:integration": "tsx scripts/test/run-integration-tests.ts",
    "analysis:quality": "tsx scripts/analysis/analyze-code-quality.ts",
    "analysis:types": "tsx scripts/analysis/analyze-types.ts",
    "analysis:console": "tsx scripts/analysis/audit-console-usage.ts",
    "automation:engine": "tsx scripts/automation/engine.ts",
    "db:init": "tsx scripts/database/init-database.ts",
    "db:migrate": "tsx scripts/database/run-migration.ts",
    "db:reset": "tsx scripts/database/reset-database.ts",
    "db:seed": "dotenv -- tsx scripts/database/seed-sample-content.ts",
    "db:setup-test": "tsx scripts/database/setup-test-db.ts",
    "deploy": "tsx scripts/dev/deploy.ts",
    "docs:manage": "tsx scripts/docs/manage-docs.ts",
    "docs:generate": "tsx scripts/docs/generate-content.ts",
    "docs:test": "cd scripts && pnpm exec vitest run",
    "mcp:all": "concurrently \"pnpm run mcp:vercel\" \"pnpm run mcp:stripe\" \"pnpm run mcp:neon\" \"pnpm run mcp:supabase\" \"pnpm run mcp:playwright\" \"pnpm run mcp:next-devtools\"",
    "mcp:vercel": "tsx scripts/mcp/mcp-vercel.ts",
    "mcp:stripe": "tsx scripts/mcp/mcp-stripe.ts",
    "mcp:neon": "tsx scripts/mcp/mcp-neon.ts",
    "mcp:supabase": "tsx scripts/mcp/mcp-supabase.ts",
    "mcp:playwright": "tsx scripts/mcp/mcp-playwright.ts",
    "mcp:next-devtools": "tsx scripts/mcp/mcp-next-devtools.ts",
    "setup:env": "tsx scripts/setup/setup-env.ts",
    "setup:node": "tsx scripts/setup/setup-node-version.ts",
    "validate:env": "tsx scripts/setup/validate-env.ts",
    "validate:package-scripts": "tsx scripts/validation/validate-package-scripts.ts",
    "validate:pre-launch": "tsx scripts/validation/pre-launch-validation.ts",
    "validate:console": "tsx scripts/validation/check-console-statements.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@neondatabase/mcp-server-neon": "^0.6.5",
    "@stripe/mcp": "^0.2.5",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/ui": "^4.0.17",
    "autocannon": "^7.15.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "fast-glob": "^3.3.3",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "next-devtools-mcp": "^0.3.10",
    "pg": "^8.17.1",
    "supabase-mcp": "^1.5.0",
    "tsx": "^4.21.0",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "vercel-mcp": "^0.0.7",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "pnpm": {
    "overrides": {
      "form-data": ">=4.0.4",
      "path-to-regexp": ">=6.3.0",
      "tar-fs": ">=2.1.4",
      "drizzle-orm": "^0.45.1",
      "zod-to-json-schema": "^3.24.0"
    }
  },
  "packageManager": "pnpm@9.14.2",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ]
  }
}
