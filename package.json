{
  "name": "reveal-ui",
  "description": "monorepo for RevealUI",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "install:clean": "cross-env NODE_OPTIONS=\"--no-deprecation\" pnpm install",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist packages/*/.next apps/*/.next packages/*/.turbo apps/*/.turbo .next .turbo",
    "clean:install": "pnpm clean && pnpm install:clean",
    "postinstall": "tsx scripts/setup/postinstall.ts",
    "build": "turbo run build --parallel",
    "build:auth": "pnpm --filter @revealui/auth build",
    "dev": "tsx scripts/orchestration/engine.ts --pre-hook && turbo run dev --parallel",
    "dev:cms": "pnpm run build:auth && pnpm --filter cms dev",
    "build:cms": "pnpm run build:auth && pnpm --filter cms build",
    "format": "biome format --write .",
    "lint": "pnpm lint:biome && pnpm lint:eslint",
    "lint:biome": "biome check .",
    "lint:eslint": "turbo run eslint .",
    "lint:fix": "biome check --write . && eslint . --fix",
    "typecheck:all": "pnpm -r typecheck",
    "test": "turbo run test --concurrency=15",
    "test:coverage": "turbo run test:coverage",
    "test:integration": "tsx scripts/setup/run-integration-tests.ts",
    "analysis:quality": "tsx scripts/analyze/code-quality.ts",
    "analysis:types": "tsx scripts/analyze/types.ts",
    "analysis:console": "tsx scripts/analyze/console-usage.ts",
    "automation:engine": "tsx scripts/orchestration/engine.ts",
    "db:init": "tsx scripts/setup/database.ts",
    "db:migrate": "tsx scripts/setup/migrations.ts",
    "db:reset": "tsx scripts/setup/reset-database.ts",
    "db:seed": "dotenv -- tsx scripts/setup/seed-sample-content.ts",
    "db:setup-test": "tsx scripts/setup/test-database.ts",
    "db:backup": "tsx scripts/commands/database/backup.ts",
    "db:restore": "tsx scripts/commands/database/restore.ts",
    "db:status": "tsx scripts/commands/database/status.ts",
    "deploy": "tsx scripts/gates/ops/deploy.ts",
    "docs:manage": "tsx scripts/orchestration/manage-docs.ts",
    "docs:generate": "tsx scripts/generate/generate-content.ts",
    "docs:test": "pnpm exec vitest run --config scripts/__tests__/vitest.config.ts",
    "mcp:all": "concurrently \"pnpm run mcp:vercel\" \"pnpm run mcp:stripe\" \"pnpm run mcp:neon\" \"pnpm run mcp:supabase\" \"pnpm run mcp:playwright\" \"pnpm run mcp:next-devtools\"",
    "mcp:vercel": "tsx scripts/mcp/adapters/vercel.ts",
    "mcp:stripe": "tsx scripts/mcp/adapters/stripe.ts",
    "mcp:neon": "tsx scripts/mcp/adapters/neon.ts",
    "mcp:supabase": "tsx scripts/mcp/adapters/supabase.ts",
    "mcp:playwright": "tsx scripts/mcp/adapters/playwright.ts",
    "mcp:next-devtools": "tsx scripts/mcp/adapters/next-devtools.ts",
    "setup:env": "tsx scripts/setup/environment.ts",
    "setup:node": "tsx scripts/setup/setup-node-version.ts",
    "validate:env": "tsx scripts/setup/validate-env.ts",
    "validate:docs": "tsx scripts/validate/validate-docs-comprehensive.ts",
    "validate:docs:json": "tsx scripts/validate/validate-docs-comprehensive.ts --json",
    "validate:package-scripts": "tsx scripts/validate/validate-package-scripts.ts",
    "validate:pre-launch": "tsx scripts/validate/pre-launch.ts",
    "validate:console": "tsx scripts/validate/console-statements.ts",
    "fix:import-extensions": "tsx scripts/analyze/fix-import-extensions.ts",
    "fix:import-extensions:dry": "tsx scripts/analyze/fix-import-extensions.ts --dry-run",
    "workflow:start": "tsx scripts/cli/workflow.ts start",
    "workflow:status": "tsx scripts/cli/workflow.ts status",
    "workflow:approve": "tsx scripts/cli/workflow.ts approve",
    "workflow:resume": "tsx scripts/cli/workflow.ts resume",
    "workflow:cancel": "tsx scripts/cli/workflow.ts cancel",
    "workflow:list": "tsx scripts/cli/workflow.ts list",
    "skills": "tsx scripts/cli/skills.ts",
    "skills:add": "tsx scripts/cli/skills.ts add",
    "skills:list": "tsx scripts/cli/skills.ts list",
    "skills:info": "tsx scripts/cli/skills.ts info",
    "skills:remove": "tsx scripts/cli/skills.ts remove",
    "skills:search": "tsx scripts/cli/skills.ts search",
    "skills:create": "tsx scripts/cli/skills.ts create"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "@electric-sql/pglite": "^0.3.15",
    "@eslint/js": "^9.39.2",
    "@neondatabase/mcp-server-neon": "^0.6.5",
    "@stripe/mcp": "^0.2.5",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/ui": "^4.0.17",
    "autocannon": "^7.15.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.15.0",
    "fast-glob": "^3.3.3",
    "globals": "^15.11.0",
    "next-devtools-mcp": "^0.3.10",
    "pg": "^8.17.1",
    "supabase-mcp": "^1.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "vercel-mcp": "^0.0.7",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "pnpm": {
    "overrides": {
      "form-data": ">=4.0.4",
      "path-to-regexp": ">=6.3.0",
      "tar-fs": ">=2.1.4",
      "drizzle-orm": "^0.45.1"
    }
  },
  "packageManager": "pnpm@10.28.2",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ]
  }
}
