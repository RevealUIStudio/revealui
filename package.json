{
  "name": "revealui",
  "version": "0.1.0",
  "private": true,
  "description": "The agentic business runtime. Users, content, products, payments, and AI — pre-wired, open source, and ready to deploy.",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.8",
    "@changesets/cli": "^2.29.8",
    "@electric-sql/pglite": "^0.4.2",
    "@lhci/cli": "^0.15.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.0",
    "@size-limit/webpack": "^12.0.0",
    "@stripe/mcp": "^0.3.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autocannon": "^8.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.4",
    "dotenv-cli": "^11.0.0",
    "fast-glob": "^3.3.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "next": "^16.2.0",
    "next-devtools-mcp": "^0.3.10",
    "pg": "^8.18.0",
    "playwright": "^1.58.2",
    "size-limit": "^12.0.0",
    "supabase-mcp": "^1.5.0",
    "syncpack": "^14.3.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2",
    "vercel": "^50.37.3",
    "vercel-mcp": "^0.0.7",
    "vitest": "^4.1.0",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "form-data": ">=4.0.4",
      "path-to-regexp": ">=6.3.0",
      "tar-fs": ">=2.1.4",
      "tar": ">=7.5.11",
      "drizzle-orm": "^0.45.2",
      "lodash": ">=4.17.23",
      "cross-spawn": ">=7.0.5",
      "qs": ">=6.14.2",
      "axios": ">=1.13.5",
      "h3": ">=1.15.5",
      "on-headers": ">=1.1.0",
      "tmp": ">=0.2.4",
      "prismjs": ">=1.30.0",
      "jsondiffpatch": ">=0.7.2",
      "markdown-it": ">=14.1.1",
      "minimatch": ">=10.2.4",
      "rollup": ">=4.59.0",
      "serialize-javascript": ">=7.0.3",
      "immutable": ">=5.1.5",
      "ajv": ">=8.18.0",
      "agents": ">=0.3.10",
      "langsmith": ">=0.4.6",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "undici": ">=7.24.0",
      "@tootallnate/once": ">=3.0.1",
      "flatted": ">=3.4.1",
      "yauzl": ">=3.2.1",
      "esbuild": ">=0.25.0",
      "body-parser": ">=2.2.1",
      "next": ">=15.5.10",
      "react": ">=19.2.4",
      "react-dom": ">=19.2.4",
      "basic-ftp": ">=5.2.0",
      "underscore": ">=1.13.8",
      "express-rate-limit": ">=8.2.2",
      "srvx": ">=0.11.13",
      "smol-toml": ">=1.6.1",
      "@revealui/config": "workspace:*",
      "@revealui/contracts": "workspace:*",
      "@revealui/db": "workspace:*"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "patchedDependencies": {}
  },
  "scripts": {
    "audit:any": "tsx scripts/analyze/audit-any-types.ts",
    "audit:console": "tsx scripts/analyze/audit-console.ts",
    "billing:catalog:sync": "tsx scripts/setup/sync-billing-catalog.ts",
    "bitnet:install": "bash scripts/bitnet/install.sh",
    "bitnet:serve": "bash scripts/bitnet/serve.sh",
    "build": "turbo run build",
    "build:api": "pnpm --filter api build",
    "build:auth": "pnpm --filter @revealui/auth build",
    "build:cms": "pnpm run build:auth && pnpm --filter cms build",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist packages/*/.next apps/*/.next packages/*/.turbo apps/*/.turbo .next .turbo",
    "clean:install": "pnpm clean && pnpm install:clean",
    "coverage:check": "tsx scripts/gates/test-coverage-gate.ts",
    "db:generate-types": "tsx scripts/dev-tools/post-migration-types.ts",
    "db:init": "tsx scripts/setup/database.ts",
    "db:migrate": "tsx scripts/setup/migrations.ts",
    "db:migrate-and-generate": "pnpm db:migrate && pnpm db:generate-types",
    "db:reset": "tsx scripts/setup/reset-database.ts",
    "db:seed": "pnpm db:seed:cms && pnpm db:seed:billing",
    "db:seed:billing": "dotenv -- tsx scripts/setup/seed-billing.ts",
    "db:seed:cms": "dotenv -- tsx --tsconfig apps/cms/tsconfig.json apps/cms/src/seed.ts",
    "deploy": "tsx scripts/gates/ops/deploy.ts",
    "deps:check": "syncpack lint",
    "deps:circular": "turbo run typecheck 2>&1 | grep -i circular || echo 'No circular dependencies detected'",
    "deps:fix": "syncpack fix && syncpack format",
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter api dev",
    "dev:app": "pnpm run build:auth && concurrently --kill-others-on-fail -n cms,api -c cyan,yellow \"pnpm --filter cms dev\" \"pnpm --filter api dev\"",
    "dev:cms": "pnpm run build:auth && pnpm --filter cms dev",
    "dev:down": "node packages/cli/bin/revealui.js dev down",
    "dev:focus": "tsx scripts/dev-tools/dev-focus.ts",
    "dev:shell": "bash scripts/dev-tools/revealui-shell.sh",
    "dev:status": "node packages/cli/bin/revealui.js dev status",
    "dev:up": "bash scripts/dev-tools/revealui-shell.sh",
    "dev:watched": "tsx scripts/dev-tools/dev-watchdog.ts",
    "docs:generate:api": "tsx scripts/docs/generate-api.ts",
    "format": "biome format --write .",
    "gate": "tsx scripts/gates/ci-gate.ts",
    "gate:quick": "tsx scripts/gates/ci-gate.ts --phase=1",
    "gate:security": "tsx scripts/gates/security-gate.ts",
    "gate:types": "tsx scripts/gates/types-gate.ts",
    "install:clean": "cross-env NODE_OPTIONS=\"--no-deprecation\" pnpm install",
    "lint": "pnpm lint:biome",
    "lint:biome": "biome check .",
    "lint:fix": "biome check --write .",
    "playwright:install": "playwright install --with-deps",
    "preflight": "tsx scripts/validate/pre-launch.ts",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "release": "tsx scripts/cli/release.ts",
    "release:dry-run": "tsx scripts/cli/release.ts dry-run",
    "release:oss": "tsx scripts/cli/release.ts oss",
    "release:pro": "tsx scripts/cli/release.ts pro",
    "release:status": "tsx scripts/cli/release.ts status",
    "revealui": "node packages/cli/bin/revealui.js",
    "scripts": "tsx scripts/cli/scripts.ts",
    "secrets:scan": "tsx scripts/secrets/scan.ts",
    "setup:mcp": "tsx scripts/setup/setup-mcp.ts",
    "stripe:seed": "tsx scripts/setup/seed-stripe.ts",
    "studio:build": "cd apps/studio/src-tauri && cargo tauri build",
    "studio:dev": "cd apps/studio/src-tauri && cargo tauri dev",
    "test": "turbo run test --concurrency=15",
    "test:coverage": "turbo run test:coverage --filter=!@revealui/harnesses -- --coverage.thresholds.lines=0 --coverage.thresholds.functions=0 --coverage.thresholds.statements=0 --coverage.thresholds.branches=0",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual:update": "playwright test --update-snapshots e2e/visual-snapshots.e2e.ts",
    "test:integration": "tsx scripts/dev-tools/run-integration-tests.ts",
    "typecheck:all": "turbo run typecheck",
    "validate:boundary": "tsx scripts/validate/boundary.ts",
    "validate:gitignore": "tsx scripts/validate/gitignore-pro.ts",
    "validate:structure": "tsx scripts/validate/structure.ts",
    "validate:versions": "tsx scripts/validate/version-policy.ts"
  },
  "type": "module"
}
