{
  "name": "reveal-ui",
  "description": "monorepo for RevealUI",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist packages/*/.next apps/*/.next packages/*/.turbo apps/*/.turbo .next .turbo",
    "clean:install": "pnpm clean && pnpm install",
    "db:reset": "tsx scripts/database/reset-database.ts",
    "preinstall": "npx only-allow pnpm",
    "dev:packages": "pnpm run dev:all-packages",
    "dev:all-packages": "pnpm -r --filter \"./packages/*\" --parallel dev",
    "build:packages": "pnpm run build:all-packages",
    "build:all-packages": "pnpm -r --filter \"./packages/dev\" build && pnpm -r --filter \"./packages/reveal\" build && pnpm -r --filter \"./packages/revealui\" build && pnpm -r --filter \"./packages/services\" build",
    "typecheck:all": "pnpm -r typecheck",
    "test-packages": "pnpm run build:all-packages && pnpm run -r test",
    "prepublishOnly": "pnpm run test && changeset version",
    "publish:beta": "changeset pre enter beta && pnpm run prepublishOnly && changeset publish -r --tag beta && changeset pre exit",
    "publish:stable": "pnpm run prepublishOnly && changeset publish -r",
    "build": "pnpm run vercel-build",
    "vercel-build": "turbo run build --parallel",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint --concurrency=15",
    "test": "turbo run test --concurrency=15",
    "test:coverage": "turbo run test:coverage",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "generate:revealui-types": "dotenv -- pnpm --filter=cms generate:revealui-types && tsx scripts/types/copy-generated-types.ts --cms",
    "generate:supabase-types": "tsx scripts/types/generate-supabase-types.ts",
    "generate:supabase-types:dotenv": "dotenv -- tsx scripts/types/generate-supabase-types.ts",
    "generate:neon-types": "pnpm --filter @revealui/db generate:types && tsx scripts/types/copy-generated-types.ts --neon",
    "copy:generated-types": "tsx scripts/types/copy-generated-types.ts",
    "electric:generate": "pnpm dlx electric-sql generate",
    "electric:service:start": "docker compose -f docker-compose.electric.yml up -d",
    "electric:service:stop": "docker compose -f docker-compose.electric.yml down",
    "electric:service:logs": "docker compose -f docker-compose.electric.yml logs -f",
    "start:cms": "dotenv -- turbo run start --filter=cms",
    "start:web": "dotenv -- turbo run start --filter=web",
    "start": "dotenv -- turbo run start --filter=cms --filter=web",
    "install:clean": "NODE_OPTIONS=\"--no-deprecation\" pnpm install",
    "install:script": "tsx scripts/setup/install-clean.ts",
    "setup:env": "tsx scripts/setup/setup-env.ts",
    "generate:secret": "tsx scripts/setup/generate-secret.ts",
    "validate:env": "tsx scripts/setup/validate-env.ts",
    "validate:package-scripts": "tsx scripts/validation/validate-package-scripts.ts",
    "validate:pre-launch": "tsx scripts/validation/pre-launch-validation.ts",
    "validate:console": "tsx scripts/validation/check-console-statements.ts",
    "analyze:code-quality": "tsx scripts/analysis/analyze-code-quality.ts",
    "verify:services": "pnpm tsx scripts/validation/verify-services-runtime.ts",
    "verify:services:types": "pnpm tsx scripts/validation/verify-services-cms-types.ts",
    "verify:services:all": "pnpm verify:services && pnpm verify:services:types",
    "docs:check": "tsx scripts/docs/docs-lifecycle.ts check",
    "docs:archive": "tsx scripts/docs/docs-lifecycle.ts archive",
    "docs:watch": "tsx scripts/docs/docs-lifecycle.ts watch",
    "docs:clean": "tsx scripts/docs/docs-lifecycle.ts clean",
    "docs:test": "cd scripts && pnpm exec vitest run",
    "docs:test:watch": "cd scripts && pnpm exec vitest",
    "docs:verify": "tsx scripts/docs/verify-docs.ts",
    "docs:verify:links": "tsx scripts/docs/verify-docs.ts --links",
    "docs:verify:versions": "tsx scripts/docs/verify-docs.ts --versions",
    "docs:verify:commands": "tsx scripts/docs/verify-docs.ts --commands",
    "docs:verify:paths": "tsx scripts/docs/verify-docs.ts --paths",
    "docs:verify:code-examples": "tsx scripts/docs/verify-docs.ts --code-examples",
    "docs:verify:consolidation": "tsx scripts/docs/verify-docs.ts --consolidation",
    "docs:verify:all": "tsx scripts/docs/verify-docs.ts --all",
    "docs:organize": "tsx scripts/docs/organize-docs.ts",
    "docs:consolidate": "tsx scripts/docs/consolidate-root-docs.ts",
    "docs:generate:api": "tsx scripts/docs/generate-api-docs.ts",
    "docs:generate:readme": "tsx scripts/docs/generate-package-readme.ts",
    "docs:validate:jsdoc": "tsx scripts/docs/validate-jsdoc.ts",
    "docs:coverage": "tsx scripts/docs/jsdoc-coverage.ts",
    "docs:generate:site": "tsx scripts/docs/build-docs-site.ts",
    "docs:generate:all": "pnpm docs:generate:api && pnpm docs:generate:readme && pnpm docs:generate:site",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:serve": "pnpm --filter docs preview",
    "docs:validate:all": "tsx scripts/docs/validate-all.ts",
    "docs:maintenance": "tsx scripts/docs/maintenance-check.ts",
    "mcp:vercel": "tsx scripts/mcp/mcp-vercel.ts",
    "mcp:stripe": "tsx scripts/mcp/mcp-stripe.ts",
    "mcp:neon": "tsx scripts/mcp/mcp-neon.ts",
    "mcp:supabase": "tsx scripts/mcp/mcp-supabase.ts",
    "mcp:playwright": "tsx scripts/mcp/mcp-playwright.ts",
    "mcp:next-devtools": "tsx scripts/mcp/mcp-next-devtools.ts",
    "mcp:all": "concurrently \"pnpm run mcp:vercel\" \"pnpm run mcp:stripe\" \"pnpm run mcp:neon\" \"pnpm run mcp:supabase\" \"pnpm run mcp:playwright\" \"pnpm run mcp:next-devtools\"",
    "db:init": "tsx scripts/database/init-database.ts",
    "db:fresh": "tsx scripts/database/setup-fresh-db.ts",
    "db:cleanup-sessions": "tsx scripts/database/cleanup-sessions.ts",
    "cleanup:rate-limits": "tsx scripts/database/cleanup-rate-limits.ts",
    "cleanup:failed-attempts": "tsx scripts/database/cleanup-failed-attempts.ts",
    "test:integration": "tsx scripts/test/run-integration-tests.ts",
    "test:integration:auth": "tsx scripts/test/run-integration-tests.ts",
    "test:integration:ci": "tsx scripts/test/run-integration-tests.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "db:migrate": "tsx scripts/database/run-migration.ts",
    "db:test": "tsx scripts/database/init-database.ts",
    "db:setup-test": "tsx scripts/database/setup-test-db.ts",
    "seed:content": "dotenv -- tsx scripts/database/seed-sample-content.ts",
    "test:integration:ai": "pnpm --filter @revealui/ai test __tests__/integration/",
    "test:auth-e2e": "tsx scripts/test/auth-e2e-test.ts",
    "test:auth-direct": "tsx scripts/test/auth-direct-test.ts",
    "test:validation": "tsx scripts/validation/run-automated-validation.ts",
    "validate:security": "tsx scripts/validation/security-test.ts",
    "validate:root-markdown": "tsx scripts/validation/validate-root-markdown.ts",
    "rollback:markdown-move": "tsx scripts/deployment/rollback-markdown-move.ts",
    "test:setup-db": "tsx scripts/database/setup-test-db.ts",
    "test:performance": "tsx scripts/test/performance-baseline.ts",
    "test:performance:regression": "tsx scripts/test/performance-regression.ts",
    "test:api-routes": "tsx scripts/validation/test-api-routes.ts",
    "validate:automation": "tsx scripts/validation/validate-automation.ts",
    "validate:production": "tsx scripts/validation/validate-production.ts",
    "db:setup-simple": "tsx scripts/database/setup-test-db-simple.ts",
    "setup:docker-wsl2": "tsx scripts/setup/setup-docker-wsl2.ts",
    "docs:archive-assessments": "tsx scripts/deployment/archive-assessments.ts",
    "ralph:start": "tsx scripts/ralph/start.ts",
    "ralph:status": "tsx scripts/ralph/status.ts",
    "ralph:continue": "tsx scripts/ralph/continue.ts",
    "ralph:cancel": "tsx scripts/ralph/cancel.ts",
    "cohesion:analyze": "tsx scripts/cohesion/analyze.ts",
    "cohesion:assess": "tsx scripts/cohesion/assess.ts",
    "cohesion:fix": "tsx scripts/cohesion/fix.ts",
    "cohesion:ralph": "tsx scripts/cohesion/ralph.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "@neondatabase/mcp-server-neon": "^0.6.5",
    "@stripe/mcp": "^0.2.5",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitest/ui": "^4.0.16",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "fast-glob": "^3.3.3",
    "next-devtools-mcp": "^0.3.9",
    "pg": "^8.16.3",
    "supabase-mcp": "^1.5.0",
    "tsx": "^4.21.0",
    "turbo": "^2.7.3",
    "typescript": "^5.9.3",
    "vercel-mcp": "^0.0.7",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "pnpm": {
    "overrides": {
      "form-data": ">=4.0.4",
      "path-to-regexp": ">=6.3.0",
      "tar-fs": ">=2.1.4",
      "drizzle-orm": "^0.45.1",
      "electric-sql>zod": "^4.3.5",
      "zod-to-json-schema": "^3.24.0"
    }
  },
  "packageManager": "pnpm@9.14.2"
}
