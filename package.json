{
  "name": "reveal-ui",
  "description": "monorepo for RevealUI",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "install:clean": "cross-env NODE_OPTIONS=\"--no-deprecation\" pnpm install",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist packages/*/.next apps/*/.next packages/*/.turbo apps/*/.turbo .next .turbo",
    "clean:install": "pnpm clean && pnpm install:clean",
    "postinstall": "tsx scripts/engineer/setup/postinstall.ts",
    "build": "turbo run build --parallel",
    "dev": "tsx scripts/engineer/automation/engine.ts --pre-hook && turbo run dev --parallel",
    "format": "biome format --write .",
    "lint": "pnpm lint:biome && pnpm lint:eslint",
    "lint:biome": "biome check .",
    "lint:eslint": "turbo run eslint .",
    "lint:fix": "biome check --write . && eslint . --fix",
    "typecheck:all": "pnpm -r typecheck",
    "test": "turbo run test --concurrency=15",
    "test:coverage": "turbo run test:coverage",
    "test:integration": "tsx scripts/engineer/test/run-integration-tests.ts",
    "analysis:quality": "tsx scripts/engineer/analysis/analyze-code-quality.ts",
    "analysis:types": "tsx scripts/engineer/analysis/analyze-types.ts",
    "analysis:console": "tsx scripts/engineer/analysis/audit-console-usage.ts",
    "automation:engine": "tsx scripts/engineer/automation/engine.ts",
    "db:init": "tsx scripts/engineer/setup/init-database.ts",
    "db:migrate": "tsx scripts/engineer/setup/run-migration.ts",
    "db:reset": "tsx scripts/engineer/setup/reset-database.ts",
    "db:seed": "dotenv -- tsx scripts/engineer/setup/seed-sample-content.ts",
    "db:setup-test": "tsx scripts/engineer/setup/setup-test-db.ts",
    "db:backup": "tsx scripts/commands/database/backup.ts",
    "db:restore": "tsx scripts/commands/database/restore.ts",
    "db:status": "tsx scripts/commands/database/status.ts",
    "deploy": "tsx scripts/engineer/dev/deploy.ts",
    "docs:manage": "tsx scripts/engineer/docs/manage-docs.ts",
    "docs:generate": "tsx scripts/engineer/docs/generate-content.ts",
    "docs:test": "cd scripts typed/&& pnpm exec vitest run",
    "mcp:all": "concurrently \"pnpm run mcp:vercel\" \"pnpm run mcp:stripe\" \"pnpm run mcp:neon\" \"pnpm run mcp:supabase\" \"pnpm run mcp:playwright\" \"pnpm run mcp:next-devtools\"",
    "mcp:vercel": "tsx scripts/engineer/mcp/mcp-vercel.ts",
    "mcp:stripe": "tsx scripts/engineer/mcp/mcp-stripe.ts",
    "mcp:neon": "tsx scripts/engineer/mcp/mcp-neon.ts",
    "mcp:supabase": "tsx scripts/engineer/mcp/mcp-supabase.ts",
    "mcp:playwright": "tsx scripts/engineer/mcp/mcp-playwright.ts",
    "mcp:next-devtools": "tsx scripts/engineer/mcp/mcp-next-devtools.ts",
    "setup:env": "tsx scripts/engineer/setup/setup-env.ts",
    "setup:node": "tsx scripts/engineer/setup/setup-node-version.ts",
    "validate:env": "tsx scripts/engineer/setup/validate-env.ts",
    "validate:package-scripts": "tsx scripts/engineer/validation/validate-package-scripts.ts",
    "validate:pre-launch": "tsx scripts/engineer/validation/pre-launch-validation.ts",
    "validate:console": "tsx scripts/engineer/gates/validation/check-console-statements.ts",
    "fix:import-extensions": "tsx scripts/engineer/gates/quality/fix-import-extensions.ts",
    "fix:import-extensions:dry": "tsx scripts/engineer/gates/quality/fix-import-extensions.ts --dry-run",
    "workflow:start": "tsx scripts/cli/workflow.ts start",
    "workflow:status": "tsx scripts/cli/workflow.ts status",
    "workflow:approve": "tsx scripts/cli/workflow.ts approve",
    "workflow:resume": "tsx scripts/cli/workflow.ts resume",
    "workflow:cancel": "tsx scripts/cli/workflow.ts cancel",
    "workflow:list": "tsx scripts/cli/workflow.ts list"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@neondatabase/mcp-server-neon": "^0.6.5",
    "@stripe/mcp": "^0.2.5",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/ui": "^4.0.17",
    "autocannon": "^7.15.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.15.0",
    "fast-glob": "^3.3.3",
    "globals": "^15.11.0",
    "next-devtools-mcp": "^0.3.10",
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "pg": "^8.17.1",
    "supabase-mcp": "^1.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "vercel-mcp": "^0.0.7",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "pnpm": {
    "overrides": {
      "form-data": ">=4.0.4",
      "path-to-regexp": ">=6.3.0",
      "tar-fs": ">=2.1.4",
      "drizzle-orm": "^0.45.1"
    }
  },
  "packageManager": "pnpm@10.28.2",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ]
  }
}
