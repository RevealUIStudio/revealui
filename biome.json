{
  "$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "!**/dist",
      "!**/node_modules",
      "!**/.next",
      "!**/build",
      "!**/.cursor",
      "!**/.turbo",
      "!**/.vite",
      "!**/coverage",
      "!**/*.min.js",
      "!**/*.bundle.js",
      "!**/scripts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useForOf": "error",
        "useConst": "error",
        "useTemplate": "error",
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "strictCase": false
          }
        }
      },
      "suspicious": {},
      "a11y": {
        "recommended": true
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "asNeeded",
      "arrowParentheses": "always"
    },
    "globals": ["console", "process", "__dirname", "__filename", "global", "Buffer", "NodeJS"]
  },
  "overrides": [
    {
      "includes": ["**/*.config.*", "**/eslint.config.*", "**/vite.config.*"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["**/*.test.*", "**/*.spec.*", "**/__tests__/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "warn"
          },
          "style": {
            "noNonNullAssertion": "warn"
          }
        }
      }
    },
    {
      "includes": ["apps/web/src/components/Builder.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "warn"
          }
        }
      }
    },
    {
      "includes": ["**/generated/**", "**/types/database.ts", "**/types/neon.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noBannedTypes": "warn"
          }
        }
      }
    },
    {
      "includes": ["**/schema/**/contracts/**", "**/core/contracts/**"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "warn"
          }
        }
      }
    }
  ],
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
