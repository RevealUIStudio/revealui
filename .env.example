# RevealUI Environment Configuration
# Copy this file to .env and fill in your values

# Vercel MCP Configuration
# Get your token from: https://vercel.com/account/tokens
VERCEL_API_KEY=your_vercel_api_key_here

# Stripe MCP Configuration
# Get your secret key from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Other environment variables for your application
# Add your application-specific environment variables here
