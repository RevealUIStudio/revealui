# =============================================================================
# RevealUI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have sensible defaults.
#
# For Nix+direnv users: secrets are loaded via Revvault in .envrc
# =============================================================================

# =============================================================================
# Database [REQUIRED]
# =============================================================================

# Primary REST database (NeonDB or Supabase)
# Used for: users, sessions, content, billing, tickets
POSTGRES_URL=postgresql://user:password@host:5432/dbname

# Vector database (Supabase with pgvector)
# Used for: AI memory embeddings, agent tasks, semantic search
# Note: DATABASE_URL is accepted as fallback but SUPABASE_DATABASE_URL is preferred
# (DATABASE_URL is reserved for ElectricSQL in Railway deployments)
SUPABASE_DATABASE_URL=postgresql://user:password@host.supabase.co:6543/postgres

# Supabase direct connection (for migrations and admin operations)
# SUPABASE_DATABASE_URI=postgresql://postgres:password@db.project.supabase.co:5432/postgres

# =============================================================================
# Database Pool [OPTIONAL]
# =============================================================================

# DB_POOL_MAX=10                    # Max connections in pg pool (default: 10)
# DB_POOL_IDLE_TIMEOUT=30000        # Idle connection timeout in ms (default: 30000)

# =============================================================================
# Authentication [REQUIRED in production]
# =============================================================================

# Secret key for signing session cookies and CSRF tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REVEALUI_SECRET=INSECURE-DEV-ONLY-CHANGE-ME-SET-REVEALUI_SECRET-IN-PRODUCTION

# Cookie domain for session cookies (e.g., .revealui.com)
# Required in production — omit for localhost development
# SESSION_COOKIE_DOMAIN=.yourdomain.com

# =============================================================================
# OAuth Providers [OPTIONAL — enable as needed]
# =============================================================================

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Vercel OAuth
# VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=

# Restrict OAuth sign-up to specific email addresses (comma-separated)
# Empty = allow all authenticated users
# OAUTH_ADMIN_EMAILS=admin@example.com,dev@example.com

# =============================================================================
# Stripe / Billing [REQUIRED for paid features]
# =============================================================================

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...   # Separate secret for live mode

# Early adopter promotion (optional)
# REVEALUI_EARLY_ADOPTER_END=2026-06-01
# REVEALUI_EARLY_ADOPTER_COUPON_PRO=coupon_xxx
# REVEALUI_EARLY_ADOPTER_COUPON_MAX=coupon_xxx

# Agent task metering (optional — Stripe Billing Meters)
# STRIPE_AGENT_METER_EVENT_NAME=agent_task_usage

# =============================================================================
# License System [REQUIRED for Pro/Enterprise features]
# =============================================================================

# RS256 key pair for signing/verifying license JWTs
# Generate with: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#                openssl rsa -in private.pem -pubout -out public.pem
# REVEALUI_LICENSE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY----- # gitleaks:allow
# REVEALUI_LICENSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Pre-generated license key (JWT signed with private key above)
# REVEALUI_LICENSE_KEY=eyJ...

# Encryption key for license keys at rest (AES-256-GCM, 32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REVEALUI_LICENSE_ENCRYPTION_KEY=

# =============================================================================
# Application URLs [REQUIRED in production]
# =============================================================================

# Public-facing URLs
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:3004
# NEXT_PUBLIC_CMS_URL=https://cms.yourdomain.com
# NEXT_PUBLIC_MARKETING_URL=https://yourdomain.com

# CORS allowed origins (comma-separated)
# CORS_ORIGIN=https://cms.yourdomain.com,https://yourdomain.com
# REVEALUI_CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# =============================================================================
# Forge / Enterprise [OPTIONAL — for white-label deployments]
# =============================================================================

# Domain lock for Forge license enforcement
# FORGE_LICENSED_DOMAIN=client.example.com
# FORGE_LICENSE_KEY=forge_xxx

# =============================================================================
# Cron Jobs [REQUIRED for scheduled tasks]
# =============================================================================

# Secret for authenticating cron job requests (X-Cron-Secret header)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REVEALUI_CRON_SECRET=

# =============================================================================
# Observability [OPTIONAL]
# =============================================================================

# Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# Internal logging/error endpoints (token-protected)
# REVEALUI_ERROR_TOKEN=
# REVEALUI_LOG_TOKEN=

# =============================================================================
# AI / LLM Providers [OPTIONAL — for Pro AI features]
# =============================================================================

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Groq
# GROQ_API_KEY=gsk_...

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434

# Web search (for AI tools)
# TAVILY_API_KEY=tvly-...

# =============================================================================
# MCP Servers [OPTIONAL — for Pro MCP features]
# =============================================================================

# MCP_PERSISTENCE_DRIVER=pglite          # pglite (default) or postgres
# MCP_METRICS_MODE=logs                  # logs (default), prometheus, or otel
# ELECTRIC_DATABASE_URL=                 # ElectricSQL connection
# ELECTRIC_API_KEY=                      # ElectricSQL API key
# PGVECTOR_ENABLED=false                 # Enable pgvector in MCP

# =============================================================================
# Supabase Client [OPTIONAL — for Supabase JS client]
# =============================================================================

# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# =============================================================================
# Development [OPTIONAL]
# =============================================================================

# NODE_ENV=development                   # Set automatically by frameworks
# SKIP_ENV_VALIDATION=true               # Skip env validation (CI builds)
# API_PORT=3004                          # API server port (default: 3004)
# PLAYWRIGHT_BASE_URL=http://localhost:4000  # E2E test base URL

# Admin seed credentials (for scripts/seed-admin.mjs)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
# ADMIN_NAME=Admin User

# E2E test credentials
# CMS_ADMIN_EMAIL=admin@example.com
# CMS_ADMIN_PASSWORD=
# STRIPE_PRO_PRICE_ID=price_xxx
# STRIPE_ENTERPRISE_PRICE_ID=price_xxx
